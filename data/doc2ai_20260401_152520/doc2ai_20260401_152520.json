        "raw": "app:\n  name: \"Folder2Context\"\n  version: \"1.0.0\"\n  debug: false\n  host: \"0.0.0.0\"\n  port: 8000\n\nprocessing:\n  max_file_size_mb: 10\n  max_total_size_mb: 100\n  max_files: 1000\n  timeout_seconds: 300\n  encoding: \"auto\"\n  exclude_patterns:\n    - \".git\"\n    - \"__pycache__\"\n    - \"node_modules\"\n    - \".DS_Store\"\n    - \"*.pyc\"\n    - \"*.log\"\n    - \"*.tmp\"\n    - \"venv\"\n    - \"env\"\n    - \".env\"\n    - \"dist\"\n    - \"build\"\n    - \".idea\"\n    - \".vscode\"\n  include_extensions: []\n  exclude_extensions: []\n  follow_symlinks: false\n\nanalysis:\n  detect_language: true\n  extract_imports: true\n  extract_classes_functions: true\n  count_tokens: true\n  tokenizer: \"cl100k_base\"\n  max_line_count: 500\n  truncate_mode: \"head_tail\"  # head_only, tail_only, head_tail\n  head_lines: 100\n  tail_lines: 50\n\noutput:\n  format: \"detailed\"  # detailed, compact, minimal\n  include_tree: true\n  include_metadata: true\n  include_statistics: true\n  include_errors: true\n  compress_output: false\n  chunk_by_tokens: false\n  max_tokens_per_chunk: 10000\n\ncache:\n  enabled: true\n  ttl_hours: 24\n  max_size_mb: 500\n  storage_path: \"./cache\"\n\ntasks:\n  cleanup_interval_minutes: 30\n  task_expiry_hours: 24\n  storage_path: \"./tasks\"",
