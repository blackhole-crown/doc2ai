    import fitz  # PyMuPDF\\nexcept ImportError:\\n    fitz = None\\n    print(\\\"警告: PyMuPDF 未安装，无法处理 PDF 文件\\\")\\n\\n\\nclass FileReader:\\n    \\\"\\\"\\\"统一的文件读取工具类\\\"\\\"\\\"\\n    \\n    # 类变量，用于记录已处理的文件\\n    _processed_files = set()\\n    \\n    # 支持的文件类型\\n    SUPPORTED_EXTS = {\\n        '.txt': '文本文件',\\n        '.md': 'Markdown',\\n        '.markdown': 'Markdown',\\n        '.docx': 'Word文档',\\n        '.pdf': 'PDF文档'\\n    }\\n    \\n    @classmethod\\n    def read_txt(cls, file_path, encoding='utf-8'):\\n        \\\"\\\"\\\"读取 TXT 文件\\\"\\\"\\\"\\n        try:\\n            with open(file_path, 'r', encoding=encoding) as f:\\n                return f.read()\\n        except UnicodeDecodeError:\\n            # 如果 UTF-8 失败，尝试 GBK 编码\\n            try:\\n                with open(file_path, 'r', encoding='gbk') as f:\\n                    return f.read()\\n            except Exception as e:\\n                print(f\\\"读取 TXT 失败（GBK编码）: {e}\\\")\\n                return None\\n        except Exception as e:\\n            print(f\\\"读取 TXT 失败: {e}\\\")\\n            return None\\n    \\n    @classmethod\\n    def read_md(cls, file_path, encoding='utf-8'):\\n        \\\"\\\"\\\"读取 Markdown 文件\\\"\\\"\\\"\\n        return cls.read_txt(file_path, encoding)\\n    \\n    @classmethod\\n    def read_docx(cls, file_path):\\n        \\\"\\\"\\\"读取 DOCX 文件 - 完整读取所有内容\\\"\\\"\\\"\\n        if Document is None:\\n            print(\\\"错误: python-docx 未安装，无法处理 DOCX 文件\\\")\\n            return None\\n        \\n        try:\\n            doc = Document(file_path)\\n            text_parts = []\\n            \\n            # 1. 提取所有段落\\n            for para in doc.paragraphs:\\n                text_parts.append(para.text)\\n            \\n            # 2. 提取所有表格\\n            if doc.tables:\\n                text_parts.append(\\\"\\\\n\\\" + \\\"=\\\"*50)\\n                text_parts.append(\\\"表格内容：\\\")\\n                text_parts.append(\\\"=\\\"*50)\\n                \\n                for table_idx, table in enumerate(doc.tables, 1):\\n                    text_parts.append(f\\\"\\\\n表格 {table_idx}:\\\")\\n                    for row_idx, row in enumerate(table.rows):\\n                        row_text = []\\n                        for cell in row.cells:\\n                            cell_text = cell.text.strip()\\n                            if cell_text:\\n                                row_text.append(cell_text)\\n                        if row_text:\\n                            text_parts.append(f\\\"  第{row_idx+1}行: {' | '.join(row_text)}\\\")\\n                    text_parts.append(\\\"\\\")\\n            \\n            # 3. 提取页眉\\n            for section in doc.sections:\\n                if section.header:\\n                    header_text = []\\n                    for para in section.header.paragraphs:\\n                        if para.text.strip():\\n                            header_text.append(para.text)\\n                    if header_text:\\n                        text_parts.append(f\\\"\\\\n[页眉] {' '.join(header_text)}\\\")\\n            \\n            # 4. 提取页脚\\n            for section in doc.sections:\\n                if section.footer:\\n                    footer_text = []\\n                    for para in section.footer.paragraphs:\\n                        if para.text.strip():\\n                            footer_text.append(para.text)\\n                    if footer_text:\\n                        text_parts.append(f\\\"[页脚] {' '.join(footer_text)}\\\")\\n            \\n            full_text = '\\\\n'.join(text_parts)\\n            print(f\\\"DOCX 提取完成，共 {len(full_text)} 字符\\\")\\n            \\n            return full_text\\n            \\n        except Exception as e:\\n            print(f\\\"读取 DOCX 失败: {e}\\\")\\n            import traceback\\n            traceback.print_exc()\\n            return None\\n    \\n    @classmethod\\n    def read_pdf(cls, file_path):\\n        \\\"\\\"\\\"读取 PDF 文件\\\"\\\"\\\"\\n        if fitz is None:\\n            print(\\\"错误: PyMuPDF 未安装，无法处理 PDF 文件\\\")\\n            return None\\n        \\n        try:\\n            doc = fitz.open(file_path)\\n            text_parts = []\\n            \\n            for page_num, page in enumerate(doc, 1):\\n                page_text = page.get_text()\\n                if page_text.strip():\\n                    text_parts.append(f\\\"=== 第 {page_num} 页 ===\\\")\\n                    text_parts.append(page_text)\\n                    text_parts.append(\\\"\\\")\\n            \\n            doc.close()\\n            full_text = '\\\\n'.join(text_parts)\\n            print(f\\\"PDF 提取完成，共 {len(full_text)} 字符，{len(doc)} 页\\\")\\n            \\n            return full_text\\n            \\n        except Exception as e:\\n            print(f\\\"读取 PDF 失败: {e}\\\")\\n            import traceback\\n            traceback.print_exc()\\n            return None\\n    \\n    @classmethod\\n    def read_auto(cls, file_path):\\n        \\\"\\\"\\\"自动识别文件类型并读取\\\"\\\"\\\"\\n        ext = os.path.splitext(file_path)[1].lower()\\n        \\n        if ext in ['.txt', '.md', '.markdown']:\\n            return cls.read_txt(file_path)\\n        elif ext == '.docx':\\n            return cls.read_docx(file_path)\\n        elif ext == '.pdf':\\n            return cls.read_pdf(file_path)\\n        else:\\n            print(f\\\"不支持的文件类型: {ext}\\\")\\n            return None\\n    \\n    @classmethod\\n    def get_next_id(cls, jsonl_path):\\n        \\\"\\\"\\\"获取下一个可用的 ID\\\"\\\"\\\"\\n        if not os.path.exists(jsonl_path):\\n            return 1\\n        \\n        try:\\n            with open(jsonl_path, 'r', encoding='utf-8') as f:\\n                max_id = 0\\n                for line in f:\\n                    if line.strip():\\n                        data = json.loads(line)\\n                        if 'id' in data and isinstance(data['id'], int):\\n                            max_id = max(max_id, data['id'])\\n                return max_id + 1\\n        except:\\n            return 1\\n    \\n    @classmethod\\n    def save_to_jsonl(cls, file_path, content, jsonl_path='output.jsonl', metadata=None):\\n        \\\"\\\"\\\"将读取的内容保存到 JSONL 文件\\\"\\\"\\\"\\n        if content is None:\\n            print(f\\\"内容为空，跳过保存: {file_path}\\\")\\n            return None\\n        \\n        # 检查是否已经处理过这个文件\\n        abs_path = os.path.abspath(file_path)\\n        if abs_path in cls._processed_files:\\n            print(f\\\"文件已处理过，跳过: {file_path}\\\")\\n            return None\\n        \\n        # 生成 ID\\n        new_id = cls.get_next_id(jsonl_path)\\n        \\n        # 获取文件信息\\n        file_stat = os.stat(file_path)\\n        \\n        # 准备数据\\n        data = {\\n            'id': new_id,\\n            'description': content,\\n            'source_file': os.path.basename(file_path),\\n            'file_path': abs_path,\\n            'file_type': os.path.splitext(file_path)[1].lower(),\\n            'file_size': file_stat.st_size,\\n            'create_time': datetime.fromtimestamp(file_stat.st_ctime).isoformat(),\\n            'modify_time': datetime.fromtimestamp(file_stat.st_mtime).isoformat(),\\n            'process_time': datetime.now().isoformat(),\\n            'content_length': len(content)\\n        }\\n        \\n        # 添加额外元数据\\n        if metadata:\\n            data.update(metadata)\\n        \\n        # 追加写入 JSONL 文件\\n        try:\\n            with open(jsonl_path, 'a', encoding='utf-8') as f:\\n                f.write(json.dumps(data, ensure_ascii=False) + '\\\\n')\\n            cls._processed_files.add(abs_path)\\n            return new_id\\n        except Exception as e:\\n            print(f\\\"保存到 JSONL 失败: {e}\\\")\\n            return None\\n    \\n    @classmethod\\n    def process_and_save(cls, file_path, jsonl_path='output.jsonl', metadata=None):\\n        \\\"\\\"\\\"读取文件并自动保存到 JSONL\\\"\\\"\\\"\\n        if not os.path.exists(file_path):\\n            print(f\\\"文件不存在: {file_path}\\\")\\n            return None\\n        \\n        print(f\\\"正在处理文件: {file_path}\\\")\\n        \\n        # 读取文件内容\\n        content = cls.read_auto(file_path)\\n        \\n        if content:\\n            return cls.save_to_jsonl(file_path, content, jsonl_path, metadata)\\n        else:\\n            print(f\\\"读取文件失败: {file_path}\\\")\\n            return None\\n    \\n    @classmethod\\n    def read_jsonl(cls, jsonl_path):\\n        \\\"\\\"\\\"读取 JSONL 文件的所有记录\\\"\\\"\\\"\\n        records = []\\n        if os.path.exists(jsonl_path):\\n            with open(jsonl_path, 'r', encoding='utf-8') as f:\\n                for line in f:\\n                    if line.strip():\\n                        records.append(json.loads(line))\\n        return records\\n    \\n    @classmethod\\n    def process_folder(cls, folder_path, jsonl_file='output.jsonl', file_extensions=None):\\n        \\\"\\\"\\\"批量处理文件夹中的文件\\\"\\\"\\\"\\n        if file_extensions is None:\\n            file_extensions = ['.txt', '.md', '.markdown', '.docx', '.pdf']\\n        \\n        processed_count = 0\\n        \\n        for root, dirs, files in os.walk(folder_path):\\n            for file in files:\\n                ext = os.path.splitext(file)[1].lower()\\n                if ext in file_extensions:\\n                    file_path = os.path.join(root, file)\\n                    metadata = {\\n                        'category': '批量导入',\\n                        'folder': folder_path,\\n                        'import_time': datetime.now().isoformat()\\n                    }\\n                    if cls.process_and_save(file_path, jsonl_file, metadata):\\n                        processed_count += 1\\n        \\n        print(f\\\"批量处理完成，共处理 {processed_count} 个文件\\\")\\n        return processed_count\\n    \\n    @classmethod\\n    def get_by_id(cls, jsonl_path, target_id):\\n        \\\"\\\"\\\"根据 ID 获取记录\\\"\\\"\\\"\\n        if not os.path.exists(jsonl_path):\\n            print(f\\\"文件不存在: {jsonl_path}\\\")\\n            return None\\n            \\n        with open(jsonl_path, 'r', encoding='utf-8') as f:\\n            for line in f:\\n                if line.strip():\\n                    data = json.loads(line)\\n                    if data['id'] == target_id:\\n                        return data\\n        return None\\n    \\n    @classmethod\\n    def clear_processed_cache(cls):\\n        \\\"\\\"\\\"清空已处理文件缓存\\\"\\\"\\\"\\n        cls._processed_files.clear()\\n        print(\\\"已处理文件缓存已清空\\\")\\n\\n\\ndef main():\\n    \\\"\\\"\\\"使用示例\\\"\\\"\\\"\\n    jsonl_file = 'output.jsonl'\\n    \\n    # 示例1：处理单个 DOCX 文件\\n    file_path = r\\\"C:\\\\Users\\\\Administrator\\\\Desktop\\\\大三下\\\\部署指南-veritas.docx\\\"\\n    metadata = {\\n        # 'category': '部署文档',\\n        # 'author': '系统用户',\\n        # 'tags': ['部署', '配置', '指南']\\n    }\\n    \\n    if os.path.exists(file_path):\\n        file_id = FileReader.process_and_save(file_path, jsonl_file, metadata)\\n        if file_id:\\n            print(f\\\"✅ 处理成功，ID: {file_id}\\\")\\n    else:\\n        print(f\\\"文件不存在: {file_path}\\\")\\n    \\n    # 示例2：处理 MD 文件（取消注释即可使用）\\n    # md_path = r\\\"C:\\\\Users\\\\Administrator\\\\Desktop\\\\大三下\\\\sql.md\\\"\\n    # if os.path.exists(md_path):\\n    #     FileReader.process_and_save(md_path, jsonl_file, {'category': 'SQL学习'})\\n    \\n    # 示例3：批量处理文件夹\\n    # folder_path = r\\\"C:\\\\Users\\\\Administrator\\\\Desktop\\\\文档\\\"\\n    # FileReader.process_folder(folder_path, jsonl_file)\\n    \\n    # 示例4：查看所有记录\\n    # records = FileReader.read_jsonl(jsonl_file)\\n    # print(f\\\"共 {len(records)} 条记录\\\")\\n    \\n    # 示例5：根据 ID 查询\\n    # record = FileReader.get_by_id(jsonl_file, 1)\\n    # if record:\\n    #     print(f\\\"ID 1: {record['source_file']}\\\")\\n\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\",\n        \"truncated\": false\n      },\n      \"metadata\": {\n      