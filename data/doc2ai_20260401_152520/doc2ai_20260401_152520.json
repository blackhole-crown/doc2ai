idates if isinstance(candidates, list) else []\\n    if not tasks:\\n        base_tasks = []\\n        if isinstance(suggest, dict):\\n            for k, v in suggest.items():\\n                title = str(k).strip()\\n                if title:\\n                    base_tasks.append({\\\"task_title\\\": title, \\\"ai_guidance\\\": str(v)[:500], \\\"priority\\\": 3})\\n        elif isinstance(suggest, list):\\n            for idx, v in enumerate(suggest):\\n                title = str(v).strip()\\n                if title:\\n                    base_tasks.append({\\\"task_title\\\": title, \\\"ai_guidance\\\": \\\"\\\", \\\"priority\\\": 3})\\n        if not base_tasks and isinstance(gap, dict):\\n            for k in gap.keys():\\n                title = str(k).strip()\\n                if title:\\n                    base_tasks.append({\\\"task_title\\\": title, \\\"ai_guidance\\\": \\\"优先补齐该能力差距\\\", \\\"priority\\\": 3})\\n        tasks = base_tasks\\n    if not isinstance(tasks, list):\\n        tasks = []\\n    norm = []\\n    for item in tasks:\\n        if not isinstance(item, dict):\\n            continue\\n        title = str(item.get(\\\"task_title\\\") or \\\"\\\").strip()\\n        if not title:\\n            continue\\n        prio = item.get(\\\"priority\\\")\\n        try:\\n            prio = int(prio) if prio is not None else 3\\n        except Exception:\\n            prio = 3\\n        norm.append(\\n            {\\n                \\\"task_title\\\": title,\\n                \\\"priority\\\": prio,\\n                \\\"ai_guidance\\\": str(item.get(\\\"ai_guidance\\\") or \\\"\\\").strip(),\\n            }\\n        )\\n    return norm\\n\\n\\ndef _get_roadmap_tasks(roadmap_id: int) -> list[dict]:\\n    if not roadmap_id:\\n        return []\\n    rows = supabase_request(\\n        \\\"GET\\\",\\n        \\\"/rest/v1/user_roadmap_tasks\\\",\\n        params={\\\"roadmap_id\\\": f\\\"eq.{int(roadmap_id)}\\\", \\\"select\\\": \\\"*\\\", \\\"order\\\": \\\"priority.asc,created_at.asc\\\"},\\n    )\\n    if isinstance(rows, list):\\n        return rows\\n    return []\\n\\n\\ndef list_roadmaps_by_user(user_id: int) -> list[dict]:\\n    rows = supabase_request(\\n        \\\"GET\\\",\\n        \\\"/rest/v1/user_roadmaps\\\",\\n        params={\\\"user_id\\\": f\\\"eq.{int(user_id)}\\\", \\\"select\\\": \\\"*\\\", \\\"order\\\": \\\"created_at.desc\\\"},\\n    )\\n    if not isinstance(rows, list):\\n        return []\\n    out = []\\n    for row in rows:\\n        rid = int(row.get(\\\"id\\\") or 0)\\n        tasks = _get_roadmap_tasks(rid) if rid else []\\n        item = dict(row)\\n        item[\\\"tasks\\\"] = tasks\\n        item[\\\"task_count\\\"] = len(tasks)\\n        out.append(item)\\n    return out\\n\\n\\ndef get_roadmap_detail(roadmap_id: int) -> dict | None:\\n    rows = supabase_request(\\n        \\\"GET\\\",\\n        \\\"/rest/v1/user_roadmaps\\\",\\n        params={\\\"id\\\": f\\\"eq.{int(roadmap_id)}\\\", \\\"select\\\": \\\"*\\\", \\\"limit\\\": \\\"1\\\"},\\n    )\\n    if not isinstance(rows, list) or not rows:\\n        return None\\n    roadmap = rows[0]\\n    tasks = _get_roadmap_tasks(int(roadmap.get(\\\"id\\\") or 0))\\n    return {\\\"roadmap\\\": roadmap, \\\"tasks\\\": tasks}\\n\\n\\ndef _insert_tasks(roadmap_id: int, parsed_tasks: list[dict]) -> list[dict]:\\n    if not parsed_tasks:\\n        return []\\n    now = _iso_now()\\n    payload = []\\n    for t in parsed_tasks:\\n        payload.append(\\n            {\\n                \\\"roadmap_id\\\": int(roadmap_id),\\n                \\\"task_title\\\": t.get(\\\"task_title\\\"),\\n                \\\"task_type\\\": t.get(\\\"task_type\\\") or \\\"\\\",\\n                \\\"is_completed\\\": False,\\n                \\\"ai_guidance\\\": t.get(\\\"ai_guidance\\\") or \\\"\\\",\\n                \\\"priority\\\": int(t.get(\\\"priority\\\") or 3),\\n                \\\"created_at\\\": now,\\n            }\\n        )\\n    inserted = supabase_request(\\\"POST\\\", \\\"/rest/v1/user_roadmap_tasks\\\", json_data=payload)\\n    if isinstance(inserted, list):\\n        return inserted\\n    return []\\n\\n\\ndef create_roadmap(user_id: int, target_job_id: int, roadmap_vision: str | None = None) -> dict:\\n    exists = supabase_request(\\n        \\\"GET\\\",\\n        \\\"/rest/v1/user_roadmaps\\\",\\n        params={\\n            \\\"user_id\\\": f\\\"eq.{int(user_id)}\\\",\\n            \\\"target_job_id\\\": f\\\"eq.{int(target_job_id)}\\\",\\n            \\\"select\\\": \\\"*\\\",\\n            \\\"limit\\\": \\\"1\\\",\\n        },\\n    )\\n    if isinstance(exists, list) and exists:\\n        roadmap = exists[0]\\n        existed_tasks = _get_roadmap_tasks(int(roadmap.get(\\\"id\\\") or 0))\\n        if existed_tasks:\\n            return {\\\"existed\\\": True, \\\"roadmap\\\": roadmap, \\\"tasks\\\": existed_tasks}\\n        match = _get_or_create_match(user_id, target_job_id)\\n        gap = match.get(\\\"gap_analysis\\\") or {}\\n        suggest = match.get(\\\"improvement_suggestions\\\") or {}\\n        job = _get_job(target_job_id)\\n        name = job.get(\\\"job_name\\\") if job else (roadmap.get(\\\"target_job_name\\\") or str(target_job_id))\\n        tasks_parsed = _call_dify_tasks(name, gap, suggest)\\n        tasks_inserted = _insert_tasks(int(roadmap.get(\\\"id\\\") or 0), tasks_parsed)\\n        return {\\\"existed\\\": True, \\\"roadmap\\\": roadmap, \\\"tasks\\\": tasks_inserted}\\n    job = _get_job(target_job_id)\\n    name = job.get(\\\"job_name\\\") if job else \\\"\\\"\\n    now = _iso_now()\\n    payload = {\\n        \\\"user_id\\\": int(user_id),\\n        \\\"target_job_id\\\": int(target_job_id),\\n        \\\"target_job_name\\\": name,\\n        \\\"roadmap_vision\\\": roadmap_vision or \\\"\\\",\\n        \\\"is_active\\\": True,\\n        \\\"created_at\\\": now,\\n    }\\n    created = supabase_request(\\\"POST\\\", \\\"/rest/v1/user_roadmaps\\\", json