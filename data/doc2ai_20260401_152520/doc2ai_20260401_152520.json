le\\\" in data:\\n                            title_duplicate_set.add(data[\\\"title\\\"])\\n                        if \\\"id\\\" in data and isinstance(data[\\\"id\\\"], int):\\n                            max_id = max(max_id, data[\\\"id\\\"])\\n            current_auto_id = max_id + 1\\n            print(f\\\"✅ 加载历史数据完成\\\")\\n            print(f\\\"   - 历史不重复标题数：{len(title_duplicate_set)}\\\")\\n            print(f\\\"   - 下一个自增ID：{current_auto_id}\\\")\\n        except Exception as e:\\n            print(f\\\"⚠️ 加载历史数据失败：{e}，将从ID=1重新开始\\\")\\n            current_auto_id = 1\\n            title_duplicate_set = set()\\n    else:\\n        print(f\\\"ℹ️ 无历史数据，ID从1开始爬取\\\")\\n\\ndef init_edge_driver():\\n    \\\"\\\"\\\"初始化Edge浏览器（无头模式，完全隐藏窗口）\\\"\\\"\\\"\\n    edge_options = Options()\\n    # ========== 核心：开启无头模式（无浏览器窗口） ==========\\n    edge_options.add_argument(\\\"--headless=new\\\")  # 新版Edge无头模式\\n    edge_options.add_argument(\\\"--disable-blink-features=AutomationControlled\\\")\\n    edge_options.add_experimental_option(\\\"excludeSwitches\\\", [\\\"enable-automation\\\"])\\n    edge_options.add_experimental_option(\\\"useAutomationExtension\\\", False)\\n    edge_options.add_argument(\\\"--start-maximized\\\")  # 最大化无头窗口（避免元素遮挡）\\n    edge_options.add_argument(\\\"--window-size=1920,1080\\\")  # 设置窗口分辨率\\n    edge_options.add_argument(\\\"--disable-gpu\\\")  # 禁用GPU加速（无头模式必需）\\n    edge_options.add_argument(\\\"--no-sandbox\\\")  # 取消沙箱模式\\n    edge_options.add_argument(\\\"--log-level=3\\\")  # 关闭日志输出，减少干扰\\n    \\n    # 初始化驱动\\n    service = Service(EDGE_DRIVER_PATH)\\n    driver = webdriver.Edge(service=service, options=edge_options)\\n    # 移除webdriver标识（关键：模拟真人）\\n    driver.execute_script(\\\"Object.defineProperty(navigator, 'webdriver', {get: () => undefined})\\\")\\n    driver.implicitly_wait(10)  # 全局隐式等待\\n    return driver\\n\\ndef extract_page_data(driver, page_num):\\n    \\\"\\\"\\\"提取当前页面所有有效数据（精准匹配你的页面结构）\\\"\\\"\\\"\\n    global current_auto_id\\n    page_new_data = []\\n    \\n    # 等待页面数据加载完成\\n    WebDriverWait(driver, 15).until(\\n        EC.presence_of_element_located((By.CLASS_NAME, \\\"zhaopin-title\\\"))\\n    )\\n    time.sleep(1)  # 额外等待1秒，确保数据完全渲染\\n    \\n    # 1. 提取所有标题列（zhaopin-title）\\n    title_tds = driver.find_elements(By.CLASS_NAME, \\\"zhaopin-title\\\")\\n    # 2. 提取所有时间列（width=\\\"240px\\\"）\\n    time_tds = driver.find_elements(By.XPATH, \\\"//td[@width='240px']\\\")\\n    \\n    print(f\\\"\\\\n🔍 第{page_num}页：找到 {len(title_tds)} 条招聘信息，{len(time_tds)} 个发布时间\\\")\\n    \\n    # 一一对应提取数据\\n    for i in range(min(len(title_tds), len(time_tds))):\\n        try:\\n            # 提取标题和链接\\n            title_td = title_tds[i]\\n            a_tag = title_td.find_element(By.TAG_NAME, \\\"a\\\")\\n            title = a_tag.text.strip()\\n            link = a_tag.get_attribute(\\\"href\\\").strip()\\n            \\n            # 提取发布时间（精准匹配width=\\\"240px\\\"的td）\\n            publish_time = time_tds[i].text.strip()\\n            \\n            # 过滤无效数据\\n            if not title or not link or len(publish_time) != 10:\\n                continue\\n            \\n            # 标题查重：跳过重复内容\\n            if title in title_duplicate_set:\\n                print(f\\\"⏭️ 跳过重复标题（ID={current_auto_id}）：{title[:30]}...\\\")\\n                continue\\n            \\n            # 组装数据（自增ID）\\n            news_item = {\\n                \\\"id\\\": current_auto_id,\\n                \\\"page\\\": page_num,  # 保留页码便于溯源（不需要可删除）\\n                \\\"title\\\": title,\\n                \\\"link\\\": link,\\n                \\\"publish_time\\\": publish_time\\n            }\\n            page_new_data.append(news_item)\\n            title_duplicate_set.add(title)\\n            current_auto_id += 1  # ID自增\\n        \\n        except Exception as e:\\n            print(f\\\"⚠️ 第{page_num}页第{i+1}条数据提取失败：{str(e)[:60]}\\\")\\n            continue\\n    \\n    print(f\\\"✅ 第{page_num}页：新增 {len(page_new_data)} 条不重复数据（当前最大ID={current_auto_id-1}）\\\")\\n    return page_new_data\\n\\ndef get_page_info(driver):\\n    \\\"\\\"\\\"获取当前页码和总页数\\\"\\\"\\\"\\n    try:\\n        allpage_input = driver.find_element(By.ID, \\\"allpage\\\")\\n        nowpage_input = driver.find_element(By.ID, \\\"nowpage\\\")\\n        total_page = int(allpage_input.get_attribute(\\\"value\\\"))\\n        now_page = int(nowpage_input.get_attribute(\\\"value\\\"))\\n        return now_page, total_page\\n    except:\\n        return 1, 6  # 默认值\\n\\ndef click_next_page(driver, current_page):\\n    \\\"\\\"\\\"点击下一页（通过执行JavaScript函数）\\\"\\\"\\\"\\n    try:\\n        # 方法1：直接执行JavaScript的翻页函数（最可靠）\\n        driver.execute_script(\\\"_gotoNextPage();\\\")\\n        print(f\\\"📝 执行JavaScript翻页函数 _gotoNextPage()\\\")\\n        return True\\n    except Exception as e:\\n        print(f\\\"⚠️ JavaScript翻页失败：{e}\\\")\\n        \\n        try:\\n            # 方法2：尝试点击下一页按钮\\n            next_button = driver.find_element(By.ID, \\\"next\\\")\\n            driver.execute_script(\\\"arguments[0].click();\\\", next_button)\\n            print(f\\\"📝 点击下一页按钮\\\")\\n            return True\\n        except Exception as e:\\n            print(f\\\"⚠️ 点击按钮翻页失败：{e}\\\")\\n            \\n            try:\\n                # 方法3：直接构造URL翻页\\n                next_url = f\\\"http://job.mohrss.gov.cn/cjobs/institution/listInstitution?pageNo={current_page + 1}&origin=\\\"\\n                driver.get(next_url)\\n                print(f\\\"📝 直接访问URL翻页：{next_url}\\\")\\n                return True\\n            except Exception as e:\\n                print(f\\\"❌ 所有翻页方法都失败：{e}\\\")\\n                return False\\n\\ndef crawl_all_pages():\\n    \\\"\\\"\\\"核心：无头模式下爬取所有页面\\\"\\\"\\\"\\n    driver = init_edge_driver()\\n    all_new_data = []\\n    \\n    # 第一步：访问目标页，爬取第1页\\n    driver.get(TARGET_URL)\\n    print(f\\\"\\\\n🚀 开始爬取第 1 页（初始页）\\\")\\n    page1_data = extract_page_data(driver, 1)\\n    all_new_data.extend(page1_data)\\n    \\n    # 获取总页数\\n    try:\\n        allpage_input = WebDriverWait(driver, 10).until(\\n            EC.presence_of_element_located((By.ID, \\\"allpage\\\"))\\n        )\\n        total_page = int(allpage_input.get_attribute(\\\"value\\\"))\\n        print(f\\\"📊 总页数：{total_page} 页\\\")\\n    except:\\n        total_page = 6  # 默认6页\\n        print(f\\\"⚠️ 无法获取总页数，默认设置为 {total_page} 页\\\")\\n    \\n    # 循环爬取剩余页面\\n    for page_num in range(2, total_page + 1):\\n        try:\\n            print(f\\\"\\\\n📝 准备爬取第 {page_num} 页\\\")\\n            \\n            # 等待并获取当前页码，确认可以翻页\\n            time.sleep(2)\\n            \\n            # 执行翻页\\n            if not click_next_page(driver, page_num - 1):\\n                print(f\\\"❌ 无法翻到第 {page_num} 页，停止爬取\\\")\\n                break\\n            \\n            # 等待页面加载完成（通过URL变化或特定元素）\\n            WebDriverWait(driver, 15).until(\\n                EC.url_contains(f\\\"pageNo={page_num}\\\")\\n            )\\n            print(f\\\"✅ URL已更新到第 {page_num} 页\\\")\\n            \\n            # 额外等待页面内容加载\\n            time.sleep(2)\\n            \\n            # 验证当前页码是否正确\\n            try:\\n                now_page, _ = get_page_info(driver)\\n                if now_page != page_num:\\n                    print(f\\\"⚠️ 页码不匹配：当前显示第{now_page}页，期望第{page_num}页\\\")\\n                    # 尝试直接通过URL访问\\n                    url = f\\\"http://job.mohrss.gov.cn/cjobs/institution/listInstitution?pageNo={page_num}&origin=\\\"\\n                    driver.get(url)\\n                    time.sleep(2)\\n            except:\\n                pass\\n            \\n            # 提取当前页数据\\n            page_data = extract_page_data(driver, page_num)\\n            all_new_data.extend(page_data)\\n            \\n            # 如果没有新数据，可以继续爬取（可能都是重复的）\\n            \\n        except Exception as e:\\n            print(f\\\"❌ 第{page_num}页爬取失败：{str(e)[:80]}\\\")\\n            # 尝试直接URL访问作为备选\\n            try:\\n                url = f\\\"http://job.mohrss.gov.cn/cjobs/institution/listInstitution?pageNo={page_num}&origin=\\\"\\n                driver.get(url)\\n                time.sleep(3)\\n                page_data = extract_page_data(driver, page_num)\\n                all_new_data.extend(page_data)\\n            except:\\n                print(f\\\"❌ 备选方案也失败，停止爬取\\\")\\n                break\\n    \\n    # 关闭浏览器\\n    driver.quit()\\n    return all_new_data\\n\\n# ========== 新增的数据库保存函数 ==========\\ndef save_to_database(news_items):\\n    \\\"\\\"\\\"保存数据到数据库（新增功能，不影响原有逻辑）\\\"\\\"\\\"\\n    if not news_items:\\n        return\\n    \\n    # 检查数据库连接\\n    try:\\n        supabase_url = get_supabase_url()\\n        supabase_key = get_supabase_key()\\n        if not supabase_url or not supabase_key:\\n            print(\\\"⚠️ 数据库配置不完整，跳过数据库保存\\\")\\n            return\\n    except Exception as e:\\n        print(f\\\"⚠️ 数据库配置检查失败：{e}，跳过数据库保存\\\")\\n        return\\n    \\n    success_count = 0\\n    for item in news_items:\\n        try:\\n            # 转换数据格式以适配数据库表\\n            db_item = {\\n                \\\"title\\\": item[\\\"title\\\"],\\n                \\\"source_url\\\": item[\\\"link\\\"],\\n                \\\"publish_date\\\": item[\\\"publish_time\\\"],  # 发布时间\\n                \\\"category\\\": DEFAULT_CATEGORY,\\n                \\\"content_text\\\": \\\"\\\",  # 暂时为空\\n                # 不传id，让数据库自增\\n                # 不传page字段\\n            }\\n            \\n            # 插入到数据库\\n            result = supabase_request(\\n                method=\\\"POST\\\",\\n                endpoint=f\\\"/rest/v1/{DB_TABLE}\\\",\\n                json_data=db_item\\n            )\\n            success_count += 1\\n            print(f\\\"✅ 已保存到数据库: {item['title'][:30]}...\\\")\\n            \\n        except Exception as e:\\n            print(f\\\"❌ 保存到数据库失败: {item['title'][:30]}... - {e}\\\")\\n    \\n    if success_count > 0:\\n        print(f\\\"📊 数据库保存完成：成功 {success_count}/{len(news_items)} 条\\\")\\n\\ndef save_to_jsonl(new_data):\\n    \\\"\\\"\\\"保存数据：合并历史+新增，保证ID连续、无重复标题（原有功能不变）\\\"\\\"\\\"\\n    # 读取历史数据\\n    history_data = []\\n    if os.path.exists(JSONL_FILE):\\n        try:\\n            with open(JSONL_FILE, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n                history_data = [json.loads(line.strip()) for line in f if line.strip()]\\n        except Exception as e:\\n            print(f\\\"⚠️ 读取历史数据失败：{e}，将覆盖原有文件\\\")\\n            history_data = []\\n    \\n    # 合并数据 + 全局去重 + 按ID排序\\n    all_data = history_data + new_data\\n    unique_data = []\\n    unique_titles = set()\\n    for item in all_data:\\n        if item[\\\"title\\\"] not in unique_titles:\\n            unique_titles.add(item[\\\"title\\\"])\\n            unique_data.append(item)\\n    # 按ID升序排列，保证ID连续\\n    unique_data.sort(key=lambda x: x[\\\"id\\\"])\\n    \\n    # 写入JSONL文件\\n    try:\\n        with open(JSONL_FILE, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n            for item in unique_data:\\n                json_line = json.dumps(item, ensure_ascii=False)\\n                f.write(json_line + \\\"\\\\n\\\")\\n        \\n        print(f\\\"\\\\n📄 JSONL文件保存成功！\\\")\\n        print(f\\\"📁 文件路径：{os.path.abspath(JSONL_FILE)}\\\")\\n        if unique_data:\\n            print(f\\\"📈 总计数据：{len(unique_data)} 条（ID范围：1~{unique_data[-1]['id']}）\\\")\\n        print(f\\\"🔍 本次新增：{len(new_data)} 条不重复数据\\\")\\n    except PermissionError:\\n        print(f\\\"\\\\n❌ 权限错误！请关闭打开的 {JSONL_FILE} 文件后重试\\\")\\n    except Exception as e:\\n        print(f\\\"\\\\n❌ 保存失败：{str(e)}\\\")\\n\\nif __name__ == \\\"__main__\\\":\\n    print(\\\"=\\\"*60)\\n    print(\\\"🚀 事业单位招聘信息爬取（Edge无头模式 + 数据库存储）\\\")\\n    print(\\\"=\\\"*60)\\n    \\n    # 1. 加载历史数据初始化\\n    load_existing_data()\\n    \\n    # 2. 爬取所有页面数据（无浏览器窗口）- 原有逻辑完全不变\\n    new_data = crawl_all_pages()\\n    \\n    # 3. 保存数据到JSONL（原有功能）\\n    save_to_jsonl(new_data)\\n    \\n    # 4. 新增：保存数据到数据库（不影响原有流程）\\n    if new_data:\\n        save_to_database(new_data)\\n    else:\\n        print(\\\"ℹ️ 没有新数据需要保存到数据库\\\")\\n    \\n    print(\\\"\\\\n🎉 所有爬取任务完成！\\\")\",\n        \"truncated\": false\n      },\n      \"metadata\": {\n        \"encoding\": \"utf-8\",\n        \"line_count\": 381,\n        \"displayed_lines\": 381,\n        \"truncated\": false,\n        \"size\": 15649,\n        \"empty\": false,\n        \"error\": null\n      }\n    },\n    {\n      \"file_info\": {\n        \"path\": \"utils\\\\db.py\",\n        \"name\": \"db.py\",\n        \"extension\": \".py\",\n        \"size_bytes\": 6526,\n        \"size_human\": \"6.37 KB\",\n        \"modified\": \"2026-03-31T19:38:05.618905\"\n      },\n      \"content\": {\n        \"raw\": \"import os\\nimport json\\nfrom pathlib import Path\\nimport ssl\\nfrom urllib.error import HTTPError, URLError\\nfrom urllib.parse import quote\\n\\ntry:\\n    import certifi\\nexcept Exception:\\n    certifi = None\\n\\ntry:\\n    import requests\\n    from requests.adapters import HTTPAdapter\\n    from requests.exceptions import RequestException, SSLError\\nexcept Exception:\\n    requests = None\\n    HTTPAdapter = None\\n    RequestException = Exception\\n    SSLError = Exception\\n\\ntry:\\n    from dotenv import load_dotenv\\nexcept Exception:\\n    load_dotenv = None\\n\\n\\ndef _load_env() -> None:\\n    if load_dotenv is None:\\n        return\\n    project_root = Path(__file__).resolve().parents[2]\\n    try:\\n        load_dotenv(project_root / \\\".env\\\")\\n    except Exception:\\n        pass\\n\\n\\n_session = None\\n\\n\\ndef _get_session():\\n    global _session\\n    if _session is not None:\\n        return _session\\n    global requests, HTTPAdapter\\n    if requests is None or HTTPAdapter is None:\\n        try:\\n            import requests as _requests\\n            from requests.adapters import HTTPAdapter as _HTTPAdapter\\n            from requests.exceptions import RequestException as _RequestException, SSLError as _SSLError\\n        except Exception:\\n            raise RuntimeError(\\\"缺少 requests 依赖\\\")\\n        requests = _requests\\n        HTTPAdapter = _HTTPAdapter\\n        globals()[\\\"RequestException\\\"] = _RequestException\\n        globals()[\\\"SSLError\\\"] = _SSLError\\n    s = requests.Session()\\n    s.trust_env = False\\n    s.headers.update({\\\"Accept\\\": \\\"application/json\\\"})\\n    adapter = HTTPAdapter(pool_connections=16, pool_maxsize=16, max_retries=0)\\n    s.mount(\\\"https://\\\", adapter)\\n    s.mount(\\\"http://\\\", adapter)\\n    _session = s\\n    return _session\\n\\n\\ndef _load_knowledge_key() -> str | None:\\n    _load_env()\\n    project_root = Path(__file__).resolve().parents[2]\\n    knowledge_path = project_root / \\\"knowledge\\\" / \\\"tech-stack.md\\\"\\n    if not knowledge_path.exists():\\n        return None\\n    try:\\n        text = knowledge_path.read_text(encoding=\\\"utf-8\\\", errors=\\\"ignore\\\")\\n    except Exception:\\n        return None\\n    marker = \\\"sb_publishable_\\\"\\n    idx = text.find(marker)\\n    if idx == -1:\\n        return None\\n    tail = text[idx:].split()[0].strip()\\n    return tail or None\\n\\n\\ndef get_supabase_url() -> str | None:\\n    _load_env()\\n    url = os.getenv(\\\"SUPABASE_URL\\\")\\n    if url:\\n        return url.strip()\\n    key = get_supabase_key()\\n    if not key:\\n        return None\\n    parts = key.split(\\\"_\\\")\\n    if len(parts) >= 3:\\n        project_ref = parts[2].strip()\\n        if project_ref:\\n            return f\\\"https://{project_ref.lower()}.supabase.co\\\"\\n    return None\\n\\n\\ndef get_supabase_key() -> str | None:\\n    _load_env()\\n    key = os.getenv(\\\"SUPABASE_ANON_KEY\\\") or os.getenv(\\\"SUPABASE_KEY\\\")\\n    if key:\\n        return key.strip()\\n    return _load_knowledge_key()\\n\\n\\ndef get_http_session():\\n    return _get_session()\\n\\n\\ndef get_dify_base_url() -> str:\\n    _load_env()\\n    base = os.getenv(\\\"DIFY_BASE_URL\\\") or os.getenv(\\\"DIFY_API_BASE_URL\\\") or \\\"https://api.dify.ai/v1\\\"\\n    return base.strip().rstrip(\\\"/\\\")\\n\\n\\ndef get_dify_api_key() -> str | None:\\n    _load_env()\\n    key = os.getenv(\\\"DIFY_API_KEY\\\")\\n    return key.strip() if key else None\\n\\n\\ndef get_dify_task_api_key() -> str | None:\\n    _load_env()\\n    key = os.getenv(\\\"DIFY_TASK_API_KEY\\\") or os.getenv(\\\"DIFY_TODO_API_KEY\\\") or os.getenv(\\\"DIFY_API_KEY\\\")\\n    return key.strip() if key else None\\n\\n\\ndef get_dify_recommend_api_key() -> str | None:\\n    _load_env()\\n    key = os.getenv(\\\"DIFY_RECOMMEND_API_KEY\\\") or os.getenv(\\\"DIFY_API_KEY\\\")\\n    return key.strip() if key else None\\n\\n\\ndef supabase_request(method: str, endpoint: str, params: dict = None, json_data: dict = None) -> list | dict | None:\\n    \\\"\\\"\\\"\\n    通用 Supabase REST 请求封装\\n    :param method: GET, POST, PATCH, DELETE\\n    :param endpoint: 比如 '/rest/v1/sys_profiles'\\n    :param params: URL 查询参数字典\\n    :param json_data: POST/PATCH 的 body 数据\\n    :return: 解析后的 JSON 数据\\n    \\\"\\\"\\\"\\n    supabase_url = get_supabase_url()\\n    supabase_key = get_supabase_key()\\n    if not supabase_url or not supabase_key:\\n        raise RuntimeError(\\\"Supabase 配置缺失\\\")\\n\\n    url = f\\\"{supabase_url.rstrip('/')}/{endpoint.lstrip('/')}\\\"\\n    \\n    headers = {\\n        \\\"apikey\\\": supabase_key,\\n        \\\"Authorization\\\": f\\\"Bearer {supabase_key}\\\",\\n        \\\"Accept\\\": \\\"application/json\\\",\\n    }\\n    \\n   \\n    if method.upper() in (\\\"POST\\\", \\\"PATCH\\\", \\\"DELETE\\\"):\\n        headers[\\\"Prefer\\\"] = \\\"return=representation\\\"\\n\\n    try:\\n        verify = True\\n        if certifi is not None:\\n            try:\\n                verify = certifi.where()\\n            except Exception:\\n                verify = True\\n                \\n        s = _get_session()\\n        # 对于 RPC 调用（特别是向量查询），使用更长的超时时间\\n        timeout_val = 30 if endpoint.startswith(\\\"/rest/v1/rpc/\\\") else 10\\n        \\n        resp = s.request(\\n            method=method.upper(),\\n            url=url,\\n            headers=headers,\\n            params=params,\\n            json=json_data,\\n            timeout=timeout_val,\\n            verify=verify,\\n        )\\n        \\n        if resp.status_code >= 400:\\n            raise RuntimeError(f\\\"Supabase 请求失败: HTTP {resp.status_code} - {resp.text}\\\")\\n            \\n        raw = resp.text\\n    except SSLError as e:\\n        raise RuntimeError(f\\\"Supabase 网络连接失败 (SSL): {str(e)}\\\") from e\\n    except RequestException as e:\\n        raise RuntimeError(f\\\"Supabase 网络连接失败: {str(e)}\\\") from e\\n    except Exception as e:\\n        raise RuntimeError(f\\\"Supabase 请求异常: {str(e)}\\\") from e\\n\\n    if not raw:\\n        return None\\n        \\n    try:\\n        data = json.loads(raw)\\n        return data\\n    except Exception as e:\\n        raise RuntimeError(\\\"Supabase 返回数据解析失败\\\") from e\\n\\n\\ndef get_sys_profile_by_phone(phone: str) -> dict | None:\\n    safe_phone = quote(phone, safe=\\\"\\\")\\n    \\n    # 直接使用封装好的 supabase_request\\n    data = supabase_request(\\n        method=\\\"GET\\\",\\n        endpoint=\\\"/rest/v1/sys_profiles\\\",\\n        params={\\n            \\\"select\\\": \\\"id,role_code,password,phone,real_name,avatar_url,resume_url\\\",\\n            \\\"phone\\\": f\\\"eq.{safe_phone}\\\",\\n            \\\"limit\\\": \\\"1\\\"\\n        }\\n    )\\n    \\n    if isinstance(data, list) and data:\\n        return data[0]\\n    return None\\n\",\n        \"truncated\": false\n      },\n      \"metadata\": {\n        \"encoding\": \"utf-8\",\n        \"line_count\": 224,\n        \"displayed_lines\": 224,\n        \"truncated\": false,\n        \"size\": 6526,\n        \"empty\": false,\n        \"error\": null\n      }\n    },\n    {\n      \"file_info\": {\n        \"path\": \"utils\\\\news_crawler.py\",\n        \"name\": \"news_crawler.py\",\n        \"extension\": \".py\",\n        \"size_bytes\": 16242,\n        \"size_human\": \"15.86 KB\",\n        \"modified\": \"2026-03-27T10:46:41.446012\"\n      },\n      \"content\": {\n        \"raw\": \"#!/usr/bin/env python\\n# -*- coding: utf-8 -*-\\n\\\"\\\"\\\"\\n人社部热点资讯爬虫（位于 app/utils/ 目录）\\n\\\"\\\"\\\"\\n\\nimport json\\nimport os\\nimport sys\\nfrom pathlib import Path\\nfrom selenium import webdriver\\nfrom selenium.webdriver.edge.service import Service\\nfrom selenium.webdriver.edge.options import Options\\nfrom selenium.webdriver.common.by import By\\nfrom selenium.webdriver.support.ui import WebDriverWait\\nfrom selenium.webdriver.support import expected_conditions as EC\\nimport time\\nimport re\\nfrom dotenv import load_dotenv\\n\\n# ========== 添加项目根目录到 Python 路径 ==========\\n# 当前文件: app/utils/test_crawler.py\\ncurrent_dir = Path(__file__).resolve().parent  # app/utils\\napp_dir = current_dir.parent  # app\\nproject_root = app_dir.parent  # demolition-brigade 根目录\\n\\nsys.path.insert(0, str(project_root))\\n\\nprint(f\\\"项目根目录: {project_root}\\\")\\n\\n# ========== 手动加载 .env 文件 ==========\\nenv_path = project_root / '.env'\\nif env_path.exists():\\n    load_dotenv(env_path)\\n    print(f\\\"✅ 已加载 .env 文件: {env_path}\\\")\\nelse:\\n    print(f\\\"⚠️ .env 文件不存在: {env_path}\\\")\\n    # 尝试在父目录查找\\n    alt_env = project_root.parent / '.env'\\n    if alt_env.exists():\\n        load_dotenv(alt_env)\\n        print(f\\\"✅ 已加载 .env 文件: {alt_env}\\\")\\n# ========================================\\n\\n# 现在可以正确导入\\ntry:\\n    from app.utils.db import supabase_request, get_supabase_url, get_supabase_key\\n    print(\\\"✅ 成功导入数据库模块\\\")\\nexcept ImportError as e:\\n    print(f\\\"⚠️ 导入数据库模块失败: {e}\\\")\\n    print(\\\"将只保存数据到 JSONL 文件\\\")\\n\\n# ========== 精准配置 ==========\\nEDGE_DRIVER_PATH = r\\\"D:\\\\Mine\\\\Download\\\\edge download\\\\edgedriver_win64\\\\msedgedriver.exe\\\"\\nTARGET_URL = \\\"http://job.mohrss.gov.cn/rdzx/index.jhtml\\\"\\n\\n# 动态获取文件路径\\nBASE_DIR = str(project_root)\\nJSONL_FILE = os.path.join(BASE_DIR, \\\"data\\\", \\\"news\\\", \\\"Hot_News.jsonl\\\")\\nJSONL_FILE = os.path.abspath(JSONL_FILE)\\n\\nHEADLESS_MODE = True  # True=无头模式，False=显示浏览器窗口\\n\\n# ========== 数据库配置 ==========\\nDB_TABLE = \\\"news_record\\\"\\nDEFAULT_CATEGORY = \\\"中华人民共和国人力资源和社会保障部-热点资讯\\\"\\n# ================================================\\n\\nprint(f\\\"📁 数据保存路径：{JSONL_FILE}\\\")\\nprint(f\\\"📁 目录是否存在：{os.path.exists(os.path.dirname(JSONL_FILE))}\\\")\\n\\n# 确保目录存在\\nos.makedirs(os.path.dirname(JSONL_FILE), exist_ok=True)\\n\\n# 全局变量（自增ID+查重）\\ntitle_duplicate_set = set()\\ncurrent_auto_id = 1\\n\\ndef load_existing_data():\\n    \\\"\\\"\\\"加载历史数据，初始化自增ID和查重集合\\\"\\\"\\\"\\n    global current_auto_id, title_duplicate_set\\n    if os.path.exists(JSONL_FILE):\\n        try:\\n            max_id = 0\\n            with open(JSONL_FILE, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n                for line in f:\\n                    line = line.strip()\\n                    if line:\\n                        data = json.loads(line)\\n                        if \\\"title\\\" in data:\\n                            title_duplicate_set.add(data[\\\"title\\\"])\\n                        if \\\"id\\\" in data and isinstance(data[\\\"id\\\"], int):\\n                            max_id = max(max_id, data[\\\"id\\\"])\\n            current_auto_id = max_id + 1\\n            print(f\\\"✅ 加载历史数据完成\\\")\\n            print(f\\\"   - 历史不重复标题数：{len(title_duplicate_set)}\\\")\\n            print(f\\\"   - 下一个自增ID：{current_auto_id}\\\")\\n        except Exception as e:\\n            print(f\\\"⚠️ 加载历史数据失败：{e}，将从ID=1重新开始\\\")\\n            current_auto_id = 1\\n            title_duplicate_set = set()\\n    else:\\n        print(f\\\"ℹ️ 无历史数据，ID从1开始爬取\\\")\\n\\ndef init_edge_driver():\\n    \\\"\\\"\\\"初始化Edge浏览器（可选无头模式）\\\"\\\"\\\"\\n    edge_options = Options()\\n    \\n    if HEADLESS_MODE:\\n        # 无头模式配置\\n        edge_options.add_argument(\\\"--headless=new\\\")\\n        edge_options.add_argument(\\\"--disable-gpu\\\")\\n        edge_options.add_argument(\\\"--window-size=1920,1080\\\")\\n        edge_options.add_argument(\\\"--no-sandbox\\\")\\n    else:\\n        # 有头模式（调试用）\\n        edge_options.add_argument(\\\"--start-maximized\\\")\\n        edge_options.add_argument(\\\"--window-size=1920,1080\\\")\\n    \\n    # 通用配置\\n    edge_options.add_argument(\\\"--disable-blink-features=AutomationControlled\\\")\\n    edge_options.add_experimental_option(\\\"excludeSwitches\\\", [\\\"enable-automation\\\"])\\n    edge_options.add_experimental_option(\\\"useAutomationExtension\\\", False)\\n    edge_options.add_argument(\\\"--log-level=3\\\")\\n    \\n    # 初始化驱动\\n    service = Service(EDGE_DRIVER_PATH)\\n    driver = webdriver.Edge(service=service, options=edge_options)\\n    driver.execute_script(\\\"Object.defineProperty(navigator, 'webdriver', {get: () => undefined})\\\")\\n    driver.implicitly_wait(10)\\n    return driver\\n\\ndef extract_news_from_page(driver, page_num=1):\\n    \\\"\\\"\\\"从当前页面提取所有新闻数据\\\"\\\"\\\"\\n    global current_auto_id\\n    page_new_data = []\\n    \\n    # 等待页面加载完成，等待新闻链接出现\\n    WebDriverWait(driver, 15).until(\\n        EC.presence_of_element_located((By.CSS_SELECTOR, \\\"a.blue-light\\\"))\\n    )\\n    time.sleep(1)\\n    \\n    # 提取所有class=\\\"blue-light\\\"的a标签（新闻标题和链接）\\n    news_links = driver.find_elements(By.CSS_SELECTOR, \\\"a.blue-light\\\")\\n    \\n    print(f\\\"\\\\n🔍 第{page_num}页：找到 {len(news_links)} 条新闻链接\\\")\\n    \\n    for i, link_element in enumerate(news_links):\\n        try:\\n            # 提取标题和链接\\n            title = link_element.text.strip()\\n            link = link_element.get_attribute(\\\"href\\\").strip()\\n            \\n            # 过滤无效数据\\n            if not title or not link:\\n                continue\\n            \\n            # 标题查重\\n            if title in title_duplicate_set:\\n                print(f\\\"⏭️ 跳过重复标题：{title[:40]}...\\\")\\n                continue\\n            \\n            # 提取发布时间（从兄弟元素或父元素中的span.floatright）\\n            publish_time = extract_publish_time(link_element)\\n            \\n            # 组装数据\\n            news_item = {\\n                \\\"id\\\": current_auto_id,\\n                \\\"page\\\": page_num,\\n                \\\"title\\\": title,\\n                \\\"link\\\": link,\\n                \\\"publish_time\\\": publish_time,\\n                \\\"source\\\": \\\"人社部热点资讯\\\"\\n            }\\n            page_new_data.append(news_item)\\n            title_duplicate_set.add(title)\\n            print(f\\\"✅ 第{page_num}页第{i+1}条：{title[:50]}... ({publish_time})\\\")\\n            current_auto_id += 1\\n            \\n        except Exception as e:\\n            print(f\\\"⚠️ 第{page_num}页第{i+1}条数据提取失败：{str(e)[:60]}\\\")\\n            continue\\n    \\n    print(f\\\"📊 第{page_num}页：新增 {len(page_new_data)} 条不重复数据\\\")\\n    return page_new_data\\n\\ndef extract_publish_time(link_element):\\n    \\\"\\\"\\\"提取发布时间：从span class='floatright font12 gray'中提取\\\"\\\"\\\"\\n    try:\\n        # 策略1：查找父级元素中的时间span\\n        parent = link_element.find_element(By.XPATH, \\\"..\\\")\\n        \\n        time_span = parent.find_elements(By.CSS_SELECTOR, \\\"span.floatright.font12.gray\\\")\\n        if time_span:\\n            time_text = time_span[0].text.strip()\\n            if time_text and re.match(r'\\\\d{4}-\\\\d{2}-\\\\d{2}', time_text):\\n                return time_text\\n        \\n        # 策略2：查找父级的父级\\n        grand_parent = link_element.find_element(By.XPATH, \\\"../..\\\")\\n        time_span = grand_parent.find_elements(By.CSS_SELECTOR, \\\"span.floatright.font12.gray\\\")\\n        if time_span:\\n            time_text = time_span[0].text.strip()\\n            if time_text and re.match(r'\\\\d{4}-\\\\d{2}-\\\\d{2}', time_text):\\n                return time_text\\n        \\n        # 策略3：查找兄弟元素中的时间\\n        sibling_time = link_element.find_elements(By.XPATH, \\\"following-sibling::span[contains(@class, 'floatright')]\\\")\\n        if sibling_time:\\n            time_text = sibling_time[0].text.strip()\\n            if time_text and re.match(r'\\\\d{4}-\\\\d{2}-\\\\d{2}', time_text):\\n                return time_text\\n        \\n        return \\\"时间未知\\\"\\n        \\n    except Exception as e:\\n        print(f\\\"时间提取异常：{e}\\\")\\n        return \\\"时间未知\\\"\\n\\ndef get_total_pages(driver):\\n    \\\"\\\"\\\"获取总页数（通过分析下一页链接）\\\"\\\"\\\"\\n    try:\\n        pagination_links = driver.find_elements(By.CSS_SELECTOR, \\\".page a, a[onclick*='index_']\\\")\\n        \\n        max_page = 1\\n        for link in pagination_links:\\n            onclick = link.get_attribute(\\\"onclick\\\") or \\\"\\\"\\n            href = link.get_attribute(\\\"href\\\") or \\\"\\\"\\n            \\n            if \\\"index_\\\" in onclick:\\n                match = re.search(r'index_(\\\\d+)\\\\.jhtml', onclick)\\n                if match:\\n                    page_num = int(match.group(1))\\n                    max_page = max(max_page, page_num)\\n            \\n            if \\\"index_\\\" in href:\\n                match = re.search(r'index_(\\\\d+)\\\\.jhtml', href)\\n                if match:\\n                    page_num = int(match.group(1))\\n                    max_page = max(max_page, page_num)\\n        \\n        if max_page > 1:\\n            print(f\\\"📊 通过分页链接识别到总页数：{max_page}\\\")\\n            return max_page\\n        \\n    except Exception as e:\\n        print(f\\\"⚠️ 获取总页数失败：{e}\\\")\\n    \\n    return 5\\n\\ndef go_to_next_page(driver, current_page):\\n    \\\"\\\"\\\"点击下一页\\\"\\\"\\\"\\n    try:\\n        next_links = driver.find_elements(By.XPATH, \\\"//a[contains(@onclick, 'index_') and contains(text(), '下一页')]\\\")\\n        \\n        if next_links:\\n            print(f\\\"📝 找到下一页链接，点击跳转到第{current_page + 1}页\\\")\\n            driver.execute_script(\\\"arguments[0].click();\\\", next_links[0])\\n            time.sleep(2)\\n            return True\\n        \\n        next_url = TARGET_URL.replace(\\\"index.jhtml\\\", f\\\"index_{current_page + 1}.jhtml\\\")\\n        print(f\\\"📝 直接构造URL：{next_url}\\\")\\n        driver.get(next_url)\\n        time.sleep(2)\\n        return True\\n        \\n    except Exception as e:\\n        print(f\\\"❌ 翻页失败：{e}\\\")\\n        return False\\n\\ndef crawl_all_pages():\\n    \\\"\\\"\\\"爬取所有页面的新闻\\\"\\\"\\\"\\n    driver = init_edge_driver()\\n    all_new_data = []\\n    \\n    try:\\n        print(f\\\"\\\\n🚀 开始爬取首页：{TARGET_URL}\\\")\\n        driver.get(TARGET_URL)\\n        time.sleep(2)\\n        \\n        page1_data = extract_news_from_page(driver, page_num=1)\\n        all_new_data.extend(page1_data)\\n        \\n        total_pages = get_total_pages(driver)\\n        print(f\\\"\\\\n📊 预计总页数：{total_pages} 页\\\")\\n        \\n        for page_num in range(2, total_pages + 1):\\n            print(f\\\"\\\\n{'='*50}\\\")\\n            print(f\\\"📝 准备爬取第 {page_num} 页\\\")\\n            \\n            if not go_to_next_page(driver, page_num - 1):\\n                print(f\\\"❌ 无法翻到第 {page_num} 页，停止爬取\\\")\\n                break\\n            \\n            WebDriverWait(driver, 10).until(\\n                EC.presence_of_element_located((By.CSS_SELECTOR, \\\"a.blue-light\\\"))\\n            )\\n            time.sleep(1.5)\\n            \\n            current_url = driver.current_url\\n            print(f\\\"📍 当前URL：{current_url}\\\")\\n            \\n            page_data = extract_news_from_page(driver, page_num=page_num)\\n            all_new_data.extend(page_data)\\n            \\n            if len(page_data) == 0:\\n                print(f\\\"⚠️ 第{page_num}页无数据，可能已到达最后一页\\\")\\n                break\\n            \\n            time.sleep(1)\\n    \\n    except Exception as e:\\n        print(f\\\"❌ 爬取过程出错：{e}\\\")\\n        import traceback\\n        traceback.print_exc()\\n    \\n    finally:\\n        driver.quit()\\n    \\n    return all_new_data\\n\\n# ========== 数据库保存函数 ==========\\ndef save_to_database(news_items):\\n    \\\"\\\"\\\"保存数据到数据库\\\"\\\"\\\"\\n    if not news_items:\\n        return\\n    \\n    # 检查数据库模块是否可用\\n    try:\\n        from app.utils.db import supabase_request, get_supabase_url, get_supabase_key\\n    except ImportError:\\n        print(\\\"⚠️ 数据库模块不可用，跳过数据库保存\\\")\\n        return\\n    \\n    try:\\n        supabase_url = get_supabase_url()\\n        supabase_key = get_supabase_key()\\n        if not supabase_url or not supabase_key:\\n            print(\\\"⚠️ 数据库配置不完整，跳过数据库保存\\\")\\n            return\\n    except Exception as e:\\n        print(f\\\"⚠️ 数据库配置检查失败：{e}，跳过数据库保存\\\")\\n        return\\n    \\n    success_count = 0\\n    for item in news_items:\\n        try:\\n            # 根据 news_record 表的实际字段构建数据\\n            db_item = {\\n                \\\"title\\\": item[\\\"title\\\"],\\n                \\\"source_url\\\": item[\\\"link\\\"],\\n                \\\"publish_date\\\": item[\\\"publish_time\\\"],\\n                \\\"category\\\": DEFAULT_CATEGORY,\\n                \\\"content_text\\\": \\\"\\\",  # 暂时为空\\n            }\\n            \\n            # 插入到数据库\\n            result = supabase_request(\\n                method=\\\"POST\\\",\\n                endpoint=f\\\"/rest/v1/{DB_TABLE}\\\",\\n                json_data=db_item\\n            )\\n            success_count += 1\\n            print(f\\\"✅ 已保存到数据库: {item['title'][:30]}...\\\")\\n            \\n        except Exception as e:\\n            print(f\\\"❌ 保存到数据库失败: {item['title'][:30]}... - {e}\\\")\\n    \\n    if success_count > 0:\\n        print(f\\\"📊 数据库保存完成：成功 {success_count}/{len(news_items)} 条\\\")\\n\\ndef save_to_jsonl(new_data):\\n    \\\"\\\"\\\"保存数据到JSONL文件\\\"\\\"\\\"\\n    if not new_data:\\n        print(\\\"\\\\n⚠️ 没有新数据需要保存\\\")\\n        return\\n    \\n    history_data = []\\n    if os.path.exists(JSONL_FILE):\\n        try:\\n            with open(JSONL_FILE, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n                history_data = [json.loads(line.strip()) for line in f if line.strip()]\\n        except Exception as e:\\n            print(f\\\"⚠️ 读取历史数据失败：{e}，将覆盖原有文件\\\")\\n            history_data = []\\n    \\n    all_data = history_data + new_data\\n    unique_data = []\\n    unique_titles = set()\\n    for item in all_data:\\n        if item[\\\"title\\\"] not in unique_titles:\\n            unique_titles.add(item[\\\"title\\\"])\\n            unique_data.append(item)\\n    \\n    unique_data.sort(key=lambda x: x[\\\"id\\\"])\\n    \\n    try:\\n        with open(JSONL_FILE, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n            for item in unique_data:\\n                json_line = json.dumps(item, ensure_ascii=False)\\n                f.write(json_line + \\\"\\\\n\\\")\\n        \\n        print(f\\\"\\\\n{'='*60}\\\")\\n        print(f\\\"📄 JSONL文件保存成功！\\\")\\n        print(f\\\"📁 文件路径：{os.path.abspath(JSONL_FILE)}\\\")\\n        if unique_data:\\n            print(f\\\"📈 总计数据：{len(unique_data)} 条（ID范围：{unique_data[0]['id']}~{unique_data[-1]['id']}）\\\")\\n        print(f\\\"🔍 本次新增：{len(new_data)} 条不重复数据\\\")\\n        print(f\\\"{'='*60}\\\")\\n    except Exception as e:\\n        print(f\\\"\\\\n❌ 保存失败：{str(e)}\\\")\\n\\ndef main():\\n    print(\\\"=\\\"*60)\\n    print(\\\"🚀 人社部热点资讯爬虫\\\")\\n    print(f\\\"📍 目标网址：{TARGET_URL}\\\")\\n    print(f\\\"🎯 运行模式：{'无头模式（后台静默运行）' if HEADLESS_MODE else '有头模式（可见浏览器窗口）'}\\\")\\n    print(f\\\"💾 数据库表名：{DB_TABLE}\\\")\\n    print(\\\"=\\\"*60)\\n    \\n    # 加载历史数据\\n    load_existing_data()\\n    \\n    # 爬取数据\\n    new_data = crawl_all_pages()\\n    \\n    # 保存到JSONL\\n    save_to_jsonl(new_data)\\n    \\n    # 保存到数据库\\n    if new_data:\\n        save_to_database(new_data)\\n    else:\\n        print(\\\"ℹ️ 没有新数据需要保存到数据库\\\")\\n    \\n    print(\\\"\\\\n🎉 爬取任务全部完成！\\\")\\n\