   \\nexcept Exception as e:\\n    print(f\\\"❌ 操作失败: {e}\\\")\",\n        \"truncated\": false\n      },\n      \"metadata\": {\n        \"encoding\": \"utf-8\",\n        \"line_count\": 67,\n        \"displayed_lines\": 67,\n        \"truncated\": false,\n        \"size\": 1808\n      }\n    },\n    {\n      \"file_info\": {\n        \"path\": \"test_schema.py\",\n        \"name\": \"test_schema.py\",\n        \"extension\": \".py\",\n        \"size_bytes\": 4680,\n        \"size_human\": \"4.57 KB\",\n        \"modified\": \"2026-03-27T10:40:46.056767\"\n      },\n      \"content\": {\n        \"raw\": \"#!/usr/bin/env python\\n# -*- coding: utf-8 -*-\\n\\\"\\\"\\\"\\n测试数据库连接并查看表结构（包括空表）\\n注意：此脚本位于 app/utils/ 目录下\\n\\\"\\\"\\\"\\n\\nimport os\\nimport sys\\nfrom pathlib import Path\\n\\n# ========== 添加项目根目录到 Python 路径 ==========\\n# 当前文件: D:\\\\Mine\\\\Project\\\\vscodefile\\\\Software\\\\demolition-brigade\\\\app\\\\utils\\\\test_schema.py\\ncurrent_dir = Path(__file__).resolve().parent  # app/utils\\napp_dir = current_dir.parent  # app\\nproject_root = app_dir.parent  # demolition-brigade 根目录\\n\\nsys.path.insert(0, str(project_root))\\n\\nprint(f\\\"当前文件: {__file__}\\\")\\nprint(f\\\"当前目录: {current_dir}\\\")\\nprint(f\\\"app目录: {app_dir}\\\")\\nprint(f\\\"项目根目录: {project_root}\\\")\\n\\n# ========== 加载 .env 文件 ==========\\nenv_path = project_root / '.env'\\nif env_path.exists():\\n    from dotenv import load_dotenv\\n    load_dotenv(env_path)\\n    print(f\\\"✅ 已加载 .env 文件: {env_path}\\\")\\nelse:\\n    print(f\\\"⚠️ .env 文件不存在: {env_path}\\\")\\n    # 尝试在项目根目录上级查找\\n    alt_env = project_root.parent / '.env'\\n    if alt_env.exists():\\n        from dotenv import load_dotenv\\n        load_dotenv(alt_env)\\n        print(f\\\"✅ 已加载 .env 文件: {alt_env}\\\")\\n    else:\\n        print(f\\\"⚠️ 未找到 .env 文件\\\")\\n\\n# ========== 导入数据库模块 ==========\\ntry:\\n    from app.utils.db import supabase_request, get_supabase_url, get_supabase_key\\n    print(\\\"✅ 成功导入数据库模块\\\")\\nexcept ImportError as e:\\n    print(f\\\"❌ 导入失败: {e}\\\")\\n    print(f\\\"当前 sys.path: {sys.path[:3]}\\\")\\n    sys.exit(1)\\n\\ndef test_connection():\\n    \\\"\\\"\\\"测试数据库连接\\\"\\\"\\\"\\n    print(\\\"\\\\n\\\" + \\\"=\\\"*60)\\n    print(\\\"1. 测试数据库连接\\\")\\n    print(\\\"=\\\"*60)\\n    \\n    try:\\n        supabase_url = get_supabase_url()\\n        supabase_key = get_supabase_key()\\n        \\n        print(f\\\"Supabase URL: {supabase_url}\\\")\\n        print(f\\\"Supabase Key: {supabase_key[:20]}...\\\" if supabase_key else \\\"None\\\")\\n        \\n        if not supabase_url or not supabase_key:\\n            print(\\\"❌ 数据库配置不完整\\\")\\n            return False\\n        \\n        # 测试简单查询\\n        result = supabase_request(\\n            method=\\\"GET\\\",\\n            endpoint=\\\"/rest/v1/news_record\\\",\\n            params={\\\"limit\\\": \\\"1\\\"}\\n        )\\n        \\n        print(f\\\"✅ 连接成功！返回数据: {result}\\\")\\n        return True\\n        \\n    except Exception as e:\\n        print(f\\\"❌ 连接失败: {e}\\\")\\n        return False\\n\\ndef main():\\n    print(\\\"\\\\n\\\" + \\\"🌟\\\"*30)\\n    print(\\\"    Supabase 数据库测试脚本\\\")\\n    print(\\\"🌟\\\"*30)\\n    \\n    # 测试连接\\n    if not test_connection():\\n        print(\\\"\\\\n❌ 数据库连接失败，请检查配置\\\")\\n        sys.exit(1)\\n    \\n    # 查看 knowledge_articles 表结构\\n    print(f\\\"\\\\n\\\" + \\\"=\\\"*60)\\n    print(\\\"2. knowledge_articles 表结构\\\")\\n    print(\\\"=\\\"*60)\\n    try:\\n        result = supabase_request(\\n            method=\\\"GET\\\",\\n            endpoint=\\\"/rest/v1/knowledge_articles\\\",\\n            params={\\\"limit\\\": \\\"1\\\"}\\n        )\\n        if result and isinstance(result, list) and len(result) > 0:\\n            print(\\\"✅ 字段列表:\\\")\\n            for key in result[0].keys():\\n                print(f\\\"  - {key}: {type(result[0][key]).__name__}\\\")\\n    except Exception as e:\\n        print(f\\\"❌ 查询失败: {e}\\\")\\n    \\n    # 测试 news_record 表\\n    print(f\\\"\\\\n\\\" + \\\"=\\\"*60)\\n    print(\\\"3. 测试 news_record 表\\\")\\n    print(\\\"=\\\"*60)\\n    \\n    # 测试插入数据\\n    test_data = {\\n        \\\"title\\\": \\\"测试新闻\\\",\\n        \\\"source_url\\\": \\\"https://test.com\\\",\\n        \\\"publish_date\\\": \\\"2026-03-27\\\",\\n        \\\"category\\\": \\\"测试分类\\\",\\n        \\\"content_text\\\": \\\"\\\"\\n    }\\n    \\n    print(f\\\"尝试插入测试数据: {test_data}\\\")\\n    \\n    try:\\n        result = supabase_request(\\n            method=\\\"POST\\\",\\n            endpoint=\\\"/rest/v1/news_record\\\",\\n            json_data=test_data\\n        )\\n        print(f\\\"✅ 插入成功！返回: {result}\\\")\\n        \\n        # 删除测试数据\\n        if result and isinstance(result, list) and len(result) > 0:\\n            test_id = result[0].get('id')\\n            if test_id:\\n                supabase_request(\\n                    method=\\\"DELETE\\\",\\n                    endpoint=\\\"/rest/v1/news_record\\\",\\n                    params={\\\"id\\\": f\\\"eq.{test_id}\\\"}\\n                )\\n                print(f\\\"✅ 已删除测试数据\\\")\\n                \\n    except Exception as e:\\n        print(f\\\"❌ 插入失败: {e}\\\")\\n    \\n    print(\\\"\\\\n\\\" + \\\"✨\\\"*30)\\n    print(\\\"    测试完成\\\")\\n    print(\\\"✨\\\"*30)\\n\\nif __name__ == \\\"__main__\\\":\\n    main()\",\n        \"truncated\": false\n      },\n      \"metadata\": {\n        \"encoding\": \"utf-8\",\n        \"line_count\": 152,\n        \"displayed_lines\": 152,\n        \"truncated\": false,\n        \"size\": 4680\n      }\n    }\n  ]\n}",
