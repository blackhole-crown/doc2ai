},\n      \"content\": {\n        \"raw\": \"from flask import Blueprint, request, jsonify\\n\\nfrom app.services.roadmap_service import create_roadmap, list_roadmaps_by_user, get_roadmap_detail\\n\\n\\nroadmap_bp = Blueprint(\\\"roadmap\\\", __name__)\\n\\n\\n@roadmap_bp.route(\\\"/roadmap/create\\\", methods=[\\\"POST\\\"])\\ndef roadmap_create():\\n    data = request.get_json(silent=True) or request.form or {}\\n    user_id = data.get(\\\"user_id\\\")\\n    target_id = data.get(\\\"target_id\\\")\\n    vision = data.get(\\\"roadmap_vision\\\") or \\\"\\\"\\n    if user_id is None or target_id is None:\\n        return jsonify({\\\"code\\\": 400, \\\"message\\\": \\\"请提供 user_id 和 target_id\\\"}), 400\\n    try:\\n        res = create_roadmap(int(user_id), int(target_id), vision)\\n        if res.get(\\\"existed\\\"):\\n            return jsonify({\\\"code\\\": 409, \\\"message\\\": \\\"职业路线已存在\\\", \\\"data\\\": res}), 409\\n        return jsonify({\\\"code\\\": 200, \\\"message\\\": \\\"职业路线已创建\\\", \\\"data\\\": res})\\n    except Exception as e:\\n        return jsonify({\\\"code\\\": 500, \\\"message\\\": f\\\"创建失败: {str(e)}\\\"}), 500\\n\\n\\n@roadmap_bp.route(\\\"/roadmap/list\\\", methods=[\\\"GET\\\"])\\ndef roadmap_list_by_user():\\n    user_id = request.args.get(\\\"user_id\\\")\\n    if user_id is None:\\n        return jsonify({\\\"code\\\": 400, \\\"message\\\": \\\"请提供 user_id\\\"}), 400\\n    try:\\n        rows = list_roadmaps_by_user(int(user_id))\\n        return jsonify({\\\"code\\\": 200, \\\"message\\\": \\\"查询成功\\\", \\\"data\\\": rows})\\n    except Exception as e:\\n        return jsonify({\\\"code\\\": 500, \\\"message\\\": f\\\"查询失败: {str(e)}\\\"}), 500\\n\\n\\n@roadmap_bp.route(\\\"/roadmap/detail\\\", methods=[\\\"GET\\\"])\\ndef roadmap_detail():\\n    roadmap_id = request.args.get(\\\"roadmap_id\\\")\\n    if roadmap_id is None:\\n        return jsonify({\\\"code\\\": 400, \\\"message\\\": \\\"请提供 roadmap_id\\\"}), 400\\n    try:\\n        data = get_roadmap_detail(int(roadmap_id))\\n        if not data:\\n            return jsonify({\\\"code\\\": 404, \\\"message\\\": \\\"路径不存在\\\"}), 404\\n        return jsonify({\\\"code\\\": 200, \\\"message\\\": \\\"查询成功\\\", \\\"data\\\": data})\\n    except Exception as e:\\n        return jsonify({\\\"code\\\": 500, \\\"message\\\": f\\\"查询失败: {str(e)}\\\"}), 500\\n\",\n        \"truncated\": false\n      },\n      \"metadata\": {\n        \"encoding\": \"utf-8\",\n        \"line_count\": 50,\n        \"displayed_lines\": 50,\n        \"truncated\": false,\n        \"size\": 2079,\n        \"empty\": false,\n        \"error\": null\n      }\n    },\n    {\n      \"file_info\": {\n        \"path\": \"api\\\\__init__.py\",\n        \"name\": \"__init__.py\",\n        \"extension\": \".py\",\n        \"size_bytes\": 0,\n        \"size_human\": \"0.00 B\",\n        \"modified\": \"2026-03-31T19:38:05.611080\"\n      },\n      \"content\": {\n        \"raw\": \"[空文件: __init__.py]\",\n        \"truncated\": false\n      },\n      \"metadata\": {\n        \"empty\": true,\n        \"error\": true\n      }\n    },\n    {\n      \"file_info\": {\n        \"path\": \"services\\\\holland_service.py\",\n        \"name\": \"holland_service.py\",\n        \"extension\": \".py\",\n        \"size_bytes\": 6794,\n        \"size_human\": \"6.63 KB\",\n        \"modified\": \"2026-03-26T22:02:46.136300\"\n      },\n      \"content\": {\n        \"raw\": \"# app/services/holland_service.py\\nimport os\\nimport pandas as pd\\nfrom pyecharts import options as opts\\nfrom pyecharts.charts import Radar\\nfrom pathlib import Path\\n\\nclass HollandTestService:\\n    \\\"\\\"\\\"霍兰德职业性格测试服务类\\\"\\\"\\\"\\n    \\n    def __init__(self):\\n        self.project_root = Path(__file__).resolve().parents[2]\\n        self.questions_file = self.project_root / \\\"data\\\" / \\\"holland\\\" / \\\"testQuestions.txt\\\"\\n        self.result_file = self.project_root / \\\"data\\\" / \\\"holland\\\" / \\\"result.txt\\\"\\n        self._questions = None\\n        self._result_descriptions = None\\n        \\n        # 确保数据目录存在\\n        self._ensure_data_dir()\\n    \\n    def _ensure_data_dir(self):\\n        \\\"\\\"\\\"确保数据目录存在\\\"\\\"\\\"\\n        data_dir = self.project_root / \\\"data\\\" / \\\"holland\\\"\\n        if not data_dir.exists():\\n            data_dir.mkdir(parents=True, exist_ok=True)\\n    \\n    def load_questions(self):\\n        \\\"\\\"\\\"加载题目列表\\\"\\\"\\\"\\n        if self._questions is not None:\\n            return self._questions\\n        \\n        questions = []\\n        if not self.questions_file.exists():\\n            # 如果文件不存在，返回示例数据\\n            return self._get_sample_questions()\\n        \\n        with open(self.questions_file, 'r', encoding='utf-8') as file:\\n            for line in file:\\n                line = line.strip()\\n                if not line:\\n                    continue\\n                parts = line.split('．')\\n                if len(parts) == 2:\\n                    questions.append({\\n                        'id': int(parts[0]),\\n                        'text': parts[1]\\n                    })\\n        self._questions = questions\\n        return questions\\n    \\n    def load_result_descriptions(self):\\n        \\\"\\\"\\\"加载结果描述\\\"\\\"\\\"\\n        if self._result_descriptions is not None:\\n            return self._result_descriptions\\n        \\n        types = ['艺术型', '常规型', '企业型', '研究型', '现实型', '社会型']\\n        result_descriptions = {}\\n        \\n        if not self.result_file.exists():\\n            return self._get_sample_results()\\n        \\n        with open(self.result_file, 'r', encoding='utf-8') as file:\\n            lines = [line.strip() for line in file.readlines() if line.strip()]\\n        \\n        # 每两种描述对应一种类型\\n        for i, type_name in enumerate(types):\\n            if i * 2 + 1 < len(lines):\\n                result_descriptions[type_name] = [\\n                    lines[i * 2],\\n                    lines[i * 2 + 1] if i * 2 + 1 < len(lines) else ''\\n                ]\\n        \\n        self._result_descriptions = result_descriptions\\n        return result_descriptions\\n    \\n    def calculate_types(self, answers):\\n        \\\"\\\"\\\"\\n        根据答案计算各类型得分\\n        answers: 长度为90的列表，1表示Yes，0表示No\\n        返回：各类型得分的字典\\n        \\\"\\\"\\\"\\n        type_scores = {\\n            '现实型': 0,\\n            '研究型': 0,\\n            '艺术型': 0,\\n            '社会型': 0,\\n            '企业型': 0,\\n            '常规型': 0\\n        }\\n        \\n        # 题目类型映射：根据题号除以6的余数判断\\n        for i, answer in enumerate(answers, start=1):\\n            remainder = i % 6\\n            if remainder == 1:\\n                type_scores['现实型'] += answer\\n            elif remainder == 2:\\n                type_scores['研究型'] += answer\\n            elif remainder == 3:\\n                type_scores['艺术型'] += answer\\n            elif remainder == 4:\\n                type_scores['社会型'] += answer\\n            elif remainder == 5:\\n                type_scores['企业型'] += answer\\n            elif remainder == 0:\\n                type_scores['常规型'] += answer\\n        \\n        return type_scores\\n    \\n    def get_top_types(self, scores):\\n        \\\"\\\"\\\"获取得分最高的前三类型\\\"\\\"\\\"\\n        sorted_types = sorted(scores.items(), key=lambda x: x[1], reverse=True)\\n        return [type_name for type_name, score in sorted_types[:3]]\\n    \\n    def generate_radar_chart(self, scores):\\n        \\\"\\\"\\\"生成雷达图HTML\\\"\\\"\\\"\\n        types_order = ['现实型', '研究型', '艺术型', '社会型', '企业型', '常规型']\\n        values = [scores[t] for t in types_order]\\n        \\n        radar = Radar()\\n        radar.add_schema(\\n            schema=[\\n                opts.RadarIndicatorItem(name=name, max_=15) for name in types_order\\n            ]\\n        )\\n        radar.add(\\n            \\\"得分统计\\\",\\n            [values],\\n            color='red',\\n            areastyle_opts=opts.AreaStyleOpts(opacity=0.5, color='pink')\\n        )\\n        radar.set_global_opts(\\n            title_opts=opts.TitleOpts(title='霍兰德职业性格测试结果'),\\n            legend_opts=opts.LegendOpts(selected_mode='single')\\n        )\\n        \\n        return radar.render_embed()\\n    \\n    def process_test(self, answers):\\n        \\\"\\\"\\\"\\n        处理完整的测试流程\\n        answers: 长度为90的列表\\n        返回：完整的测试结果\\n        \\\"\\\"\\\"\\n        # 1. 计算得分\\n        scores = self.calculate_types(answers)\\n        \\n        # 2. 获取前三类型\\n        top_types = self.get_top_types(scores)\\n        \\n        # 3. 加载结果描述\\n        result_details = self.load_result_descriptions()\\n        \\n        # 4. 生成雷达图\\n        radar_html = self.generate_radar_chart(scores)\\n        \\n        return {\\n            \\\"scores\\\": scores,\\n            \\\"top_types\\\": top_types,\\n            \\\"result_details\\\": result_details,\\n            \\\"radar_chart\\\": radar_html\\n        }\\n    \\n    def _get_sample_questions(self):\\n        \\\"\\\"\\\"返回示例题目（用于测试）\\\"\\\"\\\"\\n        return [\\n            {\\\"id\\\": i, \\\"text\\\": f\\\"示例题目 {i}：请根据实际情况回答\\\"} \\n            for i in range(1, 91)\\n        ]\\n    \\n    def _get_sample_results(self):\\n        \\\"\\\"\\\"返回示例结果描述\\\"\\\"\\\"\\n        return {\\n            '艺术型': ['有创造力，乐于创造新颖、与众不同的成果', '喜欢艺术性的工作，如音乐、舞蹈、唱歌'],\\n            '常规型': ['尊重权威和规章制度，喜欢按计划办事', '喜欢常规性的工作，如记账、秘书'],\\n            '企业型': ['追求权力、权威和物质财富', '喜欢推销、服务、管理等工作'],\\n            '研究型': ['思想家而非实干家，抽象思维能力强', '喜欢各种研究型工作'],\\n            '现实型': ['愿意使用工具从事操作性工作', '喜欢现实性的实在的工作'],\\n            '社会型': ['喜欢与人交往、不断结交新的朋友', '喜欢社会交往性工作']\\n        }\",\n        \"truncated\": false\n      },\n      \"metadata\": {\n        \"encoding\": \"utf-8\",\n        \"line_count\": 179,\n        \"displayed_lines\": 179,\n        \"truncated\": false,\n        \"size\": 6794,\n        \"empty\": false,\n        \"error\": null\n      }\n    },\n    {\n      \"file_info\": {\n        \"path\": \"services\\\\match_service.py\",\n        \"name\": \"match_service.py\",\n        \"extension\": \".py\",\n        \"size_bytes\": 7995,\n        \"size_human\": \"7.81 KB\",\n        \"modified\": \"2026-03-31T19:38:05.615807\"\n      },\n      \"content\": {\n        \"raw\": \"import json\\nimport math\\nimport re\\nfrom datetime import datetime\\n\\nfrom app.utils.db import supabase_request, get_http_session, get_dify_api_key, get_dify_base_url\\n\\n\\ndef _ensure_float_list(v, expected_dim: int) -> list[float]:\\n    if v is None:\\n        return [0.0] * expected_dim\\n    if isinstance(v, str):\\n        try:\\n            v = json.loads(v)\\n        except Exception:\\n            return [0.0] * expected_dim\\n    if not isinstance(v, (list, tuple)):\\n        return [0.0] * expected_dim\\n    out = []\\n    for x in v:\\n        try:\\n            out.append(float(x))\\n        except Exception:\\n            out.append(0.0)\\n        if len(out) >= expected_dim:\\n            break\\n    if len(out) < expected_dim:\\n        out.extend([0.0] * (expected_dim - len(out)))\\n    return out\\n\\n\\ndef _cosine_similarity(v1: list[float], v2: list[float]) -> float:\\n    dot = 0.0\\n    n1 = 0.0\\n    n2 = 0.0\\n    for a, b in zip(v1, v2):\\n        dot += a * b\\n        n1 += a * a\\n        n2 += b * b\\n    if n1 <= 1e-18 or n2 <= 1e-18:\\n        return 0.0\\n    return dot / (math.sqrt(n1) * math.sqrt(n2))\\n\\n\\ndef _parse_report_section(text: str) -> dict:\\n    dimensions = [\\\"tech\\\", \\\"soft\\\", \\\"project\\\", \\\"edu\\\"]\\n    result = {}\\n    for dim in dimensions:\\n        pattern = rf\\\"\\\\\\\\[{dim}\\\\\\\\]\\\\\\\\s*[:：]\\\\\\\\s*(.*?)(?=\\\\\\\\n\\\\\\\\s*\\\\\\\\[|$)\\\"\\n        match = re.search(pattern, text or \\\"\\\", re.S)\\n        content = match.group(1).strip() if match else \\\"暂无评价\\\"\\n        result[dim] = content.replace(\\\"**\\\", \\\"\\\")\\n    return result\\n\\n\\ndef _call_dify_workflow(user_id: int, inputs: dict) -> dict:\\n    api_key = get_dify_api_key()\\n    if not api_key:\\n        return {}\\n    base_url = get_dify_base_url()\\n    session = get_http_session()\\n    resp = session.post(\\n        f\\\"{base_url}/workflows/run\\\",\\n        headers={\\\"Authorization\\\": f\\\"Bearer {api_key}\\\"},\\n        json={\\\"inputs\\\": inputs, \\\"response_mode\\\": \\\"blocking\\\", \\\"user\\\": f\\\"tester_{user_id}\\\"},\\n        timeout=60,\\n    )\\n    if resp.status_code >= 400:\\n        raise RuntimeError(f\\\"Dify 请求失败: HTTP {resp.status_code}\\\")\\n    data = resp.json()\\n    if \\\"data\\\" not in data:\\n        raise RuntimeError(\\\"Dify 返回结构异常\\\")\\n    return data\\n\\n\\ndef run_job_match(user_id: int, job_id: int) -> dict:\\n    cached = supabase_request(\\n        \\\"GET\\\",\\n        \\\"/rest/v1/job_match_results\\\",\\n        params={\\n            \\\"user_id\\\": f\\\"eq.{int(user_id)}\\\",\\n            \\\"job_profile_id\\\": f\\\"eq.{int(job_id)}\\\",\\n            \\\"select\\\": \\\"*\\\",\\n            \\\"order\\\": \\\"matched_at.desc\\\",\\n            \\\"limit\\\": \\\"1\\\",\\n        },\\n    )\\n    if isinstance(cached, list) and cached:\\n        return cached[0]\\n\\n    job_res = supabase_request(\\n        \\\"GET\\\",\\n        \\\"/rest/v1/standard_job_profiles\\\",\\n        params={\\\"id\\\": f\\\"eq.{int(job_id)}\\\", \\\"select\\\": \\\"*\\\", \\\"limit\\\": \\\"1\\\"},\\n    )\\n    stu_res = supabase_request(\\n        \\\"GET\\\",\\n        \\\"/rest/v1/student_portraits\\\",\\n        params={\\\"user_id\\\": f\\\"eq.{int(user_id)}\\\", \\\"select\\\": \\\"*\\\", \\\"limit\\\": \\\"1\\\"},\\n    )\\n    if not isinstance(job_res, list) or not job_res:\\n        raise RuntimeError(\\\"未找到岗位画像\\\")\\n    if not isinstance(stu_res, list) or not stu_res:\\n        raise RuntimeError(\\\"未找到学生画像\\\")\\n    job = job_res[0]\\n    student = stu_res[0]\\n\\n    rpc_params = {\\n        \\\"p_user_id\\\": int(user_id),\\n        \\\"p_job_name\\\": str(job.get(\\\"job_name\\\", \\\"\\\")),\\n        \\\"p_job_level\\\": str(job.get(\\\"job_level\\\", \\\"\\\")),\\n    }\\n    tech_data = supabase_request(\\\"POST\\\", \\\"/rest/v1/rpc/match_tech_v2\\\", json_data=rpc_params)\\n    soft_data = supabase_request(\\\"POST\\\", \\\"/rest/v1/rpc/match_soft_v2\\\", json_data=rpc_params)\\n    tech_rpc = tech_data[0] if isinstance(tech_data, list) and tech_data else {\\\"match_score\\\": 0, \\\"missing_skills\\\": []}\\n    soft_rpc = soft_data[0] if isinstance(soft_data, list) and soft_data else {\\\"match_score\\\": 0, \\\"missing_skills\\\": []}\\n\\n    dim = 1024\\n    v_stu = _ensure_float_list(student.get(\\\"resume_embedding\\\"), dim)\\n    v_job = _ensure_float_list(job.get(\\\"embedding_vector\\\"), dim)\\n    vec_sim = _cosine_similarity(v_stu, v_job)\\n    vector_score = round(float(vec_sim) * 100.0, 2)\\n\\n    exp_res = supabase_request(\\n        \\\"GET\\\",\\n        \\\"/rest/v1/student_experience_detail\\\",\\n        params={\\\"user_id\\\": f\\\"eq.{int(user_id)}\\\", \\\"select\\\": \\\"exp_type,title,content_raw\\\"},\\n    )\\n    exp_text = \\\"\\\"\\n    if isinstance(exp_res, list) and exp_res:\\n        exp_text = \\\"\\\\n\\\".join(\\n            [f\\\"[{e.get('exp_type', '经历')}] {e.get('title', '未命名')}: {e.get('content_raw', '')}\\\" for e in exp_res]\\n        )\\n\\n    dify_inputs = {\\n        \\\"job_name\\\": str(job.get(\\\"job_name\\\", \\\"\\\")),\\n        \\\"job_level\\\": str(job.get(\\\"job_level\\\", \\\"\\\")),\\n        \\\"min_edu_level\\\": str(job.get(\\\"min_education_level\\\", \\\"不限\\\")),\\n        \\\"stu_degree\\\": str(student.get(\\\"degree\\\", \\\"未知\\\")),\\n        \\\"stu_major\\\": str(student.get(\\\"major\\\", \\\"未填专业\\\")),\\n        \\\"exp_text\\\": str(exp_text) if exp_text else \\\"暂无项目经历\\\",\\n        \\\"tech_score\\\": str(tech_rpc.get(\\\"match_score\\\", 0)),\\n        \\\"soft_score\\\": str(soft_rpc.get(\\\"match_score\\\", 0)),\\n        \\\"vector_score\\\": str(vector_score),\\n        \\\"missing_tech\\\": \\\", \\\".join(tech_rpc.get(\\\"missing_skills\\\") or []) or \\\"无核心缺失\\\",\\n        \\\"missing_soft\\\": \\\", \\\".join(soft_rpc.get(\\\"missing_skills\\\") or []) or \\\"无核心缺失\\\",\\n    }\\n\\n    d_res = _call_dify_workflow(int(user_id), dify_inputs)\\n    outputs = d_res.get(\\\"data\\\", {}).get(\\\"outputs\\\") or {}\\n\\n    edu_score = 0.0\\n    project_score = 0.0\\n    summary_dict = {}\\n    gap_dict = {}\\n    suggest_dict = {}\\n\\n    try:\\n        edu_raw = outputs.get(\\\"edu_score\\\", {})\\n        if isinstance(edu_raw, str):\\n            edu_raw = json.loads(edu_raw or \\\"{}\\\")\\n        edu_score = float(edu_raw.get(\\\"edu_major_score\\\", 0) if isinstance(edu_raw, dict) else edu_raw or 0)\\n\\n        proj_raw = outputs.get(\\\"project_score\\\", {})\\n        if isinstance(proj_raw, str):\\n            proj_raw = json.loads(proj_raw or \\\"{}\\\")\\n        project_score = float(proj_raw.get(\\\"project_score\\\", 0) if isinstance(proj_raw, dict) else proj_raw or 0)\\n\\n        report_raw = outputs.get(\\\"text\\\", {})\\n        if isinstance(report_raw, str):\\n            report_raw = json.loads(report_raw or \\\"{}\\\")\\n        if isinstance(report_raw, dict):\\n            summary_dict = report_raw.get(\\\"current_level_summary\\\", {}) or {}\\n            gap_dict = report_raw.get(\\\"gap_analysis\\\", {}) or {}\\n            suggest_dict = report_raw.get(\\\"improvement_suggestions\\\", {}) or {}\\n    except Exception:\\n        txt = str(outputs.get(\\\"text\\\") or \\\"\\\")\\n        summary_dict = _parse_report_section(txt)\\n\\n    w_tech = float(job.get(\\\"weight_tech\\\", 0.4) or 0.4)\\n    w_proj = float(job.get(\\\"weight_project\\\", 0.2) or 0.2)\\n    w_acad = float(job.get(\\\"weight_academic\\\", 0.2) or 0.2)\\n    w_soft = float(job.get(\\\"weight_soft\\\", 0.1) or 0.1)\\n    w_vec = float(job.get(\\\"weight_vector\\\", 0.1) or 0.1)\\n\\n    total_score = (\\n        float(tech_rpc.get(\\\"match_score\\\", 0)) * w_tech\\n        + float(project_score) * w_proj\\n        + float(edu_score) * w_acad\\n        + float(soft_rpc.get(\\\"match_score\\\", 0)) * w_soft\\n        + float(vector_score) * w_vec\\n    )\\n\\n    final_record = {\\n        \\\"user_id\\\": int(user_id),\\n        \\\"job_profile_id\\\": int(job_id),\\n        \\\"total_score\\\": round(float(total_score), 2),\\n        \\\"tech_score\\\": float(tech_rpc.get(\\\"match_score\\\", 0)),\\n        \\\"project_score\\\": float(project_score),\\n        \\\"edu_major_score\\\": float(edu_score),\\n        \\\"soft_skill_score\\\": float(soft_rpc.get(\\\"match_score\\\", 0)),\\n        \\\"vector_similarity\\\": float(vec_sim),\\n        \\\"current_level_summary\\\": summary_dict,\\n        \\\"gap_analysis\\\": gap_dict,\\n        \\\"improvement_suggestions\\\": suggest_dict,\\n        \\\"matched_at\\\": datetime.utcnow().isoformat(timespec=\\\"seconds\\\") + \\\"Z\\\",\\n    }\\n\\n    inserted = supabase_request(\\\"POST\\\", \\\"/rest/v1/job_match_results\\\", json_data=final_record)\\n    if isinstance(inserted, list) and inserted:\\n        return inserted[0]\\n    return final_record\\n\",\n        \"truncated\": false\n      },\n      \"metadata\": {\n        \"encoding\": \"utf-8\",\n        \"line_count\": 213,\n        \"displayed_lines\": 213,\n        \"truncated\": false,\n        \"size\": 7995,\n        \"empty\": false,\n        \"error\": null\n      }\n    },\n    {\n      \"file_info\": {\n        \"path\": \"services\\\\recommend_service.py\",\n        \"name\": \"recommend_service.py\",\n        \"extension\": \".py\",\n        \"size_bytes\": 9000,\n        \"size_human\": \"8.79 KB\",\n        \"modified\": \"2026-03-31T19:38:05.617345\"\n      },\n      \"content\": {\n        \"raw\": \"import json\\nfrom typing import Any\\nfrom datetime import datetime\\n\\nfrom app.utils.db import supabase_request, get_http_session, get_dify_base_url, get_dify_recommend_api_key\\n\\n\\ndef _iso_now() -> str:\\n    \\\"\\\"\\\"返回 ISO 格式的当前时间\\\"\\\"\\\"\\n    return datetime.utcnow().isoformat(timespec=\\\"seconds\\\") + \\\"Z\\\"\\n\\n\\ndef _get_user_resume(user_id: int) -> str:\\n    \\\"\\\"\\\"\\n    从 student_portraits 表中获取用户的简历内容\\n    \\\"\\\"\\\"\\n    res = supabase_request(\\n        \\\"GET\\\",\\n        \\\"/rest/v1/student_portraits\\\",\\n        params={\\n            \\\"user_id\\\": f\\\"eq.{int(user_id)}\\\",\\n            \\\"select\\\": \\\"resume_content\\\",\\n            \\\"limit\\\": \\\"1\\\"\\n        }\\n    )\\n    \\n    if isinstance(res, list) and res:\\n        return res[0].get(\\\"resume_content\\\") or \\\"\\\"\\n    return \\\"\\\"\\n\\n\\ndef _call_supabase_function(user_id: int) -> list[dict]:\\n    \\\"\\\"\\\"\\n    调用 Supabase 的 fn_get_top_matches 函数\\n    返回向量匹配度最高的 10 个岗位\\n    \\\"\\\"\\\"\\n    result = supabase_request(\\n        \\\"POST\\\",\\n        \\\"/rest/v1/rpc/fn_get_top_matches\\\",\\n        json_data={\\\"p_user_id\\\": int(user_id)}\\n    )\\n    \\n    if isinstance(result, list):\\n        return result\\n    return []\\n\\n\\ndef _format_jobs_for_dify(jobs: list[dict]) -> str:\\n    \\\"\\\"\\\"\\n    将岗位列表格式化为适合 Dify 输入的文本\\n    \\\"\\\"\\\"\\n    formatted = []\\n    for idx, job in enumerate(jobs, 1):\\n        skills = job.get(\\\"required_skills\\\", [])\\n        if isinstance(skills, str):\\n            try:\\n                skills = json.loads(skills)\\n            except Exception:\\n                skills = []\\n        \\n        skills_text = \\\", \\\".join(skills) if isinstance(skills, list) else str(skills)\\n        \\n        job_text = f\\\"\\\"\\\"\\n【岗位 {idx}】\\n- 岗位ID: {job.get('job_id')}\\n- 岗位名称: {job.get('job_name')}\\n- 公司: {job.get('company')}\\n- 岗位描述: {job.get('job_desc', '暂无描述')[:200]}\\n- 技能要求: {skills_text}\\n- 来源: {job.get('job_source')}\\n- 向量匹配分: {job.get('match_score', 0):.2f}\\n\\\"\\\"\\\"\\n        formatted.append(job_text.strip())\\n    \\n    return \\\"\\\\n\\\\n\\\".join(formatted)\\n\\n\\ndef _call_dify_recommend(user_resume: str, jobs_text: str, user_id: int) -> dict:\\n    \\\"\\\"\\\"\\n    调用 Dify API 进行智能推荐\\n    从 10 个候选岗位中筛选出最推荐的 3 个\\n    \\\"\\\"\\\"\\n    api_key = get_dify_recommend_api_key()\\n    if not api_key:\\n        return {}\\n    \\n    base_url = get_dify_base_url()\\n    session = get_http_session()\\n    \\n    # 设计 Dify 输入参数\\n    payload = {\\n        \\\"inputs\\\": {\\n            \\\"user_resume\\\": user_resume[:3000],  # 限制简历长度避免 token 超限\\n            \\\"candidate_jobs\\\": jobs_text,\\n            \\\"recommendation_count\\\": \\\"3\\\"\\n        },\\n        \\\"response_mode\\\": \\\"blocking\\\",\\n        \\\"user\\\": f\\\"recommend_{user_id}\\\"\\n    }\\n    \\n    try:\\n        resp = session.post(\\n            f\\\"{base_url}/workflows/run\\\",\\n            headers={\\\"Authorization\\\": f\\\"Bearer {api_key}\\\"},\\n            json=payload,\\n            timeout=60\\n        )\\n    except Exception as e:\\n        raise RuntimeError(f\\\"Dify API 调用失败: {str(e)}\\\")\\n    \\n    if resp.status_code >= 400:\\n        raise RuntimeError(f\\\"Dify API 返回错误: HTTP {resp.status_code}\\\")\\n    \\n    try:\\n        data = resp.json()\\n    except Exception:\\n        raise RuntimeError(\\\"Dify 返回数据解析失败\\\")\\n    \\n    outputs = data.get(\\\"data\\\", {}).get(\\\"outputs\\\") or {}\\n    return outputs\\n\\n\\ndef _parse_dify_recommendations(outputs: dict, original_jobs: list[dict]) -> list[dict]:\\n    \\\"\\\"\\\"\\n    解析 Dify 返回的推荐结果\\n    支持多种可能的输出格式\\n    \\\"\\\"\\\"\\n    # 尝试从多个可能的字段中获取推荐结果\\n    recommendations = None\\n    \\n    for key in [\\\"recommendations\\\", \\\"top_jobs\\\", \\\"selected_jobs\\\", \\\"result\\\", \\\"text\\\"]:\\n        if key in outputs:\\n            raw = outputs[key]\\n            \\n            # 如果是字符串，尝试解析为 JSON\\n            if isinstance(raw, str):\\n                try:\\n                    recommendations = json.loads(raw)\\n                    if isinstance(recommendations, list):\\n                        break\\n                except Exception:\\n                    # 可能是纯文本，尝试提取岗位ID\\n                    import re\\n                    job_ids = re.findall(r'岗位ID[：:]\\\\s*(\\\\d+)', raw)\\n                    if job_ids:\\n                        recommendations = [{\\\"job_id\\\": int(jid)} for jid in job_ids[:3]]\\n                        break\\n            \\n            # 如果已经是列表\\n            elif isinstance(raw, list):\\n                recommendations = raw\\n                break\\n    \\n    # 如果没有找到推荐结果，返回前3个原始岗位\\n    if not recommendations or not isinstance(recommendations, list):\\n        return original_jobs[:3]\\n    \\n    # 匹配推荐的岗位ID到原始岗位数据\\n    result = []\\n    for rec in recommendations[:3]:\\n        if isinstance(rec, dict):\\n            job_id = rec.get(\\\"job_id\\\")\\n            # 从原始岗位列表中找到对应的完整信息\\n            matched_job = next((j for j in original_jobs if j.get(\\\"job_id\\\") == job_id), None)\\n            \\n            if matched_job:\\n                # 合并 Dify 返回的推荐理由\\n                final_job = dict(matched_job)\\n                final_job[\\\"recommend_reason\\\"] = rec.get(\\\"reason\\\") or rec.get(\\\"recommend_reason\\\") or \\\"该岗位与您的背景高度匹配\\\"\\n                final_job[\\\"rank\\\"] = len(result) + 1\\n                result.append(final_job)\\n    \\n    # 如果解析失败，返回前3个原始岗位\\n    if not result:\\n        for idx, job in enumerate(original_jobs[:3], 1):\\n            job_copy = dict(job)\\n            job_copy[\\\"recommend_reason\\\"] = \\\"基于向量相似度匹配\\\"\\n            job_copy[\\\"rank\\\"] = idx\\n            result.append(job_copy)\\n    \\n    return result\\n\\n\\ndef get_smart_job_recommendations(user_id: int) -> dict:\\n    \\\"\\\"\\\"\\n    获取智能岗位推荐\\n    \\n    流程：\\n    1. 优先从缓存表 job_recommendations 中查询\\n    2. 如果缓存存在，直接返回\\n    3. 如果缓存不存在，执行完整推荐流程并保存到缓存表\\n    \\\"\\\"\\\"\\n    # 1. 检查缓存（查询最新的一条推荐记录）\\n    cached = supabase_request(\\n        \\\"GET\\\",\\n        \\\"/rest/v1/job_recommendations\\\",\\n        params={\\n            \\\"user_id\\\": f\\\"eq.{int(user_id)}\\\",\\n            \\\"select\\\": \\\"*\\\",\\n            \\\"order\\\": \\\"generated_at.desc\\\",\\n            \\\"limit\\\": \\\"1\\\"\\n        }\\n    )\\n    \\n    # 2. 如果有缓存，直接返回\\n    if isinstance(cached, list) and cached:\\n        cache_record = cached[0]\\n        recommended_jobs = cache_record.get(\\\"recommended_jobs\\\", [])\\n        \\n        # 如果 recommended_jobs 是字符串，解析为 JSON\\n        if isinstance(recommended_jobs, str):\\n            try:\\n                recommended_jobs = json.loads(recommended_jobs)\\n            except Exception:\\n                recommended_jobs = []\\n        \\n        # 如果缓存有效，直接返回\\n        if recommended_jobs:\\n            return {\\n                \\\"user_id\\\": user_id,\\n                \\\"total_candidates\\\": 10,\\n                \\\"recommended_count\\\": len(recommended_jobs),\\n                \\\"recommendations\\\": recommended_jobs,\\n                \\\"generated_at\\\": cache_record.get(\\\"generated_at\\\"),\\n                \\\"from_cache\\\": True\\n            }\\n    \\n    # 3. 没有缓存，执行完整推荐流程\\n    \\n    # 3.1 获取用户简历\\n    user_resume = _get_user_resume(user_id)\\n    if not user_resume:\\n        raise RuntimeError(\\\"未找到用户简历，请先完善个人信息\\\")\\n    \\n    # 3.2 调用 Supabase 函数获取候选岗位\\n    candidate_jobs = _call_supabase_function(user_id)\\n    \\n    if not candidate_jobs:\\n        raise RuntimeError(\\\"未找到匹配的岗位\\\")\\n    \\n    # 3.3 格式化岗位信息用于 Dify 分析\\n    jobs_text = _format_jobs_for_dify(candidate_jobs)\\n    \\n    # 3.4 调用 Dify 进行智能推荐\\n    dify_outputs = _call_dify_recommend(user_resume, jobs_text, user_id)\\n    \\n    # 3.5 解析 Dify 返回结果\\n    top_recommendations = _parse_dify_recommendations(dify_outputs, candidate_jobs)\\n    \\n    # 3.6 保存到缓存表\\n    now = _iso_now()\\n    cache_data = {\\n        \\\"user_id\\\": int(user_id),\\n        \\\"recommended_jobs\\\": top_recommendations,\\n        \\\"generated_at\\\": now\\n    }\\n    \\n    try:\\n        supabase_request(\\\"POST\\\", \\\"/rest/v1/job_recommendations\\\", json_data=cache_data)\\n    except Exception as e:\\n        # 缓存保存失败不影响返回结果\\n        print(f\\\"警告：推荐结果缓存保存失败: {e}\\\")\\n    \\n    # 3.7 构建返回结果\\n    return {\\n        \\\"user_id\\\": user_id,\\n        \\\"total_candidates\\\": len(candidate_jobs),\\n        \\\"recommended_count\\\": len(top_recommendations),\\n        \\\"recommendations\\\": top_recommendations,\\n        \\\"generated_at\\\": now,\\n        \\\"from_cache\\\": False\\n    }\\n\",\n        \"truncated\": false\n      },\n      \"metadata\": {\n        \"encoding\": \"utf-8\",\n        \"line_count\": 273,\n        \"displayed_lines\": 273,\n        \"truncated\": false,\n        \"size\": 9000,\n        \"empty\": false,\n        \"error\": null\n      }\n    },\n    {\n      \"file_info\": {\n        \"path\": \"services\\\\roadmap_service.py\",\n        \"name\": \"roadmap_service.py\",\n        \"extension\": \".py\",\n        \"size_bytes\": 9796,\n        \"size_human\": \"9.57 KB\",\n        \"modified\": \"2026-03-31T19:38:05.617345\"\n      },\n      \"content\": {\n        \"raw\": \"import json\\nfrom typing import Any\\nfrom datetime import datetime\\nimport re\\nimport ast\\n\\nfrom app.utils.db import supabase_request, get_http_session, get_dify_base_url, get_dify_task_api_key\\nfrom app.services.match_service import run_job_match\\n\\n\\ndef _iso_now() -> str:\\n    return datetime.utcnow().isoformat(timespec=\\\"seconds\\\") + \\\"Z\\\"\\n\\n\\ndef _get_job(job_id: int) -> dict | None:\\n    res = supabase_request(\\n        \\\"GET\\\",\\n        \\\"/rest/v1/standard_job_profiles\\\",\\n        params={\\\"id\\\": f\\\"eq.{int(job_id)}\\\", \\\"select\\\": \\\"id,job_name\\\", \\\"limit\\\": \\\"1\\\"},\\n    )\\n    if isinstance(res, list) and res:\\n        return res[0]\\n    return None\\n\\n\\ndef _get_or_create_match(user_id: int, job_id: int) -> dict:\\n    hit = supabase_request(\\n        \\\"GET\\\",\\n        \\\"/rest/v1/job_match_results\\\",\\n        params={\\n            \\\"user_id\\\": f\\\"eq.{int(user_id)}\\\",\\n            \\\"job_profile_id\\\": f\\\"eq.{int(job_id)}\\\",\\n            \\\"select\\\": \\\"*\\\",\\n            \\\"order\\\": \\\"matched_at.desc\\\",\\n            \\\"limit\\\": \\\"1\\\",\\n        },\\n    )\\n    if isinstance(hit, list) and hit:\\n        return hit[0]\\n    return run_job_match(user_id, job_id)\\n\\n\\ndef _call_dify_tasks(target_job_name: str, gap: Any, suggest: Any) -> list[dict]:\\n    def _to_text_input(v: Any) -> str:\\n        if v is None:\\n            return \\\"\\\"\\n        if isinstance(v, str):\\n            return v\\n        try:\\n            return json.dumps(v, ensure_ascii=False)\\n        except Exception:\\n            return str(v)\\n\\n    api_key = get_dify_task_api_key()\\n    if not api_key:\\n        return []\\n    base_url = get_dify_base_url()\\n    sess = get_http_session()\\n    payload = {\\n        \\\"inputs\\\": {\\n            \\\"target_job_name\\\": target_job_name,\\n            \\\"gap_analysis\\\": _to_text_input(gap),\\n            \\\"improvement_suggestions\\\": _to_text_input(suggest),\\n        },\\n        \\\"response_mode\\\": \\\"blocking\\\",\\n        \\\"user\\\": f\\\"roadmap_{target_job_name}\\\",\\n    }\\n    try:\\n        resp = sess.post(\\n            f\\\"{base_url}/workflows/run\\\",\\n            headers={\\\"Authorization\\\": f\\\"Bearer {api_key}\\\"},\\n            json=payload,\\n            timeout=60,\\n        )\\n    except Exception:\\n        return []\\n    if resp