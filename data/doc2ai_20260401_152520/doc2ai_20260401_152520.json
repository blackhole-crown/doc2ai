data.append(news_item)\\n            title_duplicate_set.add(title)\\n            current_auto_id += 1  # IDè‡ªå¢�\\n            page_count += 1\\n    \\n    print(f\\\"âœ… ç¬¬{page_num}é¡µï¼šæ–°å¢� {page_count} æ�¡ä¸�é‡�å¤�æ•°æ�®ï¼ˆå½“å‰�æœ€å¤§ID={current_auto_id-1}ï¼‰\\\")\\n    return page_new_data, len(all_a) > 0\\n\\ndef crawl_dynamic_pages():\\n    \\\"\\\"\\\"æ¨¡æ‹ŸJSç¿»é¡µçˆ¬å�–æ‰€æœ‰æ•°æ�®\\\"\\\"\\\"\\n    session = requests.Session()\\n    all_new_data = []\\n    current_page = 1\\n    has_next_page = True\\n    \\n    # çˆ¬å�–ç¬¬ä¸€é¡µ\\n    print(f\\\"\\\\nğŸš€ å¼€å§‹çˆ¬å�–ç¬¬ {current_page} é¡µï¼ˆåˆ�å§‹é¡µï¼‰\\\")\\n    response = session.get(BASE_URL, headers=HEADERS, timeout=15, verify=False)\\n    response.encoding = \\\"utf-8\\\"\\n    page_data, has_data = extract_page_data(response.text, current_page)\\n    all_new_data.extend(page_data)\\n    \\n    # å¾ªç�¯çˆ¬å�–ä¸‹ä¸€é¡µ\\n    while has_next_page and has_data:\\n        current_page += 1\\n        print(f\\\"\\\\nğŸ“� æ¨¡æ‹Ÿç‚¹å‡»ä¸‹ä¸€é¡µï¼Œçˆ¬å�–ç¬¬ {current_page} é¡µ\\\")\\n        next_page_url = f\\\"{BASE_URL}?p={current_page}&pageSize=15\\\"\\n        \\n        try:\\n            time.sleep(2)  # æ¨¡æ‹Ÿäººç±»ç¿»é¡µå»¶è¿Ÿ\\n            response = session.get(next_page_url, headers=HEADERS, timeout=15, verify=False)\\n            response.raise_for_status()\\n            response.encoding = \\\"utf-8\\\"\\n            \\n            page_data, has_data = extract_page_data(response.text, current_page)\\n            all_new_data.extend(page_data)\\n            \\n            # æ— æ–°æ•°æ�®åˆ™å�œæ­¢ç¿»é¡µ\\n            if len(page_data) == 0:\\n                has_next_page = False\\n                print(f\\\"ğŸ“Œ ç¬¬{current_page}é¡µæ— æ–°æ•°æ�®ï¼Œå·²çˆ¬å�–åˆ°æœ€å��ä¸€é¡µ\\\")\\n                \\n            time.sleep(0.5)  # éš�æœºå°�å»¶è¿Ÿ\\n            \\n        except Exception as e:\\n            print(f\\\"â�Œ ç¬¬{current_page}é¡µçˆ¬å�–å¤±è´¥ï¼š{str(e)[:100]}\\\")\\n            t