      "content": {
        "raw": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Folder2Context - AI 友好的文件夹分析工具</title>\n    <link rel=\"stylesheet\" href=\"https://unpkg.com/element-ui/lib/theme-chalk/index.css\">\n    <link rel=\"stylesheet\" href=\"{{ url_for('static', filename='css/style.css') }}\">\n</head>\n<body>\n    <div id=\"app\">\n        <!-- 头部 -->\n        <el-header>\n            <div class=\"header-container\">\n                <h1>\n                    <i class=\"el-icon-folder-opened\"></i>\n                    Folder2Context\n                    <span class=\"subtitle\">让 AI 轻松理解你的项目结构</span>\n                </h1>\n                <div class=\"header-actions\">\n                    <el-button type=\"text\" @click=\"showConfig = true\">\n                        <i class=\"el-icon-setting\"></i> 配置\n                    </el-button>\n                    <el-button type=\"text\" @click=\"showHelp = true\">\n                        <i class=\"el-icon-question\"></i> 帮助\n                    </el-button>\n                </div>\n            </div>\n        </el-header>\n\n        <el-main>\n            <!-- 主要操作区 -->\n            <el-row :gutter=\"20\">\n                <!-- 左侧：输入区 -->\n                <el-col :span=\"12\">\n                    <el-card class=\"input-card\">\n                        <div slot=\"header\">\n                            <span><i class=\"el-icon-upload\"></i> 选择项目</span>\n                        </div>\n                        \n                        <!-- 上传方式切换 -->\n                        <el-radio-group v-model=\"inputMethod\" style=\"margin-bottom: 20px;\">\n                            <el-radio-button label=\"path\">本地路径</el-radio-button>\n                            <el-radio-button label=\"upload\">上传压缩包</el-radio-button>\n                        </el-radio-group>\n\n                        <!-- 本地路径输入 -->\n                        <div v-if=\"inputMethod === 'path'\">\n                            <el-input\n                                v-model=\"folderPath\"\n                                placeholder=\"请输入文件夹路径，例如：D:/Projects/myapp\"\n                                clearable>\n                                <el-button slot=\"append\" icon=\"el-icon-search\" @click=\"previewFolder\">预览</el-button>\n                            </el-input>\n                            <div class=\"path-tips\">\n                                <i class=\"el-icon-info\"></i> \n                                支持绝对路径和相对路径，可以使用 / 或 \\\\\n                            </div>\n                        </div>\n\n                        <!-- 文件上传 -->\n                        <div v-else>\n                            <el-upload\n                                class=\"upload-area\"\n                                drag\n                                :action=\"uploadUrl\"\n                                :on-success=\"handleUploadSuccess\"\n                                :on-error=\"handleUploadError\"\n                                :before-upload=\"beforeUpload\"\n                                :file-list=\"fileList\">\n                                <i class=\"el-icon-upload\"></i>\n                                <div class=\"el-upload__text\">将压缩包拖到此处，或<em>点击上传</em></div>\n                                <div class=\"el-upload__tip\" slot=\"tip\">\n                                    支持 .zip, .tar, .tar.gz 格式，最大 500MB\n                                </div>\n                            </el-upload>\n                            \n                            <!-- 上传任务状态 -->\n                            <div v-if=\"uploadTaskId\" class=\"upload-status\">\n                                <el-progress \n                                    :percentage=\"uploadProgress\" \n                                    :status=\"uploadStatus\"\n                                    :format=\"formatProgress\">\n                                </el-progress>\n                                <div class=\"status-message\">{{ uploadMessage }}</div>\n                            </div>\n                        </div>\n\n                        <!-- 处理按钮 -->\n                        <div class=\"action-buttons\">\n                            <el-button \n                                type=\"primary\" \n                                :loading=\"processing\"\n                                @click=\"processFolder\"\n                                :disabled=\"!canProcess\">\n                                <i class=\"el-icon-cpu\"></i> \n                                {{ processing ? '处理中...' : '开始处理' }}\n                            </el-button>\n                            \n                            <el-button \n                                v-if=\"result\"\n                                type=\"success\" \n                                @click=\"downloadResult\">\n                                <i class=\"el-icon-download\"></i> 下载结果\n                            </el-button>\n                        </div>\n                    </el-card>\n                </el-col>\n\n                <!-- 右侧：预览区 -->\n                <el-col :span=\"12\">\n                    <el-card class=\"preview-card\">\n                        <div slot=\"header\">\n                            <span><i class=\"el-icon-view\"></i> 项目预览</span>\n                            <el-button \n                                v-if=\"previewTree\" \n                                type=\"text\" \n                                size=\"small\" \n                                @click=\"clearPreview\"\n                                style=\"float: right;\">\n                                清空\n                            </el-button>\n                        </div>\n                        \n                        <div v-if=\"previewTree\" class=\"preview-content\">\n                            <el-tree\n                                :data=\"[previewTree]\"\n                                :props=\"treeProps\"\n                                node-key=\"path\"\n                                :expand-on-click-node=\"false\"\n                                :default-expanded-keys=\"defaultExpandedKeys\">\n                                <span class=\"custom-tree-node\" slot-scope=\"{ node, data }\">\n                                    <i :class=\"data.type === 'directory' ? 'el-icon-folder' : 'el-icon-document'\"></i>\n                                    <span class=\"node-name\">{{ node.label }}</span>\n                                    <span v-if=\"data.type === 'file'\" class=\"node-size\">{{ data.size_human }}</span>\n                                </span>\n                            </el-tree>\n                        </div>\n                        <div v-else class=\"preview-placeholder\">\n                            <i class=\"el-icon-folder-opened\"></i>\n                            <p>输入路径后点击「预览」查看项目结构</p>\n                            <p class=\"tip\">或上传压缩包自动预览</p>\n                        </div>\n                    </el-card>\n                </el-col>\n            </el-row>\n\n            <!-- 处理结果展示 -->\n            <el-card v-if=\"result\" class=\"result-card\">\n                <div slot=\"header\">\n                    <span><i class=\"el-icon-data-analysis\"></i> 处理结果</span>\n                    <el-button type=\"text\" size=\"small\" @click=\"showRawJson = !showRawJson\">\n                        {{ showRawJson ? '显示统计' : '显示原始 JSON' }}\n                    </el-button>\n                </div>\n                \n                <!-- 统计信息 -->\n                <div v-if=\"!showRawJson\" class=\"stats-content\">\n                    <el-row :gutter=\"20\">\n                        <el-col :span=\"8\">\n                            <div class=\"stat-card\">\n                                <div class=\"stat-number\">{{ result.statistics.total_files }}</div>\n                                <div class=\"stat-label\">文件总数</div>\n                            </div>\n                        </el-col>\n                        <el-col :span=\"8\">\n                            <div class=\"stat-card\">\n                                <div class=\"stat-number\">{{ result.statistics.total_size_human }}</div>\n                                <div class=\"stat-label\">总大小</div>\n                            </div>\n                        </el-col>\n                        <el-col :span=\"8\">\n                            <div class=\"stat-card\">\n                                <div class=\"stat-number\">{{ result.statistics.skipped_files || 0 }}</div>\n                                <div class=\"stat-label\">跳过文件</div>\n                            </div>\n                        </el-col>\n                    </el-row>\n                    \n                    <div class=\"file-types\">\n                        <h4>文件类型分布</h4>\n                        <div class=\"type-tags\">\n                            <el-tag \n                                v-for=\"(count, ext) in result.statistics.file_types\" \n                                :key=\"ext\"\n                                size=\"medium\"\n                                style=\"margin: 5px;\">\n                                {{ ext || '无扩展名' }}: {{ count }}\n                            </el-tag>\n                        </div>\n                    </div>\n                    \n                    <div class=\"project-tree\">\n                        <h4>项目结构</h4>\n                        <el-tree\n                            :data=\"[result.tree]\"\n                            :props=\"treeProps\"\n                            node-key=\"path\"\n                            :expand-on-click-node=\"false\">\n                            <span class=\"custom-tree-node\" slot-scope=\"{ node, data }\">\n                                <i :class=\"data.type === 'directory' ? 'el-icon-folder' : 'el-icon-document'\"></i>\n                                <span class=\"node-name\">{{ node.label }}</span>\n                            </span>\n                        </el-tree>\n                    </div>\n                </div>\n                \n                <!-- 原始 JSON -->\n                <div v-else class=\"json-content\">\n                    <pre>{{ JSON.stringify(result, null, 2) }}</pre>\n                </div>\n            </el-card>\n        </el-main>\n\n        <!-- 配置对话框 -->\n        <el-dialog title=\"配置选项\" :visible.sync=\"showConfig\" width=\"600px\">\n            <el-form :model=\"config\" label-width=\"140px\">\n                <el-form-item label=\"最大文件大小 (MB)\">\n                    <el-input-number v-model=\"config.processing.max_file_size_mb\" :min=\"1\" :max=\"100\"></el-input-number>\n                </el-form-item>\n                <el-form-item label=\"最大文件行数\">\n                    <el-input-number v-model=\"config.analysis.max_line_count\" :min=\"10\" :max=\"10000\"></el-input-number>\n                </el-form-item>\n                <el-form-item label=\"截断模式\">\n                    <el-select v-model=\"config.analysis.truncate_mode\">\n                        <el-option label=\"保留头尾\" value=\"head_tail\"></el-option>\n                        <el-option label=\"仅保留开头\" value=\"head_only\"></el-option>\n                        <el-option label=\"仅保留结尾\" value=\"tail_only\"></el-option>\n                    </el-select>\n                </el-form-item>\n                <el-form-item label=\"排除模式\">\n                    <el-input\n                        type=\"textarea\"\n                        :rows=\"3\"\n                        v-model=\"excludePatternsText\"\n                        placeholder=\"每行一个排除模式，例如：.git&#10;__pycache__&#10;*.log\">\n                    </el-input>\n                </el-form-item>\n                <el-form-item label=\"输出格式\">\n                    <el-radio-group v-model=\"config.output.format\">\n                        <el-radio label=\"detailed\">详细格式</el-radio>\n                        <el-radio label=\"compact\">紧凑格式</el-radio>\n                        <el-radio label=\"minimal\">最简格式</el-radio>\n                    </el-radio-group>\n                </el-form-item>\n            </el-form>\n            <span slot=\"footer\">\n                <el-button @click=\"showConfig = false\">取消</el-button>\n                <el-button type=\"primary\" @click=\"saveConfig\">保存配置</el-button>\n            </span>\n        </el-dialog>\n\n        <!-- 帮助对话框 -->\n        <el-dialog title=\"使用帮助\" :visible.sync=\"showHelp\" width=\"500px\">\n            <div class=\"help-content\">\n                <h4>本地路径模式</h4>\n                <p>输入服务器上已有的文件夹路径，点击「预览」查看结构，点击「开始处理」进行分析。</p>\n                \n                <h4>上传压缩包模式</h4>\n                <p>上传项目的 ZIP 或 TAR 压缩包，系统会自动解压并分析。</p>\n                \n                <h4>输出格式</h4>\n                <ul>\n                    <li><strong>详细格式</strong>：包含完整的元数据、目录树和文件内容</li>\n                    <li><strong>紧凑格式</strong>：精简输出，适合大型项目</li>\n                    <li><strong>最简格式</strong>：只包含文件路径和内容</li>\n                </ul>\n                \n                <h4>排除模式</h4>\n                <p>支持通配符，例如：<code>*.log</code>、<code>__pycache__</code>、<code>.git</code></p>\n            </div>\n        </el-dialog>\n    </div>\n\n    <script src=\"https://cdn.jsdelivr.net/npm/vue@2.6.14/dist/vue.js\"></script>\n    <script src=\"https://unpkg.com/element-ui/lib/index.js\"></script>\n    <script src=\"https://unpkg.com/axios/dist/axios.min.js\"></script>\n    <script src=\"{{ url_for('static', filename='js/app.js') }}\"></script>\n</body>\n</html>",
        "truncated": false
      },
