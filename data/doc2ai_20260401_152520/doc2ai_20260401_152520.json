ubmit_test():\\n    \\\"\\\"\\\"\\n    提交测试答案\\n    请求体: {\\\"answers\\\": [0,1,0,1,...]} 长度为90\\n    \\\"\\\"\\\"\\n    try:\\n        data = request.get_json()\\n        \\n        if not data:\\n            return jsonify({\\n                \\\"code\\\": 400,\\n                \\\"message\\\": \\\"请提供答案数据\\\"\\n            }), 400\\n        \\n        answers = data.get('answers')\\n        \\n        if not answers:\\n            return jsonify({\\n                \\\"code\\\": 400,\\n                \\\"message\\\": \\\"缺少 answers 字段\\\"\\n            }), 400\\n        \\n        # 验证答案长度\\n        if len(answers) != 90:\\n            return jsonify({\\n                \\\"code\\\": 400,\\n                \\\"message\\\": f\\\"答案数量必须是90个，当前为 {len(answers)} 个\\\"\\n            }), 400\\n        \\n        # 验证答案格式\\n        if not all(ans in [0, 1] for ans in answers):\\n            return jsonify({\\n                \\\"code\\\": 400,\\n                \\\"message\\\": \\\"答案只能是0或1\\\"\\n            }), 400\\n        \\n        # 处理测试\\n        result = holland_service.process_test(answers)\\n        \\n        return jsonify({\\n            \\\"code\\\": 200,\\n            \\\"message\\\": \\\"测试完成\\\",\\n            \\\"data\\\": result\\n        })\\n        \\n    except Exception as e:\\n        return jsonify({\\n            \\\"code\\\": 500,\\n            \\\"message\\\": f\\\"处理失败: {str(e)}\\\"\\n        }), 500\\n\\n\\n@holland_bp.route('/result-details/<type_name>', methods=['GET'])\\ndef get_result_detail(type_name):\\n    \\\"\\\"\\\"\\n    获取特定类型的详细描述\\n    \\\"\\\"\\\"\\n    try:\\n        result_details = holland_service.load_result_descriptions()\\n        \\n        if type_name not in result_details:\\n            return jsonify({\\n                \\\"code\\\": 404,\\n                \\\"message\\\": f\\\"未找到类型: {type_name}\\\"\\n            }), 404\\n        \\n        return jsonify({\\n            \\\"code\\\": 200,\\n            \\\"message\\\": \\\"获取成功\\\",\\n            \\\"data\\\": {\\n                \\\"type\\\": type_name,\\n                \\\"description\\\": result_details[type_name]\\n            }\\n        })\\n        \\n    except Exception as e:\\n        return jsonify({\\n            \\\"code\\\": 500,\\n            \\\"message\\\": f\\\"获取失败: {str(e)}\\\"\\n        }), 500\\n\\n\\n@holland_bp.route('/health', methods=['GET'])\\ndef health_check():\\n    \\\"\\\"\\\"健康检查\\\"\\\"\\\"\\n    return jsonify({\\n        \\\"code\\\": 200,\\n        \\\"message\\\": \\\"霍兰德测试服务正常\\\",\\n        \\\"data\\\": {\\n            \\\"status\\\": \\\"running\\\",\\n            \\\"service\\\": \\\"holland_test\\\"\\n        }\\n    })\",\n        \"truncated\": false\n      },\n      \"metadata\": {\n        \"encoding\": \"utf-8\",\n        \"line_count\": 128,\n        \"displayed_lines\": 128,\n        \"truncated\": false,\n        \"size\": 3468,\n        \"empty\": false,\n        \"error\": null\n      }\n    },\n    {\n      \"file_info\": {\n        \"path\": \"api\\\\login.py\",\n        \"name\": \"login.py\",\n        \"extension\": \".py\",\n        \"size_bytes\": 2936,\n        \"size_human\": \"2.87 KB\",\n        \"modified\": \"2026-03-31T19:38:05.612658\"\n      },\n      \"content\": {\n        \"raw\": \"from flask import Blueprint, request, jsonify\\nfrom app.utils.db import get_sys_profile_by_phone\\nfrom datetime import datetime\\n\\n# 创建登录蓝图\\nlogin_bp = Blueprint('login', __name__)\\n\\n@login_bp.route('/login', methods=['POST'])\\ndef login():\\n    \\\"\\\"\\\"基于 phone 的简单登录接口 (密码不加密，连接 Supabase)\\\"\\\"\\\"\\n    try:\\n        # 尝试获取 JSON 数据，如果 Content-Type 不是 application/json 也会尝试解析\\n        data = request.get_json(silent=True)\\n        \\n        # 如果不是 JSON 或者没有提供数据，尝试从表单获取\\n        if data is None:\\n            data = request.form\\n            \\n        # 如果依然没有数据，返回错误\\n        if not data:\\n            return jsonify({\\n                \\\"code\\\"