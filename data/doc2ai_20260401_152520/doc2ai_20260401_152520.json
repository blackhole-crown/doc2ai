        "raw": "* {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n}\n\nbody {\n    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;\n    background-color: #f5f7fa;\n}\n\n.el-header {\n    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n    color: white;\n    padding: 0;\n    box-shadow: 0 2px 8px rgba(0,0,0,0.1);\n}\n\n.header-container {\n    max-width: 1400px;\n    margin: 0 auto;\n    padding: 20px 30px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n}\n\n.header-container h1 {\n    font-size: 28px;\n    font-weight: 600;\n    margin: 0;\n}\n\n.header-container h1 i {\n    margin-right: 12px;\n}\n\n.subtitle {\n    font-size: 14px;\n    font-weight: normal;\n    margin-left: 15px;\n    opacity: 0.9;\n}\n\n.header-actions .el-button {\n    color: white;\n    font-size: 14px;\n}\n\n.header-actions .el-button:hover {\n    opacity: 0.8;\n}\n\n.el-main {\n    max-width: 1400px;\n    margin: 0 auto;\n    padding: 30px;\n}\n\n.input-card, .preview-card, .result-card {\n    border-radius: 12px;\n    box-shadow: 0 2px 12px rgba(0,0,0,0.08);\n}\n\n.input-card .el-card__header,\n.preview-card .el-card__header,\n.result-card .el-card__header {\n    background: #fafbfc;\n    border-bottom: 1px solid #e8eaed;\n    font-weight: 600;\n}\n\n.upload-area {\n    margin: 20px 0;\n}\n\n.path-tips {\n    font-size: 12px;\n    color: #909399;\n    margin-top: 8px;\n}\n\n.path-tips i {\n    margin-right: 4px;\n}\n\n.action-buttons {\n    margin-top: 20px;\n    display: flex;\n    gap: 12px;\n}\n\n.preview-content {\n    max-height: 500px;\n    overflow-y: auto;\n}\n\n.preview-placeholder {\n    text-align: center;\n    padding: 60px 20px;\n    color: #909399;\n}\n\n.preview-placeholder i {\n    font-size: 64px;\n    margin-bottom: 20px;\n}\n\n.preview-placeholder p {\n    margin: 8px 0;\n}\n\n.preview-placeholder .tip {\n    font-size: 12px;\n    color: #c0c4cc;\n}\n\n.custom-tree-node {\n    flex: 1;\n    display: flex;\n    align-items: center;\n    font-size: 14px;\n}\n\n.custom-tree-node i {\n    margin-right: 8px;\n    color: #67c23a;\n}\n\n.custom-tree-node .node-name {\n    flex: 1;\n}\n\n.custom-tree-node .node-size {\n    font-size: 12px;\n    color: #909399;\n}\n\n.result-card {\n    margin-top: 30px;\n}\n\n.stats-content {\n    padding: 10px 0;\n}\n\n.stat-card {\n    text-align: center;\n    padding: 20px;\n    background: #f5f7fa;\n    border-radius: 8px;\n}\n\n.stat-number {\n    font-size: 32px;\n    font-weight: bold;\n    color: #409eff;\n}\n\n.stat-label {\n    font-size: 14px;\n    color: #606266;\n    margin-top: 8px;\n}\n\n.file-types {\n    margin: 20px 0;\n}\n\n.file-types h4 {\n    margin-bottom: 12px;\n    color: #606266;\n}\n\n.type-tags {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 8px;\n}\n\n.project-tree {\n    margin-top: 20px;\n}\n\n.json-content {\n    max-height: 500px;\n    overflow: auto;\n    background: #1e1e1e;\n    border-radius: 8px;\n    padding: 15px;\n}\n\n.json-content pre {\n    margin: 0;\n    color: #d4d4d4;\n    font-family: 'Monaco', 'Menlo', 'Courier New', monospace;\n    font-size: 12px;\n    white-space: pre-wrap;\n    word-wrap: break-word;\n}\n\n.upload-status {\n    margin-top: 15px;\n    padding: 15px;\n    background: #f5f7fa;\n    border-radius: 8px;\n}\n\n.status-message {\n    margin-top: 8px;\n    font-size: 12px;\n    color: #909399;\n    text-align: center;\n}\n\n.help-content h4 {\n    margin: 15px 0 8px;\n    color: #409eff;\n}\n\n.help-content ul {\n    margin: 8px 0 0 20px;\n}\n\n.help-content code {\n    background: #f5f7fa;\n    padding: 2px 6px;\n    border-radius: 4px;\n    font-family: monospace;\n    font-size: 12px;\n}\n\n/* 响应式 */\n@media (max-width: 768px) {\n    .el-main {\n        padding: 15px;\n    }\n    \n    .header-container {\n        padding: 15px 20px;\n    }\n    \n    .header-container h1 {\n        font-size: 20px;\n    }\n    \n    .subtitle {\n        display: none;\n    }\n}",
