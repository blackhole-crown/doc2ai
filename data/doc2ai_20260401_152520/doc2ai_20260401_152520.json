txt(file_path, encoding)\\n    \\n    @staticmethod\\n    def read_docx(file_path):\\n        \\\"\\\"\\\"读取 DOCX 文件 - 完整读取所有内容\\\"\\\"\\\"\\n        try:\\n            doc = Document(file_path)\\n            text_parts = []\\n            \\n            # 1. 提取所有段落（保留空行作为分隔）\\n            for para in doc.paragraphs:\\n                # 即使段落为空也添加，用于保持格式\\n                text_parts.append(para.text)\\n            \\n            # 2. 提取所有表格\\n            if doc.tables:\\n                text_parts.append(\\\"\\\\n\\\" + \\\"=\\\"*50)\\n                text_parts.append(\\\"表格内容：\\\")\\n                text_parts.append(\\\"=\\\"*50)\\n                \\n                for table_idx, table in enumerate(doc.tables, 1):\\n                    text_parts.append(f\\\"\\\\n表格 {table_idx}:\\\")\\n                    for row_idx, row in enumerate(table.rows):\\n                        row_text = []\\n                        for cell in row.cells:\\n                            cell_text = cell.text.strip()\\n                            if cell_text:\\n                                row_text.append(cell_text)\\n                        if row_text:\\n                            text_parts.append(f\\\"  第{row_idx+1}行: {' | '.join(row_text)}\\\")\\n                    text_parts.append(\\\"\\\")\\n            \\n            # 3. 提取页眉\\n            for section in doc.sections:\\n                if section.header:\\n                    header_text = []\\n                    for para in section.header.paragraphs:\\n                        if para.text.strip():\\n                            header_text.append(para.text)\\n                    if header_text:\\n                        text_parts.append(f\\\"\\\\n[页眉] {' '.join(header_text)}\\\")\\n            \\n            # 4. 提取页脚\\n            for section in doc.sections:\\n                if section.footer:\\n                    footer_text = []\\n                    for para in section.footer.paragraphs:\\n                        if para.text.strip():\\n                            footer_text.append(para.text)\\n                    if footer_text:\\n                        text_parts.append(f\\\"[页脚] {' '.join(footer_text)}\\\")\\n            \\n            # 用换行符连接所有内容\\n            full_text = '\\\\n'.join(text_parts)\\n            \\n            # 调试信息：打印提取的字符数\\n            print(f\\\"DOCX 提取完成，共 {len(full_text)} 字符\\\")\\n            \\n            return full_text\\n            \\n        except Exception as e:\\n            print(f\\\"读取 DOCX 失败: {e}\\\")\\n            import traceback\\n            traceback.print_exc()\\n            return None\\n    \\n    @staticmethod\\n    def read_pdf(file_path):\\n        \\\"\\\"\\\"读取 PDF 文件\\\"\\\"\\\"\\n        try:\\n            doc = fitz.open(file_path)\\n            text_parts = []\\n            \\n            for page_num, page in enumerate(doc, 1):\\n                page_text = page.get_text()\\n                if page_text.strip():\\n                    text_parts.append(f\\\"=== 第 {page_num} 页 ===\\\")\\n                    text_parts.append(page_text)\\n                    text_parts.append(\\\"\\\")\\n            \\n            doc.close()\\n            full_text = '\\\\n'.join(text_parts)\\n            print(f\\\"PDF 提取完成，共 {len(full_text)} 字符，{len(doc)} 页\\\")\\n            \\n            return full_text\\n            \\n        except Exception as e:\\n            print(f\\\"读取 PDF 失败: {e}\\\")\\n            import traceback\\n            traceback.print_exc()\\n            return None\\n    \\n    @staticmethod\\n    def read_auto(file_path):\\n        \\\"\\\"\\\"自动识别文件类型并读取\\\"\\\"\\\"\\n        ext = os.path.splitext(file_path)[1].lower()\\n        \\n        if ext == '.txt':\\n            return FileReader.read_txt(file_path)\\n        elif ext == '.md' or ext == '.markdown':  # 添加对 .md 文件的支持\\n            return FileReader.read_md(file_path)\\n        elif ext == '.docx':\\n            return FileReader.read_docx(file_path)\\n        elif ext == '.pdf':\\n            return FileReader.read_pdf(file_path)\\n        else:\\n            print(f\\\"不支持的文件类型: {ext}\\\")\\n            return None\\n    \\n    @staticmethod\\n    def get_next_id(jsonl_path):\\n        \\\"\\\"\\\"获取下一个可用的 ID\\\"\\\"\\\"\\n        if not os.path.exists(jsonl_path):\\n            return 1\\n        \\n        try:\\n            with open(jsonl_path, 'r', encoding='utf-8') as f:\\n                max_id = 0\\n                for line in f:\\n                    if line.strip():\\n                        data = json.loads(line)\\n                        if 'id' in data and isinstance(data['id'], int):\\n                            max_id = max(max_id, data['id'])\\n                return max_id + 1\\n        except:\\n            return 1\\n    \\n    @staticmethod\\n    def save_to_jsonl(file_path, content, jsonl_path='output.jsonl', metadata=None):\\n        \\\"\\\"\\\"\\n        将读取的内容保存到 JSONL 文件\\n        :param file_path: 原始文件路径\\n        :param content: 读取的内容\\n        :param jsonl_path: JSONL 输出文件路径\\n        :param metadata: 额外的元数据（字典）\\n        :return: 生成的 id\\n        \\\"\\\"\\\"\\n        if content is None:\\n            print(f\\\"内容为空，跳过保存: {file_path}\\\")\\n            return None\\n        \\n        # 检查是否已经处理过这个文件\\n        abs_path = os.path.abspath(file_path)\\n        if abs_path in FileReader._processed_files:\\n            print(f\\\"文件已处理过，跳过: {file_path}\\\")\\n            return None\\n        \\n        # 生成 ID\\n        new_id = FileReader.get_next_id(jsonl_path)\\n        \\n        # 获取文件信息\\n        file_stat = os.stat(file_path)\\n        \\n        # 准备数据\\n        data = {\\n            'id': new_id,\\n            'description': content,\\n            'source_file': os.path.basename(file_path),\\n            'file_path': abs_path,\\n            'file_type': os.path.splitext(file_path)[1].lower(),\\n            'file_size': file_stat.st_size,\\n            'create_time': datetime.fromtimestamp(file_stat.st_ctime).isoformat(),\\n            'modify_time': datetime.fromtimestamp(file_stat.st_mtime).isoformat(),\\n            'process_time': datetime.now().isoformat(),\\n            'content_length': len(content)\\n        }\\n        \\n        # 添加额外元数据\\n        if metadata:\\n            data.update(metadata)\\n        \\n        # 追加写入 JSONL 文件\\n        try:\\n            with open(jsonl_path, 'a', encoding='utf-8') as f:\\n                f.write(json.dumps(data, ensure_ascii=False) + '\\\\n')\\n            FileReader._processed_files.add(abs_path)\\n            # print(f\\\"成功保存到 {jsonl_path}，ID: {new_id}，内容长度: {len(content)} 字符\\\")\\n            # print(f\\\"内容预览: {content[:200]}...\\\")\\n            return new_id\\n        except Exception as e:\\n            print(f\\\"保存到 JSONL 失败: {e}\\\")\\n            return None\\n    \\n    @staticmethod\\n    def process_and_save(file_path, jsonl_path='output.jsonl', metadata=None):\\n        \\\"\\\"\\\"\\n        读取文件并自动保存到 JSONL\\n        :param file_path: 要处理的文件路径\\n        :param jsonl_path: JSONL 输出文件路径\\n        :param metadata: 额外的元数据\\n        :return: 生成的 id\\n        \\\"\\\"\\\"\\n        if not os.path.exists(file_path):\\n            print(f\\\"文件不存在: {file_path}\\\")\\n            return None\\n        \\n        print(f\\\"正在处理文件: {file_path}\\\")\\n        \\n        # 读取文件内容\\n        content = FileReader.read_auto(file_path)\\n        \\n        if content:\\n            # 保存到 JSONL\\n            return FileReader.save_to_jsonl(file_path, content, jsonl_path, metadata)\\n        else:\\n            print(f\\\"读取文件失败: {file_path}\\\")\\n            return None\\n    \\n    @staticmethod\\n    def read_jsonl(jsonl_path):\\n        \\\"\\\"\\\"读取 JSONL 文件的所有记录\\\"\\\"\\\"\\n        records = []\\n        if os.path.exists(jsonl_path):\\n            with open(jsonl_path, 'r', encoding='utf-8') as f:\\n                for line in f:\\n                    if line.strip():\\n                        records.append(json.loads(line))\\n        return records\\n    \\n    @staticmethod\\n    def process_folder(folder_path, jsonl_file, file_extensions=None):\\n        \\\"\\\"\\\"批量处理文件夹中的文件\\\"\\\"\\\"\\n        if file_extensions is None:\\n            file_extensions = ['.txt', '.md', '.docx', '.pdf']  # 添加 .md 支持\\n        \\n        processed_count = 0\\n        reader = FileReader()  # 创建实例来调用方法\\n        \\n        for root, dirs, files in os.walk(folder_path):\\n            for file in files:\\n                ext = os.path.splitext(file)[1].lower()\\n                if ext in file_extensions:\\n                    file_path = os.path.join(root, file)\\n                    metadata = {\\n                        'category': '批量导入',\\n                        'folder': folder_path,\\n                        'import_time': datetime.now().isoformat()\\n                    }\\n                    if reader.process_and_save(file_path, jsonl_file, metadata):\\n                        processed_count += 1\\n        \\n        print(f\\\"批量处理完成，共处理 {processed_count} 个文件\\\")\\n        return processed_count\\n    \\n    @staticmethod\\n    def get_by_id(jsonl_path, target_id):\\n        \\\"\\\"\\\"根据 ID 获取记录\\\"\\\"\\\"\\n        if not os.path.exists(jsonl_path):\\n            print(f\\\"文件不存在: {jsonl_path}\\\")\\n            return None\\n            \\n        with open(jsonl_path, 'r', encoding='utf-8') as f:\\n            for line in f:\\n                if line.strip():\\n                    data = json.loads(line)\\n                    if data['id'] == target_id:\\n                        return data\\n        return None\\n\\n# 使用示例\\ndef main():\\n    reader = FileReader()\\n    jsonl_file = 'output.jsonl'\\n    metadata = {}\\n    \\n    # 可以选择要处理的文件路径\\n    # 取消注释你想要处理的文件\\n    \\n    # 处理 PDF 文件\\n    # file_path = r\\\"C:\\\\Users\\\\Administrator\\\\Desktop\\\\大三下\\\\竞赛\\\\软著产权.pdf\\\"\\n    \\n    # 处理 DOCX 文件\\n    fil