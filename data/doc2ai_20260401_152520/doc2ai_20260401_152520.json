_FILE = \\\"事业单位招聘信息_完整数据.jsonl\\\"\\ntitle_duplicate_set = set()  # 标题查重集合\\ncurrent_auto_id = 1          # 自增ID计数器（核心：从1开始）\\n\\ndef load_existing_data():\\n    \\\"\\\"\\\"加载历史数据：恢复标题查重集合 + 初始化自增ID\\\"\\\"\\\"\\n    global current_auto_id, title_duplicate_set\\n    if os.path.exists(JSONL_FILE):\\n        try:\\n            max_id = 0\\n            with open(JSONL_FILE, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n                for line in f:\\n                    line = line.strip()\\n                    if line:\\n                        data = json.loads(line)\\n                        # 1. 记录所有标题（查重）\\n                        if \\\"title\\\" in data:\\n                            title_duplicate_set.add(data[\\\"title\\\"])\\n                        # 2. 找到最大ID，作为下一个ID的起始值\\n                        if \\\"id\\\" in data and isinstance(data[\\\"id\\\"], int):\\n                            if data[\\\"id\\\"] > max_id:\\n                                max_id = data[\\\"id\\\"]\\n            # 自增ID从最大ID+1开始\\n            current_auto_id = max_id + 1\\n            print(f\\\"✅ 加载历史数据完成\\\")\\n            print(f\\\"   - 历史不重复标题数：{len(title_duplicate_set)}\\\")\\n            print(f\\\"   - 下一个自增ID：{current_auto_id}\\\")\\n        except Exception as e:\\n            print(f\\\"⚠️ 加载历史数据失败：{e}，将从ID=1开始重新爬取\\\")\\n            current_auto_id = 1\\n            title_duplicate_set = set()\\n    else:\\n        print(f\\\"ℹ️ 无历史数据，从ID=1开始爬取\\\")\\n\\ndef extract_page_data(html_text, page_num):\\n    \\\"\\\"\\\"提取单页数据：自增ID + 标题查重\\\"\\\"\\\"\\n    global current_auto_id\\n    html = etree.HTML(html_text)\\n    \\n    all_a = html.xpath(f\\\"//a[contains(@href, '{LINK_FEATURE}') and @class='aa_lan_2']\\\")\\n    all_dates = html.xpath(\\\"//td[@class='zhaopin-title']/following-sibling::td[1]/text()\\\")\\n    \\n    print(f\\\"\\\\n🔍 第{page_num}页：匹配到 {len(all_a)} 个链接，{len(all_dates)} 个时间\\\")\\n    page_new_data = []\\n    page_count = 0\\n    \\n    for i in range(min(len(all_a), len(all_dates))):\\n        a_node = all_a[i]\\n        title = a_node.text.strip() if a_node.text else f\\\"无标题_{page_num}_{i+1}\\\"\\n        link = a_node.get(\\\"href\\\", \\\"\\\").strip()\\n        publish_time = all_dates[i].strip()\\n        \\n        # 1. 标题查重：跳过重复内容\\n        if title in title_duplicate_set:\\n            print(f\\\"⏭️ 跳过重复标题（ID={current_auto_id}）：{title[:30]}...\\\")\\n            continue\\n        \\n        # 2. 数据校验\\n        if title and link and len(publish_time) == 10:\\n            news_item = {\\n                \\\"id\\\": current_auto_id,  # 自增ID（核心修改）\\n                \\\"page\\\": page_num,       # 保留页码（可选，便于溯源）\\n                \\\"title\\\": title,\\n                \\\"link\\\": link,\\n                \\\"publish_time\\\": publish_time\\n            }\\n            page_new_data.append(news_item)\\n            title_duplicate_set.add(title)\\n            current_auto_id += 1  # ID自增\\n            page_count += 1\\n    \\n    print(f\\\"✅ 第{page_num}页：新增 {page_count} 条不重复数据（当前最大ID={current_auto_id-1}）\\\")\\n    return page_new_data, len(all_a) > 0\\n\\ndef crawl_dynamic_pages():\\n    \\\"\\\"\\\"模拟JS翻页爬取所有数据\\\"\\\"\\\"\\n    session = requests.Session()\\n    all_new_data = []\\n    current_page = 1\\n    has_next_page = True\\n    \\n    # 爬取第一页\\n    print(f\\\"\\\\n🚀 开始爬取第 {current_page} 页（初始页）\\\")\\n    response = session.get(BASE_URL, headers=HEADERS, timeout=15, verify=False)\\n    response.encoding = \\\"utf-8\\\"\\n    page_data, has_data = extract_page_data(response.text, current_page)\\n    all_new_data.extend(page_data)\\n    \\n    # 循环爬取下一页\\n    while has_next_page and has_data:\\n        current_page += 1\\n        print(f\\\"\\\\n📝 模拟点击下一页，爬取第 {current_page} 页\\\")\\n        next_page_url = f\\\"{BASE_URL}?p={current_page}&pageSize=15\\\"\\n        \\n        try:\\n            time.sleep(2)  # 模拟人类翻页延迟\\n            response = session.get(next_page_url, headers=HEADERS, timeout=15, verify=False)\\n            response.raise_for_status()\\n            response.encoding = \\\"utf-8\\\"\\n            \\n            page_data, has_data = extract_page_data(response.text, current_page)\\n            all_new_data.extend(page_data)\\n            \\n            # 无新数据则停止翻页\\n            if len(page_data) == 0:\\n                has_next_page = False\\n                print(f\\\"📌 第{current_page}页无新数据，已爬取到最后一页\\\")\\n                \\n            time.sleep(0.5)  # 随机小延迟\\n            \\n        except Exception as e:\\n            print(f\\\"❌ 第{current_page}页爬取失败：{str(e)[:100]}\\\")\\n            time.sleep(3)\\n            try:\\n                response = session.get(next_page_url, headers=HEADERS, timeout=15, verify=False)\\n                page_data, has_data = extract_page_data(response.text, current_page)\\n                all_new_data.extend(page_data)\\n            except:\\n                has_next_page = False\\n                print(f\\\"📌 第{current_page}页重试失败，停止翻页\\\")\\n    \\n    return all_new_data\\n\\ndef save_to_jsonl(new_data):\\n    \\\"\\\"\\\"保存数据：合并历史+新增，保证ID连续且不重复\\\"\\\"\\\"\\n    # 1. 读取历史数据\\n    history_data = []\\n    if os.path.exists(JSONL_FILE):\\n        try:\\n            with open(JSONL_FILE, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n                for line in f:\\n                    line = line.strip()\\n                    if line:\\n                        history_data.append(json.loads(line))\\n        except Exception as e:\\n            print(f\\\"⚠️ 读取历史数据失败：{e}，将覆盖原有文件\\\")\\n            history_data = []\\n    \\n    # 2. 合并数据（历史+新增）\\n    all_data = history_data + new_data\\n    \\n    # 3. 最终去重（按标题）+ 按ID排序\\n    unique_data = []\\n    unique_titles = set()\\n    for item in all_data:\\n        if item[\\\"title\\\"] not in unique_titles:\\n            unique_titles.add(item[\\\"title\\\"])\\n            unique_data.append(item)\\n    # 按ID升序排列，保证顺序一致\\n    unique_data.sort(key=lambda x: x[\\\"id\\\"])\\n    \\n    # 4. 写入文件\\n    try:\\n        with open(JSONL_FILE, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n            for item in unique_data:\\n                json_line = json.dumps(item, ensure_ascii=False)\\n                f.write(json_line + \\\"\\\\n\\\")\\n        \\n        print(f\\\"\\\\n📄 JSONL文件保存成功！\\\")\\n        print(f\\\"📁 文件路径：{os.path.abspath(JSONL_FILE)}\\\")\\n        print(f\\\"📈 总计数据：{len(unique_data)} 条（ID范围：1~{unique_data[-1]['id']}）\\\")\\n        print(f\\\"🔍 本次新增：{len(new_data)} 条\\\")\\n    except PermissionError:\\n        print(f\\\"\\\\n❌ 权限不足！请关闭打开的 {JSONL_FILE} 文件后重试\\\")\\n    except Exception as e:\\n        print(f\\\"\\\\n❌ 保存失败：{str(e)}\\\")\\n\\nif __name__ == \\\"__main__\\\":\\n    print(\\\"🚀 开始爬取事业单位招聘信息（自增ID+全局查重+动态翻页）\\\")\\n    # 步骤1：加载历史数据，初始化自增ID\\n    load_existing_data()\\n    # 步骤2：动态翻页爬取新数据\\n    new_data = crawl_dynamic_pages()\\n    # 步骤3：保存数据（合并历史+新增）\\n    save_to_jsonl(new_data)\\n    print(\\\"\\\\n🎉 爬取任务全部完成！\\\")\",\n        \"truncated\": false\n      },\n      \"metadata\": {\n        \"encoding\": \"utf-8\",\n        \"line_count\": 195,\n        \"displayed_lines\": 195,\n        \"truncated\": false,\n        \"size\": 8183\n      }\n    },\n    {\n      \"file_info\": {\n        \"path\": \"crawler.py\",\n        \"name\": \"crawler.py\",\n        \"extension\": \".py\",\n        \"size_bytes\": 9214,\n        \"size_human\": \"9.00 KB\",\n        \"modified\": \"2026-03-17T20:36:35.022594\"\n      },\n      \"content\": {\n        \"raw\": \"import json\\nimport time\\nimport re\\nfrom selenium import webdriver\\nfrom selenium.webdriver.common.by import By\\nfrom selenium.webdriver.support.ui import WebDriverWait\\nfrom selenium.webdriver.support import expected_conditions as EC\\nfrom selenium.webdriver.edge.options import Options\\nfrom selenium.webdriver.edge.service import Service\\nfrom selenium.common.exceptions import TimeoutException, NoSuchElementException\\n\\n# ========== 配置区 ==========\\nEDGE_DRIVER_PATH = r\\\"D:\\\\Mine\\\\Download\\\\edge download\\\\edgedriver_win64\\\\msedgedriver.exe\\\" # 请确认你的路径\\nTARGET_URL = \\\"https://xiaoyuan.zhaopin.com/search/index?refcode=4404&cateType=major\\\"\\nOUTPUT_FILE = \\\"jobs_page_1.jsonl\\\"\\n# ===========================\\n\\ndef init_driver():\\n    \\\"\\\"\\\"初始化Edge浏览器（无头模式，隐藏窗口）\\\"\\\"\\\"\\n    edge_options = Options()\\n    edge_options.add_argument(\\\"--headless=new\\\")\\n    edge_options.add_argument(\\\"--disable-blink-features=AutomationControlled\\\")\\n    edge_options.add_experimental_option(\\\"excludeSwitches\\\", [\\\"enable-automation\\\"])\\n    edge_options.add_experimental_option(\\\"useAutomationExtension\\\", False)\\n    edge_options.add_argument(\\\"--window-size=1920,1080\\\")\\n    edge_options.add_argument(\\\"--disable-gpu\\\")\\n    edge_options.add_argument(\\\"--no-sandbox\\\")\\n    edge_options.add_argument(\\\"--log-level=3\\\")\\n    \\n    service = Service(EDGE_DRIVER_PATH)\\n    driver = webdriver.Edge(service=service, options=edge_options)\\n    # 移除webdriver特征\\n    driver.execute_script(\\\"Object.defineProperty(navigator, 'webdriver', {get: () => undefined})\\\")\\n    driver.implicitly_wait(10)\\n    return driver\\n\\ndef parse_list_item(item_element):\\n    \\\"\\\"\\\"从列表页的单个职位卡片中提取数据\\\"\\\"\\\"\\n    try:\\n        # 1. 岗位名称\\n        job_name = item_element.find_element(By.CSS_SELECTOR, \\\".position-card__job-name\\\").text.strip()\\n        \\n        # 2. 地址（需要从类似「郑州·中原」的文本中提取）\\n        city_text = item_element.find_element(By.CSS_SELECTOR, \\\".position-card__city-name\\\").text.strip()\\n        # 使用正则提取城市名，去掉「·」后面的区域\\n        city_match = re.search(r'[「]?(.*?)[·」]', city_text)\\n        address = city_match.group(1) if city_match else city_text.replace('「', '').replace('」', '')\\n        \\n        # 3. 薪资范围\\n        salary = item_element.find_element(By.CSS_SELECTOR, \\\".position-card__salary\\\").text.strip()\\n        \\n        # 4. 公司名称\\n        company = item_element.find_element(By.CSS_SELECTOR, \\\".position-card__company__name\\\").text.strip()\\n        \\n        # 5. 所属行业、公司规模、公司类型（在tabs里）\\n        tabs = item_element.find_elements(By.CSS_SELECTOR, \\\".position-card__company__tabs-item\\\")\\n        industry = tabs[0].text.strip() if len(tabs) > 0 else \\\"\\\"\\n        company_size = tabs[1].text.strip() if len(tabs) > 1 else \\\"\\\"\\n        company_type = tabs[2].text.strip() if len(tabs) > 2 else \\\"\\\"\\n        \\n        # 6. 岗位编码（从data属性或链接中提取）\\n        # 优先从外层div的data属性获取\\n        job_code = item_element.get_attribute(\\\"data-sensors-exposure-option\\\")\\n        if job_code:\\n            try:\\n                import json as json_lib\\n                opt = json_lib.loads(job_code.replace('&quot;', '\\\"'))\\n                job_code = opt.get(\\\"properties\\\", {}).get(\\\"jdno\\\", \\\"\\\")\\n            except:\\n                job_code = \\\"\\\"\\n        \\n        # 7. 岗位来源地址（详情页链接）\\n        # 智联的详情页链接可以通过岗位编码拼接，或者从卡片上的某个属性获取\\n        # 这里使用拼接方式，因为链接结构固定\\n        if job_code:\\n            detail_url = f\\\"https://xiaoyuan.zhaopin.com/job/{job_code}?refcode=4430&srccode=443001&jobSourceType=2\\\"\\n        else:\\n            # 如果没拿到编码，暂时留空\\n            detail_url = \\\"\\\"\\n        \\n        return {\\n            \\\"岗位名称\\\": job_name,\\n            \\\"地址\\\": address,\\n            \\\"薪资范围\\\": salary,\\n            \\\"公司名称\\\": company,\\n            \\\"所属行业\\\": industry,\\n            \\\"公司规模\\\": company_size,\\n            \\\"公司类型\\\": company_type,\\n            \\\"岗位编码\\\": job_code,\\n            \\\"岗位详情\\\": \\\"\\\",  # 待详情页补充\\n            \\\"更新日期\\\": \\\"\\\",  # 待详情页补充（如果列表页没有）\\n            \\\"公司详情\\\": \\\"\\\",  # 待详情页补充\\n            \\\"岗位来源地址\\\": detail_url\\n        }\\n    except Exception as e:\\n        print(f\\\"解析列表项时出错: {e}\\\")\\n        return None\\n\\ndef parse_detail_page(driver, detail_url):\\n    \\\"\\\"\\\"访问详情页，补充岗位详情和公司详情\\\"\\\"\\\"\\n    if not detail_url:\\n        return \\\"\\\", \\\"\\\", \\\"\\\"\\n    \\n    try:\\n        driver.get(detail_url)\\n        # 等待详情页的核心内容加载\\n        WebDriverWait(driver, 10).until(\\n            EC.presence_of_element_located((By.CSS_SELECTOR, \\\".job-info__desc\\\"))\\n        )\\n        time.sleep(1)  # 额外等待动态内容\\n        \\n        # 1. 岗位详情\\n        job_desc = \\\"\\\"\\n        try:\\n            desc_elem = driver.find_element(By.CSS_SELECTOR, \\\".job-info__desc\\\")\\n            job_desc = desc_elem.get_attribute(\\\"innerHTML\\\").replace(\\\"<br>\\\", \\\"\\\\n\\\").strip()\\n        except:\\n            pass\\n        \\n        # 2. 更新日期（可能需要从其他位置提取，比如发布时间）\\n        update_date = \\\"\\\"\\n        try:\\n            # 尝试查找发布时间，这里需要根据实际页面结构调整选择器\\n            # 假设在一个class为\\\"job-info__time\\\"的元素里\\n            time_elem = driver.find_element(By.CSS_SELECTOR, \\\".job-info__time\\\")\\n            update_date = time_elem.text.strip()\\n        except:\\n            pass\\n        \\n        # 3. 公司详情（可能需要点击\\\"公司详情\\\"选项卡或查找特定区域）\\n        company_desc = \\\"\\\"\\n        try:\\n            # 尝试查找公司介绍区域\\n            company_elem = driver.find_element(By.CSS_SELECTOR, \\\".company-info__desc\\\")\\n            company_desc = company_elem.get_attribute(\\\"innerHTML\\\").replace(\\\"<br>\\\", \\\"\\\\n\\\").strip()\\n        except:\\n            pass\\n        \\n        return job_desc, update_date, company_desc\\n    except Exception as e:\\n        print(f\\\"解析详情页 {detail_url} 时出错: {e}\\\")\\n        return \\\"\\\", \\\"\\\", \\\"\\\"\\n\\ndef crawl_first_page():\\n    \\\"\\\"\\\"爬取第一页的所有职位数据\\\"\\\"\\\"\\n    driver = init_driver()\\n    all_jobs = []\\n    \\n    try:\\n        print(f\\\"正在访问: {TARGET_URL}\\\")\\n        driver.get(TARGET_URL)\\n        \\n        # 等待职位卡片加载\\n        WebDriverWait(driver, 20).until(\\n            EC.presence_of_element_located((By.CSS_SELECTOR, \\\".position-card\\\"))\\n        )\\n        # 额外等待，确保所有动态内容加载完毕\\n        time.sleep(3)\\n        \\n        # 获取所有职位卡片\\n        job_cards = driver.find_elements(By.CSS_SELECTOR, \\\".position-card\\\")\\n        print(f\\\"找到 {len(job_cards)} 个职位卡片\\\")\\n        \\n        # 先解析列表页数据\\n        for i, card in enumerate(job_cards):\\n            print(f\\\"正在解析第 {i+1} 个职位...\\\")\\n            job_data = parse_list_item(card)\\n            if job_data:\\n                all_jobs.append(job_data)\\n        \\n        # 再逐个访问详情页补充数据（可选，如果需要完整字段）\\n        # 如果第一页数据量不大，可以开启；如果只想快速获取第一页，可以暂时注释掉\\n        print(\\\"\\\\n开始访问详情页补充数据...\\\")\\n        for i, job in enumerate(all_jobs):\\n            if job[\\\"岗位来源地址\\\"]:\\n                print(f\\\"  正在获取第 {i+1} 个职位的详情...\\\")\\n                desc, update, company = parse_detail_page(driver, job[\\\"岗位来源地址\\\"])\\n                job[\\\"岗位详情\\\"] = desc\\n                job[\\\"更新日期\\\"] = update\\n                job[\\\"公司详情\\\"] = company\\n                # 随机暂停，避免请求过快\\n                time.sleep(1)\\n        \\n        print(f\\\"\\\\n✅ 第一页数据爬取完成，共 {len(all_jobs)} 条\\\")\\n        return all_jobs\\n        \\n    except TimeoutException:\\n        print(\\\"❌ 页面加载超时，请检查网络或网站是否正常\\\")\\n        return []\\n    except Exception as e:\\n        print(f\\\"❌ 发生未知错误: {e}\\\")\\n        return []\\n    finally:\\n        driver.quit()\\n\\ndef save_to_jsonl(data, filename):\\n    \\\"\\\"\\\"保存为JSONL格式\\\"\\\"\\\"\\n    with open(filename, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n        for item in data:\\n            f.write(json.dumps(item, ensure_ascii=False) + \\\"\\\\n\\\")\\n    print(f\\\"📁 数据已保存到: {filename}\\\")\\n\\nif __name__ == \\\"__main__\\\":\\n    print(\\\"=\\\"*50)\\n    print(\\\"智联招聘校园招聘爬虫（第一页）\\\")\\n    print(\\\"=\\\"*50)\\n    \\n    # 爬取第一页\\n    jobs_data = crawl_first_page()\\n    \\n    # 保存结果\\n    if jobs_data:\\n        save_to_jsonl(jobs_data, OUTPUT_FILE)\\n        # 打印第一条作为示例\\n        print(\\\"\\\\n示例数据（第一条）：\\\")\\n        print(json.dumps(jobs_data[0], ensure_ascii=False, indent=2))\\n    else:\\n        print(\\\"没有获取到任何数据\\\")\",\n        \"truncated\": false\n      },\n      \"metadata\": {\n        \"encoding\": \"utf-8\",\n        \"line_count\": 218,\n        \"displayed_lines\": 218,\n        \"truncated\": false,\n        \"size\": 9214\n      }\n    },\n    {\n      \"file_info\": {\n        \"path\": \"crawler_news.py\",\n        \"name\": \"crawler_news.py\",\n        \"extension\": \".py\",\n        \"size_bytes\": 12005,\n        \"size_human\": \"11.72 KB\",\n        \"modified\": \"2026-03-26T22:58:52.399850\"\n      },\n      \"content\": {\n        \"raw\": \"import json\\nimport os\\nfrom selenium import webdriver\\nfrom selenium.webdriver.edge.service import Service\\nfrom selenium.webdriver.edge.options import Options\\nfrom selenium.webdriver.common.by import By\\nfrom selenium.webdriver.support.ui import WebDriverWait\\nfrom selenium.webdriver.support import expected_conditions as EC\\nimport time\\nimport re\\n\\n# ========== 精准配置（针对新页面） ==========\\nEDGE_DRIVER_PATH = r\\\"D:\\\\Mine\\\\Download\\\\edge download\\\\edgedriver_win64\\\\msedgedriver.exe\\\"\\nTARGET_URL = \\\"http://job.mohrss.gov.cn/rdzx/index.jhtml\\\"\\nJSONL_FILE = \\\"../data/Hot_News.jsonl\\\"  # 改用不同的文件名\\nHEADLESS_MODE = False  # 调试时先用有头模式，False=显示窗口，True=无头模式\\n# ================================================\\n\\n# 全局变量（自增ID+查重）\\ntitle_duplicate_set = set()\\ncurrent_auto_id = 1\\n\\ndef load_existing_data():\\n    \\\"\\\"\\\"加载历史数据，初始化自增ID和查重集合\\\"\\\"\\\"\\n    global current_auto_id, title_duplicate_set\\n    if os.path.exists(JSONL_FILE):\\n        try:\\n            max_id = 0\\n            with open(JSONL_FILE, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n                for line in f:\\n                    line = line.strip()\\n                    if line:\\n                        data = json.loads(line)\\n                        if \\\"title\\\" in data:\\n                            title_duplicate_set.add(data[\\\"title\\\"])\\n                        if \\\"id\\\" in data and isinstance(data[\\\"id\\\"], int):\\n                            max_id = max(max_id, data[\\\"id\\\"])\\n            current_auto_id = max_id + 1\\n            print(f\\\"✅ 加载历史数据完成\\\")\\n            print(f\\\"   - 历史不重复标题数：{len(title_duplicate_set)}\\\")\\n            print(f\\\"   - 下一个自增ID：{current_auto_id}\\\")\\n        except Exception as e:\\n            print(f\\\"⚠️ 加载历史数据失败：{e}，将从ID=1重新开始\\\")\\n            current_auto_id = 1\\n            title_duplicate_set = set()\\n    else:\\n        print(f\\\"ℹ️ 无历史数据，ID从1开始爬取\\\")\\n\\ndef init_edge_driver():\\n    \\\"\\\"\\\"初始化Edge浏览器（可选无头模式）\\\"\\\"\\\"\\n    edge_options = Options()\\n    \\n    if HEADLESS_MODE:\\n        # 无头模式配置\\n        edge_options.add_argument(\\\"--headless=new\\\")\\n        edge_options.add_argument(\\\"--disable-gpu\\\")\\n        edge_options.add_argument(\\\"--window-size=1920,1080\\\")\\n        edge_options.add_argument(\\\"--no-sandbox\\\")\\n    else:\\n        # 有头模式（调试用）\\n        edge_options.add_argument(\\\"--start-maximized\\\")\\n        edge_options.add_argument(\\\"--window-size=1920,1080\\\")\\n    \\n    # 通用配置\\n    edge_options.add_argument(\\\"--disable-blink-features=AutomationControlled\\\")\\n    edge_options.add_experimental_option(\\\"excludeSwitches\\\", [\\\"enable-automation\\\"])\\n    edge_options.add_experimental_option(\\\"useAutomationExtension\\\", False)\\n    edge_options.add_argument(\\\"--log-level=3\\\")\\n    \\n    # 初始化驱动\\n    service = Service(EDGE_DRIVER_PATH)\\n    driver = webdriver.Edge(service=service, options=edge_options)\\n    driver.execute_script(\\\"Object.defineProperty(navigator, 'webdriver', {get: () => undefined})\\\")\\n    driver.implicitly_wait(10)\\n    return driver\\n\\ndef extract_news_from_page(driver, page_url=None, page_num=1):\\n    \\\"\\\"\\\"从当前页面提取所有新闻数据\\\"\\\"\\\"\\n    global current_auto_id\\n    page_new_data = []\\n    \\n    if page_url:\\n        driver.get(page_url)\\n        time.sleep(2)\\n    \\n    # 等待页面加载完成\\n    WebDriverWait(driver, 15).until(\\n        EC.presence_of_element_located((By.CLASS_NAME, \\\"blue-light\\\"))\\n    )\\n    time.sleep(1)\\n    \\n    # 提取所有class=\\\"blue-light\\\"的a标签\\n    news_links = driver.find_elements(By.CSS_SELECTOR, \\\"a.blue-light\\\")\\n    \\n    print(f\\\"\\\\n🔍 第{page_num}页：找到 {len(news_links)} 条新闻链接\\\")\\n    \\n    for i, link_element in enumerate(news_links):\\n        try:\\n            # 提取标题和链接\\n            title = link_element.text.strip()\\n            link = link_element.get_attribute(\\\"href\\\").strip()\\n            \\n            # 过滤无效数据\\n            if not title or not link:\\n                continue\\n            \\n            # 标题查重\\n            if title in title_duplicate_set:\\n                print(f\\\"⏭️ 跳过重复标题：{title[:30]}...\\\")\\n                continue\\n            \\n            # 尝试提取发布时间（可能在父元素或相邻元素中）\\n            publish_time = extract_publish_time(link_element)\\n            \\n            # 组装数据\\n            news_item = {\\n                \\\"id\\\": current_auto_id,\\n                \\\"page\\\": page_num,\\n                \\\"title\\\": title,\\n                \\\"link\\\": link,\\n                \\\"publish_time\\\": publish_time,\\n                \\\"source\\\": \\\"人社部热点资讯\\\"\\n            }\\n            page_new_data.append(news_item)\\n            title_duplicate_set.add(title)\\n            print(f\\\"✅ 第{page_num}页第{i+1}条：{title[:40]}... ({publish_time})\\\")\\n            current_auto_id += 1\\n            \\n        except Exception as e:\\n            print(f\\\"⚠️ 第{page_num}页第{i+1}条数据提取失败：{str(e)[:60]}\\\")\\n            continue\\n    \\n    print(f\\\"📊 第{page_num}页：新增 {len(page_new_data)} 条不重复数据\\\")\\n    return page_new_data\\n\\ndef extract_publish_time(element):\\n    \\\"\\\"\\\"提取发布时间（尝试多种策略）\\\"\\\"\\\"\\n    try:\\n        # 策略1：查找父元素中的时间标签\\n        parent = element.find_element(By.XPATH, \\\"..\\\")\\n        time_elements = parent.find_elements(By.CSS_SELECTOR, \\\"span.time, span.date, .date, .time\\\")\\n        if time_elements:\\n            time_text = time_elements[0].text.strip()\\n            if time_text:\\n                # 提取日期格式（如：2025-03-26）\\n                date_match = re.search(r'\\\\d{4}-\\\\d{2}-\\\\d{2}', time_text)\\n                if date_match:\\n                    return date_match.group()\\n        \\n        # 策略2：查找兄弟元素中的时间\\n        sibling_time = element.find_elements(By.XPATH, \\\"following-sibling::*[contains(@class, 'time') or contains(@class, 'date')]\\\")\\n        if sibling_time:\\n            time_text = sibling_time[0].text.strip()\\n            date_match = re.search(r'\\\\d{4}-\\\\d{2}-\\\\d{2}', time_text)\\n            if date_match:\\n                return date_match.group()\\n        \\n        # 策略3：从页面URL或默认值\\n        return \\\"时间未知\\\"\\n        \\n    except Exception as e:\\n        return \\\"时间未知\\\"\\n\\ndef get_pagination_info(driver):\\n    \\\"\\\"\\\"获取分页信息\\\"\\\"\\\"\\n    try:\\n        # 查找分页链接\\n        pagination = driver.find_elements(By.CSS_SELECTOR, \\\".page a, .pagination a\\\")\\n        page_numbers = []\\n        for link in pagination:\\n            text = link.text.strip()\\n            if text.isdigit():\\n                page_numbers.append(int(text))\\n        \\n        if page_numbers:\\n            total_pages = max(page_numbers)\\n            print(f\\\"📊 找到分页信息，总页数：{total_pages}\\\")\\n            return total_pages\\n        \\n        # 查找\\\"下一页\\\"按钮来判断是否有更多页\\n        next_buttons = driver.find_elements(By.LINK_TEXT, \\\"下一页\\\")\\n        if next_buttons:\\n            # 有下一页，但不知道总页数，先返回一个较大的值\\n            return 10\\n        \\n    except Exception as e:\\n        print(f\\\"⚠️ 获取分页信息失败：{e}\\\")\\n    \\n    # 默认只爬取第一页\\n    return 1\\n\\ndef click_next_page(driver, current_page):\\n    \\\"\\\"\\\"点击下一页\\\"\\\"\\\"\\n    try:\\n        # 方法1：查找\\\"下一页\\\"链接\\n        next_links = driver.find_elements(By.LINK_TEXT, \\\"下一页\\\")\\n        if next_links:\\n            driver.execute_script(\\\"arguments[0].click();\\\", next_links[0])\\n            time.sleep(2)\\n            print(f\\\"✅ 点击下一页成功\\\")\\n            return True\\n        \\n        # 方法2：查找带next类的元素\\n        next_buttons = driver.find_elements(By.CSS_SELECTOR, \\\".next, .page-next\\\")\\n        if next_buttons:\\n            driver.execute_script(\\\"arguments[0].click();\\\", next_buttons[0])\\n            time.sleep(2)\\n            return True\\n            \\n    except Exception as e:\\n        print(f\\\"⚠️ 翻页失败：{e}\\\")\\n    \\n    return False\\n\\ndef crawl_all_pages():\\n    \\\"\\\"\\\"爬取所有页面的新闻\\\"\\\"\\\"\\n    driver = init_edge_driver()\\n    all_new_data = []\\n    \\n    try:\\n        # 访问首页\\n        print(f\\\"\\\\n🚀 开始爬取首页：{TARGET_URL}\\\")\\n        driver.get(TARGET_URL)\\n        time.sleep(2)\\n        \\n        # 爬取第一页\\n        page1_data = extract_news_from_page(driver, page_num=1)\\n        all_new_data.extend(page1_data)\\n        \\n        # 获取总页数\\n        total_pages = get_pagination_info(driver)\\n        print(f\\\"\\\\n📊 预计总页数：{total_pages}\\\")\\n        \\n        # 爬取剩余页面\\n        for page_num in range(2, total_pages + 1):\\n            print(f\\\"\\\\n📝 准备爬取第 {page_num} 页\\\")\\n            \\n            if not click_next_page(driver, page_num - 1):\\n                print(f\\\"❌ 无法翻到第 {page_num} 页，停止爬取\\\")\\n                break\\n            \\n            # 等待页面加载\\n            time.sleep(2)\\n            WebDriverWait(driver, 10).until(\\n                EC.presence_of_element_located((By.CLASS_NAME, \\\"blue-light\\\"))\\n            )\\n            \\n            # 提取当前页数据\\n            page_data = extract_news_from_page(driver, page_num=page_num)\\n            all_new_data.extend(page_data)\\n            \\n            # 如果没有新数据，可以提前结束\\n            if len(page_data) == 0:\\n                print(f\\\"⚠️ 第{page_num}页无新数据，可能已到达最后一页\\\")\\n                break\\n    \\n    except Exception as e:\\n        print(f\\\"❌ 爬取过程出错：{e}\\\")\\n    \\n    finally:\\n        driver.quit()\\n    \\n    return all_new_data\\n\\ndef save_to_jsonl(new_data):\\n    \\\"\\\"\\\"保存数据到JSONL文件\\\"\\\"\\\"\\n    # 读取历史数据\\n    history_data = []\\n    if os.path.exists(JSONL_FILE):\\n        try:\\n            with open(JSONL_FILE, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n                history_data = [json.loads(line.strip()) for line in f if line.strip()]\\n        except Exception as e:\\n            print(f\\\"⚠️ 读取历史数据失败：{e}，将覆盖原有文件\\\")\\n            history_data = []\\n    \\n    # 合并数据并去重\\n    all_data = history_data + new_data\\n    unique_data = []\\n    unique_titles = set()\\n    for item in all_data:\\n        if item[\\\"title\\\"] not in unique_titles:\\n            unique_titles.add(item[\\\"title\\\"])\\n            unique_data.append(item)\\n    \\n    # 按ID排序\\n    unique_data.sort(key=lambda x: x[\\\"id\\\"])\\n    \\n    # 写入文件\\n    try:\\n        with open(JSONL_FILE, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n            for item in unique_data:\\n                json_line = json.dumps(item, ensure_ascii=False)\\n                f.write(json_line + \\\"\\\\n\\\")\\n        \\n        print(f\\\"\\\\n📄 JSONL文件保存成功！\\\")\\n        print(f\\\"📁 文件路径：{os.path.abspath(JSONL_FILE)}\\\")\\n        if unique_data:\\n            print(f\\\"📈 总计数据：{len(unique_data)} 条（ID范围：1~{unique_data[-1]['id']}）\\\")\\n        print(f\\\"🔍 本次新增：{len(new_data)} 条不重复数据\\\")\\n    except Exception as e:\\n        print(f\\\"\\\\n❌ 保存失败：{str(e)}\\\")\\n\\nif __name__ == \\\"__main__\\\":\\n    print(\\\"=\\\"*60)\\n    print(\\\"🚀 人社部热点资讯爬取\\\")\\n    print(f\\\"📍 模式：{'有头模式（可见窗口）' if not HEADLESS_MODE else '无头模式（后台运行）'}\\\")\\n    print(\\\"=\\\"*60)\\n    \\n    # 加载历史数据\\n    load_existing_data()\\n    \\n    # 爬取数据\\n    new_data = crawl_all_pages()\\n    \\n    # 保存数据\\n    if new_data:\\n        save_to_jsonl(new_data)\\n    else:\\n        print(\\\"\\\\n⚠️ 未获取到新数据\\\")\\n    \\n    print(\\\"\\\\n🎉 爬取任务完成！\\\")\",\n        \"truncated\": false\n      },\n      \"metadata\": {\n        \"encoding\": \"utf-8\",\n        \"line_count\": 322,\n        \"displayed_lines\": 322,\n        \"truncated\": false,\n        \"size\": 12005\n      }\n    },\n    {\n      \"file_info\": {\n        \"path\": \"crawler_news2.py\",\n        \"name\": \"crawler_news2.py\",\n        \"extension\": \".py\",\n        \"size_bytes\": 13403,\n        \"size_human\": \"13.09 KB\",\n        \"modified\": \"2026-03-26T23:27:46.046281\"\n      },\n      \"content\": {\n        \"raw\": \"import json\\nimport os\\nfrom selenium import webdriver\\nfrom selenium.webdriver.edge.service import Service\\nfrom selenium.webdriver.edge.options import Options\\nfrom selenium.webdriver.common.by import By\\nfrom selenium.webdriver.support.ui import WebDriverWait\\nfrom selenium.webdriver.support import expected_conditions as EC\\nimport time\\nimport re\\n\\n# ========== 精准配置（针对新页面） ==========\\nEDGE_DRIVER_PATH = r\\\"D:\\\\Mine\\\\Download\\\\edge download\\\\edgedriver_win64\\\\msedgedriver.exe\\\"\\nTARGET_URL = \\\"http://job.mohrss.gov.cn/rdzx/index.jhtml\\\"\\nJSONL_FILE = \\\"../data/Hot_News.jsonl\\\"\\nHEADLESS_MODE = True  # 调试时先用有头模式，False=显示窗口，True=无头模式\\n# ================================================\\n\\n# 全局变量（自增ID+查重）\\ntitle_duplicate_set = set()\\ncurrent_auto_id = 1\\n\\ndef load_existing_data():\\n    \\\"\\\"\\\"加载历史数据，初始化自增ID和查重集合\\\"\\\"\\\"\\n    global current_auto_id, title_duplicate_set\\n    if os.path.exists(JSONL_FILE):\\n        try:\\n            max_id = 0\\n            with open(JSONL_FILE, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n                for line in f:\\n                    line = line.strip()\\n                    if line:\\n                        data = json.loads(line)\\n                        if \\\"title\\\" in data:\\n                            title_duplicate_set.add(data[\\\"title\\\"])\\n                        if \\\"id\\\" in data and isinstance(data[\\\"id\\\"], int):\\n                            max_id = max(max_id, data[\\\"id\\\"])\\n            current_auto_id = max_id + 1\\n            print(f\\\"✅ 加载历史数据完成\\\")\\n            print(f\\\"   - 历史不重复标题数：{len(title_duplicate_set)}\\\")\\n            print(f\\\"   - 下一个自增ID：{current_auto_id}\\\")\\n        except Exception as e:\\n            print(f\\\"⚠️ 加载历史数据失败：{e}，将从ID=1重新开始\\\")\\n            current_auto_id = 1\\n            title_duplicate_set = set()\\n    else:\\n        print(f\\\"ℹ️ 无历史数据，ID从1开始爬取\\\")\\n\\ndef init_edge_driver():\\n    \\\"\\\"\\\"初始化Edge浏览器（可选无头模式）\\\"\\\"\\\"\\n    edge_options = Options()\\n    \\n    if HEADLESS_MODE:\\n        # 无头模式配置\\n        edge_options.add_argument(\\\"--headless=new\\\")\\n        edge_options.add_argument(\\\"--disable-gpu\\\")\\n        edge_options.add_argument(\\\"--window-size=1920,1080\\\")\\n        edge_options.add_argument(\\\"--no-sandbox\\\")\\n    else:\\n        # 有头模式（调试用）\\n        edge_options.add_argument(\\\"--start-maximized\\\")\\n        edge_options.add_argument(\\\"--window-size=1920,1080\\\")\\n    \\n    # 通用配置\\n    edge_options.add_argument(\\\"--disable-blink-features=AutomationControlled\\\")\\n    edge_options.add_experimental_option(\\\"excludeSwitches\\\", [\\\"enable-automation\\\"])\\n    edge_options.add_experimental_option(\\\"useAutomationExtension\\\", False)\\n    edge_options.add_argument(\\\"--log-level=3\\\")\\n    \\n    # 初始化驱动\\n    service = Service(EDGE_DRIVER_PATH)\\n    driver = webdriver.Edge(service=service, options=edge_options)\\n    driver.execute_script(\\\"Object.defineProperty(navigator, 'webdriver', {get: () => undefined})\\\")\\n    driver.implicitly_wait(10)\\n    return driver\\n\\ndef extract_news_from_page(driver, page_num=1):\\n    \\\"\\\"\\\"从当前页面提取所有新闻数据\\\"\\\"\\\"\\n    global current_auto_id\\n    page_new_data = []\\n    \\n    # 等待页面加载完成，等待新闻链接出现\\n    WebDriverWait(driver, 15).until(\\n        EC.presence_of_element_located((By.CSS_SELECTOR, \\\"a.blue-light\\\"))\\n    )\\n    time.sleep(1)\\n    \\n    # 提取所有class=\\\"blue-light\\\"的a标签（新闻标题和链接）\\n    news_links = driver.find_elements(By.CSS_SELECTOR, \\\"a.blue-light\\\")\\n    \\n    print(f\\\"\\\\n🔍 第{page_num}页：找到 {len(news_links)} 条新闻链接\\\")\\n    \\n    for i, link_element in enumerate(news_links):\\n        try:\\n            # 提取标题和链接\\n            title = link_element.text.strip()\\n            link = link_element.get_attribute(\\\"href\\\").strip()\\n            \\n            # 过滤无效数据\\n            if not title or not link:\\n                continue\\n            \\n            # 标题查重\\n            if title in title_duplicate_set:\\n                print(f\\\"⏭️ 跳过重复标题：{title[:40]}...\\\")\\n                continue\\n            \\n            # 提取发布时间（从兄弟元素或父元素中的span.floatright）\\n            publish_time = extract_publish_time(link_element)\\n            \\n            # 组装数据\\n            news_item = {\\n                \\\"id\\\": current_auto_id,\\n                \\\"page\\\": page_num,\\n                \\\"title\\\": title,\\n                \\\"link\\\": link,\\n                \\\"publish_time\\\": publish_time,\\n                \\\"source\\\": \\\"人社部热点资讯\\\"\\n            }\\n            page_new_data.append(news_item)\\n            title_duplicate_set.add(title)\\n            print(f\\\"✅ 第{page_num}页第{i+1}条：{title[:50]}... ({publish_time})\\\")\\n            current_auto_id += 1\\n            \\n        except Exception as e:\\n            print(f\\\"⚠️ 第{page_num}页第{i+1}条数据提取失败：{str(e)[:60]}\\\")\\n            continue\\n    \\n    print(f\\\"📊 第{page_num}页：新增 {len(page_new_data)} 条不重复数据\\\")\\n    return page_new_data\\n\\ndef extract_publish_time(link_element):\\n    \\\"\\\"\\\"提取发布时间：从span class='floatright font12 gray'中提取\\\"\\\"\\\"\\n    try:\\n        # 策略1：查找父级元素中的时间span\\n        # 通常新闻结构是：<li> <a>标题</a> <span class=\\\"floatright font12 gray\\\">2026-03-25</span> </li>\\n        parent = link_element.find_element(By.XPATH, \\\"..\\\")\\n        \\n        # 在父级中查找时间span\\n        time_span = parent.find_elements(By.CSS_SELECTOR, \\\"span.floatright.font12.gray\\\")\\n        if time_span:\\n            time_text = time_span[0].text.strip()\\n            if time_text and re.match(r'\\\\d{4}-\\\\d{2}-\\\\d{2}', time_text):\\n                return time_text\\n        \\n        # 策略2：查找父级的父级（如果li内部结构更复杂）\\n        grand_parent = link_element.find_element(By.XPATH, \\\"../..\\\")\\n        time_span = grand_parent.find_elements(By.CSS_SELECTOR, \\\"span.floatright.font12.gray\\\")\\n        if time_span:\\n            time_text = time_span[0].text.strip()\\n            if time_text and re.match(r'\\\\d{4}-\\\\d{2}-\\\\d{2}', time_text):\\n                return time_text\\n        \\n        # 策略3：查找兄弟元素中的时间\\n        sibling_time = link_element.find_elements(By.XPATH, \\\"following-sibling::span[contains(@class, 'floatright')]\\\")\\n        if sibling_time:\\n            time_text = sibling_time[0].text.strip()\\n            if time_text and re.match(r'\\\\d{4}-\\\\d{2}-\\\\d{2}', time_text):\\n                return time_text\\n        \\n        return \\\"时间未知\\\"\\n        \\n    except Exception as e:\\n        print(f\\\"时间提取异常：{e}\\\")\\n        return \\\"时间未知\\\"\\n\\ndef get_total_pages(driver):\\n    \\\"\\\"\\\"获取总页数（通过分析下一页链接）\\\"\\\"\\\"\\n    try:\\n        # 查找所有分页链接\\n        pagination_links = driver.find_elements(By.CSS_SELECTOR, \\\".page a, a[onclick*='index_']\\\")\\n        \\n        max_page = 1\\n        for link in pagination_links:\\n            onclick = link.get_attribute(\\\"onclick\\\") or \\\"\\\"\\n            href = link.get_attribute(\\\"href\\\") or \\\"\\\"\\n            \\n            # 从onclick中提取页码：location.href=encodeURI('index_2.jhtml')\\n            if \\\"index_\\\" in onclick:\\n                match = re.search(r'index_(\\\\d+)\\\\.jhtml', onclick)\\n                if match:\\n                    page_num = int(match.group(1))\\n                    max_page = max(max_page, page_num)\\n            \\n            # 从href中提取页码\\n            if \\\"index_\\\" in href:\\n                match = re.search(r'index_(\\\\d+)\\\\.jhtml', href)\\n                if match:\\n                    page_num = int(match.group(1))\\n                    max_page = max(max_page, page_num)\\n        \\n        if max_page > 1:\\n            print(f\\\"📊 通过分页链接识别到总页数：{max_page}\\\")\\n            return max_page\\n        \\n    except Exception as e:\\n        print(f\\\"⚠️ 获取总页数失败：{e}\\\")\\n    \\n    # 默认爬取5页（根据实际需求调整）\\n    return 5\\n\\ndef go_to_next_page(driver, current_page):\\n    \\\"\\\"\\\"点击下一页（使用特定的翻页链接）\\\"\\\"\\\"\\n    try:\\n        # 查找下一页链接（带onclick属性的a标签）\\n        next_links = driver.find_elements(By.XPATH, \\\"//a[contains(@onclick, 'index_') and contains(text(), '下一页')]\\\")\\n        \\n        if next_links:\\n            print(f\\\"📝 找到下一页链接，点击跳转到第{current_page + 1}页\\\")\\n            driver.execute_script(\\\"arguments[0].click();\\\", next_links[0])\\n            time.sleep(2)\\n            return True\\n        \\n        # 备选方案：直接构造URL\\n        next_url = TARGET_URL.replace(\\\"index.jhtml\\\", f\\\"index_{current_page + 1}.jhtml\\\")\\n        print(f\\\"📝 直接构造URL：{next_url}\\\")\\n        driver.get(next_url)\\n        time.sleep(2)\\n        return True\\n        \\n    except Exception as e:\\n        print(f\\\"❌ 翻页失败：{e}\\\")\\n        return False\\n\\ndef crawl_all_pages():\\n    \\\"\\\"\\\"爬取所有页面的新闻\\\"\\\"\\\"\\n    driver = init_edge_driver()\\n    all_new_data = []\\n    \\n    try:\\n        # 访问首页\\n        print(f\\\"\\\\n🚀 开始爬取首页：{TARGET_URL}\\\")\\n        driver.get(TARGET_URL)\\n        time.sleep(2)\\n        \\n        # 爬取第一页\\n        page1_data = extract_news_from_page(driver, page_num=1)\\n        all_new_data.extend(page1_data)\\n        \\n        # 获取总页数\\n        total_pages = get_total_pages(driver)\\n        print(f\\\"\\\\n📊 预计总页数：{total_pages} 页\\\")\\n        \\n        # 爬取剩余页面\\n        for page_num in range(2, total_pages + 1):\\n            print(f\\\"\\\\n{'='*50}\\\")\\n            print(f\\\"📝 准备爬取第 {page_num} 页\\\")\\n            \\n            # 翻页\\n            if not go_to_next_page(driver, page_num - 1):\\n                print(f\\\"❌ 无法翻到第 {page_num} 页，停止爬取\\\")\\n                break\\n            \\n            # 等待页面加载\\n            WebDriverWait(driver, 10).until(\\n                EC.presence_of_element_located((By.CSS_SELECTOR, \\\"a.blue-light\\\"))\\n            )\\n            time.sleep(1.5)\\n            \\n            # 验证URL是否正确\\n            current_url = driver.current_url\\n            print(f\\\"📍 当前URL：{current_url}\\\")\\n            \\n            # 提取当前页数据\\n            page_data = extract_news_from_page(driver, page_num=page_num)\\n            all_new_data.extend(page_data)\\n            \\n            # 如果没有新数据，提前结束\\n            if len(page_data) == 0:\\n                print(f\\\"⚠️ 第{page_num}页无数据，可能已到达最后一页\\\")\\n                break\\n            \\n            # 避免请求过快\\n            time.sleep(1)\\n    \\n    except Exception as e:\\n        print(f\\\"❌ 爬取过程出错：{e}\\\")\\n        import traceback\\n        traceback.print_exc()\\n    \\n    finally:\\n        driver.quit()\\n    \\n    return all_new_data\\n\\ndef save_to_jsonl(new_data):\\n    \\\"\\\"\\\"保存数据到JSONL文件\\\"\\\"\\\"\\n    if not new_data:\\n        print(\\\"\\\\n⚠️ 没有新数据需要保存\\\")\\n        return\\n    \\n    # 读取历史数据\\n    history_data = []\\n    if os.path.exists(JSONL_FILE):\\n        try:\\n            with open(JSONL_FILE, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n                history_data = [json.loads(line.strip()) for line in f if line.strip()]\\n        except Exception as e:\\n            print(f\\\"⚠️ 读取历史数据失败：{e}，将覆盖原有文件\\\")\\n            history_data = []\\n    \\n    # 合并数据并去重（按标题去重）\\n    all_data = history_data + new_data\\n    unique_data = []\\n    unique_titles = set()\\n    for item in all_data:\\n        if item[\\\"title\\\"] not in unique_titles:\\n            unique_titles.add(item[\\\"title\\\"])\\n            unique_data.append(item)\\n    \\n    # 按ID排序\\n    unique_data.sort(key=lambda x: x[\\\"id\\\"])\\n    \\n    # 写入文件\\n    try:\\n        with open(JSONL_FILE, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n            for item in unique_data:\\n                json_line = json.dumps(item, ensure_ascii=False)\\n                f.write(json_line + \\\"\\\\n\\\")\\n        \\n        print(f\\\"\\\\n{'='*60}\\\")\\n        print(f\\\"📄 JSONL文件保存成功！\\\")\\n        print(f\\\"📁 文件路径：{os.path.abspath(JSONL_FILE)}\\\")\\n        if unique_data:\\n            print(f\\\"📈 总计数据：{len(unique_data)} 条（ID范围：{unique_data[0]['id']}~{unique_data[-1]['id']}）\\\")\\n        print(f\\\"🔍 本次新增：{len(new_data)} 条不重复数据\\\")\\n        print(f\\\"{'='*60}\\\")\\n    except Exception as e:\\n        print(f\\\"\\\\n❌ 保存失败：{str(e)}\\\")\\n\\nif __name__ == \\\"__main__\\\":\\n    print(\\\"=\\\"*60)\\n    print(\\\"🚀 人社部热点资讯爬虫\\\")\\n    print(f\\\"📍 目标网址：{TARGET_URL}\\\")\\n    print(f\\\"🎯 运行模式：{'有头模式（可见浏览器窗口）' if not HEADLESS_MODE else '无头模式（后台静默运行）'}\\\")\\n    print(\\\"=\\\"*60)\\n    \\n    # 加载历史数据\\n    load_existing_data()\\n    \\n    # 爬取数据\\n    new_data = crawl_all_pages()\\n    \\n    # 保存数据\\n    save_to_jsonl(new_data)\\n    \\n    print(\\\"\\\\n🎉 爬取任务全部完成！\\\")\",\n        \"truncated\": false\n      },\n      \"metadata\": {\n        \"encoding\": \"utf-8\",\n        \"line_count\": 347,\n        \"displayed_lines\": 347,\n        \"truncated\": false,\n        \"size\": 13403\n      }\n    },\n    {\n      \"file_info\": {\n        \"path\": \"crawler_test.py\",\n        \"name\": \"crawler_test.py\",\n        \"extension\": \".py\",\n        \"size_bytes\": 13215,\n        \"size_human\": \"12.91 KB\",\n        \"modified\": \"2026-03-17T21:01:23.097957\"\n      },\n      \"content\": {\n        \"raw\": \"import json\\nimport time\\nimport re\\nfrom selenium import webdriver\\nfrom selenium.webdriver.common.by import By\\nfrom selenium.webdriver.support.ui import WebDriverWait\\nfrom selenium.webdriver.support import expected_conditions as EC\\nfrom selenium.webdriver.edge.options import Options\\nfrom selenium.webdriver.edge.service import Service\\nfrom selenium.common.exceptions import TimeoutException, NoSuchElementException\\n\\n# ========== 配置区 ==========\\nEDGE_DRIVER_PATH = r\\\"D:\\\\Mine\\\\Download\\\\edge download\\\\edgedriver_win64\\\\msedgedriver.exe\\\"\\nTARGET_URL = \\\"https://xiaoyuan.zhaopin.com/search/index?refcode=4404&cateType=major\\\"\\nOUTPUT_FILE = \\\"jobs_page_1.jsonl\\\"\\nCOOKIE_FILE = \\\"zhaopin_cookies.json\\\"\\n\\n# 账号配置\\nUSERNAME = \\\"19012713550\\\"\\nPASSWORD = \\\"zzh20050119\\\"\\n# ===========================\\n\\ndef init_driver(headless=False):\\n    \\\"\\\"\\\"初始化Edge浏览器\\\"\\\"\\\"\\n    edge_options = Options()\\n    if headless:\\n        edge_options.add_argument(\\\"--headless=new\\\")\\n    edge_options.add_argument(\\\"--disable-blink-features=AutomationControlled\\\")\\n    edge_options.add_experimental_option(\\\"excludeSwitches\\\", [\\\"enable-automation\\\"])\\n    edge_options.add_experimental_option(\\\"useAutomationExtension\\\", False)\\n    edge_options.add_argument(\\\"--window-size=1920,1080\\\")\\n    edge_options.add_argument(\\\"--disable-gpu\\\")\\n    edge_options.add_argument(\\\"--no-sandbox\\\")\\n    edge_options.add_argument(\\\"--log-level=3\\\")\\n    edge_options.add_argument(\\\"--disable-images\\\")  # 禁用图片加快加载\\n    edge_options.add_argument(\\\"--disable-javascript\\\")  # 根据需要决定是否禁用JS\\n    \\n    service = Service(EDGE_DRIVER_PATH)\\n    driver = webdriver.Edge(service=service, options=edge_options)\\n    driver.execute_script(\\\"Object.defineProperty(navigator, 'webdriver', {get: () => undefined})\\\")\\n    driver.implicitly_wait(10)\\n    return driver\\n\\ndef auto_login(driver):\\n    \\\"\\\"\\\"自动使用账号密码登录\\\"\\\"\\\"\\n    print(\\\"🔑 开始自动登录...\\\")\\n    \\n    # 访问登录页（目标URL会自动跳转到登录页）\\n    driver.get(TARGET_URL)\\n    time.sleep(2)\\n    \\n    # 检查是否已经在目标页（已登录状态）\\n    if \\\"xiaoyuan.zhaopin.com\\\" in driver.current_url and \\\"search\\\" in driver.current_url:\\n        print(\\\"✅ 已经处于登录状态\\\")\\n        return True\\n    \\n    try:\\n        # 1. 等待登录页加载\\n        WebDriverWait(driver, 10).until(\\n            EC.presence_of_element_located((By.CLASS_NAME, \\\"zppp-panel-tab\\\"))\\n        )\\n        \\n        # 2. 切换到\\\"账密登录\\\"标签\\n        print(\\\"  切换到账密登录...\\\")\\n        password_tab = driver.find_element(By.XPATH, \\\"//li[@class='zppp-panel-tab' and contains(text(), '账密登录')]\\\")\\n        password_tab.click()\\n        time.sleep(1)\\n        \\n        # 3. 填写用户名\\n        print(\\\"  填写用户名...\\\")\\n        username_input = driver.find_element(By.CSS_SELECTOR, \\\"input.zppp-input[placeholder='用户名/手机号/邮箱']\\\")\\n        username_input.clear()\\n        username_input.send_keys(USERNAME)\\n        time.sleep(0.5)\\n        \\n        # 4. 填写密码\\n        print(\\\"  填写密码...\\\")\\n        password_input = driver.find_element(By.CSS_SELECTOR, \\\"input.zppp-input[type='password']\\\")\\n        password_input.clear()\\n        password_input.send_keys(PASSWORD)\\n        time.sleep(0.5)\\n        \\n        # 5. 勾选协议（默认未勾选）\\n        print(\\\"  勾选用户协议...\\\")\\n        checkbox = driver.find_element(By.CSS_SELECTOR, \\\"input.zppp-accept__checkbox#accept\\\")\\n        if not checkbox.is_selected():\\n            # 点击复选框\\n            driver.execute_script(\\\"arguments[0].click();\\\", checkbox)\\n        time.sleep(0.5)\\n        \\n        # 6. 点击登录按钮\\n        print(\\\"  点击登录按钮...\\\")\\n        login_button = driver.find_element(By.CSS_SELECTOR, \\\"button.zppp-submit\\\")\\n        login_button.click()\\n        \\n        # 7. 等待登录成功（跳转到目标页）\\n        print(\\\"  等待登录成功...\\\")\\n        WebDriverWait(driver, 30).until(\\n            lambda d: \\\"xiaoyuan.zhaopin.com\\\" in d.current_url and \\\"search\\\" in d.current_url\\n        )\\n        print(\\\"✅ 登录成功！\\\")\\n        \\n        # 可选：保存cookies供后续使用\\n        save_cookies(driver, COOKIE_FILE)\\n        return True\\n        \\n    except TimeoutException:\\n        print(\\\"❌ 登录超时，请检查网络或账号\\\")\\n        return False\\n    except Exception as e:\\n        print(f\\\"❌ 登录过程出错: {e}\\\")\\n        return False\\n\\ndef save_cookies(driver, filename):\\n    \\\"\\\"\\\"保存cookies到文件\\\"\\\"\\\"\\n    cookies = driver.get_cookies()\\n    with open(filename, 'w', encoding='utf-8') as f:\\n        json.dump(cookies, f, ensure_ascii=False, indent=2)\\n    print(f\\\"✅ Cookies已保存到 {filename}\\\")\\n\\ndef parse_list_item(item_element):\\n    \\\"\\\"\\\"从列表页的单个职位卡片中提取数据\\\"\\\"\\\"\\n    try:\\n        # 1. 岗位名称\\n        job_name = item_element.find_element(By.CSS_SELECTOR, \\\".position-card__job-name\\\").text.strip()\\n        \\n        # 2. 地址\\n        city_text = item_element.find_element(By.CSS_SELECTOR, \\\".position-card__city-name\\\").text.strip()\\n        city_match = re.search(r'[「]?(.*?)[·」]', city_text)\\n        address = city_match.group(1) if city_match else city_text.replace('「', '').replace('」', '')\\n        \\n        # 3. 薪资范围\\n        salary = item_element.find_element(By.CSS_SELECTOR, \\\".position-card__salary\\\").text.strip()\\n        \\n        # 4. 公司名称\\n        company = item_element.find_element(By.CSS_SELECTOR, \\\".position-card__company__name\\\").text.strip()\\n        \\n        # 5-7. 所属行业、公司规模、公司类型\\n        tabs = item_element.find_elements(By.CSS_SELECTOR, \\\".position-card__company__tabs-item\\\")\\n        industry = tabs[0].text.strip() if len(tabs) > 0 else \\\"\\\"\\n        company_size = tabs[1].text.strip() if len(tabs) > 1 else \\\"\\\"\\n        company_type = tabs[2].text.strip() if len(tabs) > 2 else \\\"\\\"\\n        \\n        # 8. 岗位编码\\n        job_code = \\\"\\\"\\n        data_option = item_element.get_attribute(\\\"data-sensors-exposure-option\\\")\\n        if data_option:\\n            try:\\n                data_option = data_option.replace('&quot;', '\\\"')\\n                opt = json.loads(data_option)\\n                job_code = opt.get(\\\"properties\\\", {}).get(\\\"jdno\\\", \\\"\\\")\\n            except:\\n                pass\\n        \\n        # 12. 岗位来源地址\\n        detail_url = f\\\"https://xiaoyuan.zhaopin.com/job/{job_code}?refcode=4430&srccode=443001&jobSourceType=2\\\" if job_code else \\\"\\\"\\n        \\n        return {\\n            \\\"岗位名称\\\": job_name,\\n            \\\"地址\\\": address,\\n            \\\"薪资范围\\\": salary,\\n            \\\"公司名称\\\": company,\\n            \\\"所属行业\\\": industry,\\n            \\\"公司规模\\\": company_size,\\n            \\\"公司类型\\\": company_type,\\n            \\\"岗位编码\\\": job_code,\\n            \\\"岗位详情\\\": \\\"\\\",  # 待详情页补充\\n            \\\"更新日期\\\": \\\"\\\",  # 待详情页补充\\n            \\\"公司详情\\\": \\\"\\\",  # 待详情页补充\\n            \\\"岗位来源地址\\\": detail_url\\n        }\\n    except Exception as e:\\n        print(f\\\"解析列表项时出错: {e}\\\")\\n        return None\\n\\ndef parse_detail_page(driver, detail_url):\\n    \\\"\\\"\\\"访问详情页，补充岗位详情、更新日期、公司详情\\\"\\\"\\\"\\n    if not detail_url:\\n        return \\\"\\\", \\\"\\\", \\\"\\\"\\n    \\n    try:\\n        driver.get(detail_url)\\n        \\n        # 等待岗位详情区域加载\\n        WebDriverWait(driver, 10).until(\\n            EC.presence_of_element_located((By.CSS_SELECTOR, \\\".job-info__desc\\\"))\\n        )\\n        time.sleep(1)\\n        \\n        # 9. 岗位详情\\n        job_desc = \\\"\\\"\\n        try:\\n            desc_elem = driver.find_element(By.CSS_SELECTOR, \\\".job-info__desc\\\")\\n            job_desc = desc_elem.get_attribute(\\\"innerHTML\\\").replace(\\\"<br>\\\", \\\"\\\\n\\\").strip()\\n        except:\\n            pass\\n        \\n        # 10. 更新日期（尝试多个可能的选择器）\\n        update_date = \\\"\\\"\\n        possible_selectors = [\\n            \\\".job-info__time\\\",\\n            \\\".job-header__info-item\\\", \\n            \\\".publish-time\\\",\\n            \\\".job-operate\\\"\\n        ]\\n        for selector in possible_selectors:\\n            try:\\n                elem = driver.find_element(By.CSS_SELECTOR, selector)\\n                text = elem.text\\n                # 提取包含日期的文本\\n                date_match = re.search(r'\\\\d{1,2}月\\\\d{1,2}日|\\\\d{4}-\\\\d{2}-\\\\d{2}', text)\\n                if date_match:\\n                    update_date = date_match.group()\\n                    break\\n            except:\\n                continue\\n        \\n        # 11. 公司详情\\n        company_desc = \\\"\\\"\\n        try:\\n            # 可能需要点击\\\"公司详情\\\"标签\\n            try:\\n                company_tab = driver.find_element(By.XPATH, \\\"//div[contains(text(), '公司详情')]\\\")\\n                company_tab.click()\\n                time.sleep(0.5)\\n            except:\\n                pass\\n            \\n            # 查找公司介绍区域\\n            company_elem = driver.find_element(By.CSS_SELECTOR, \\\".company-info__desc\\\")\\n            company_desc = company_elem.get_attribute(\\\"innerHTML\\\").replace(\\\"<br>\\\", \\\"\\\\n\\\").strip()\\n        except:\\n            pass\\n        \\n        return job_desc, update_date, company_desc\\n    except Exception as e:\\n        print(f\\\"解析详情页 {detail_url} 时出错: {e}\\\")\\n        return \\\"\\\", \\\"\\\", \\\"\\\"\\n\\ndef crawl_first_page():\\n    \\\"\\\"\\\"爬取第一页的所有职位数据（自动登录+列表页+详情页）\\\"\\\"\\\"\\n    driver = init_driver(headless=False)  # 先有窗口模式调试\\n    all_jobs = []\\n    \\n    try:\\n        # 1. 自动登录\\n        if not auto_login(driver):\\n            print(\\\"❌ 登录失败，程序退出\\\")\\n            return []\\n        \\n        # 2. 等待职位卡片加载\\n        print(\\\"\\\\n等待职位列表加载...\\\")\\n        WebDriverWait(driver, 20).until(\\n            EC.presence_of_element_located((By.CSS_SELECTOR, \\\".position-card\\\"))\\n        )\\n        time.sleep(2)\\n        \\n        # 3. 获取所有职位卡片\\n        job_cards = driver.find_elements(By.CSS_SELECTOR, \\\".position-card\\\")\\n        print(f\\\"找到 {len(job_cards)} 个职位卡片\\\")\\n        \\n        # 4. 解析列表页数据\\n        for i, card in enumerate(job_cards):\\n            print(f\\\"\\\\n正在解析第 {i+1} 个职位（列表页）...\\\")\\n            job_data = parse_list_item(card)\\n            if job_data:\\n                all_jobs.append(job_data)\\n        \\n        # 5. 访问详情页补充完整数据\\n        print(\\\"\\\\n\\\" + \\\"=\\\"*50)\\n        print(\\\"开始访问详情页补充数据...\\\")\\n        print(\\\"=\\\"*50)\\n        \\n        for i, job in enumerate(all_jobs):\\n            if job[\\\"岗位来源地址\\\"]:\\n                print(f\\\"\\\\n📄 正在获取第 {i+1} 个职位的详情页 ({job['岗位名称']})...\\\")\\n                desc, update, company = parse_detail_page(driver, job[\\\"岗位来源地址\\\"])\\n                job[\\\"岗位详情\\\"] = desc\\n                job[\\\"更新日期\\\"] = update\\n                job[\\\"公司详情\\\"] = company\\n                \\n                # 打印进度\\n                print(f\\\"  ✅ 岗位详情: {len(desc)} 字符\\\")\\n                print(f\\\"  ✅ 更新日期: {update}\\\")\\n                print(f\\\"  ✅ 公司详情: {len(company)} 字符\\\")\\n                \\n                # 礼貌性暂停，避免请求过快\\n                time.sleep(1.5)\\n            else:\\n                print(f\\\"\\\\n⚠️ 第 {i+1} 个职位缺少详情链接，跳过\\\")\\n        \\n        print(f\\\"\\\\n✅ 第一页数据爬取完成，共 {len(all_jobs)} 条完整职位信息\\\")\\n        return all_jobs\\n        \\n    except TimeoutException:\\n        print(\\\"❌ 页面加载超时，请检查网络\\\")\\n        return []\\n    except Exception as e:\\n        print(f\\\"❌ 发生未知错误: {e}\\\")\\n        return []\\n    fi