urn False\\n\\ndef crawl_all_pages():\\n    \\\"\\\"\\\"æ ¸å¿ƒï¼šæ— å¤´æ¨¡å¼�ä¸‹çˆ¬å�–æ‰€æœ‰é¡µé�¢\\\"\\\"\\\"\\n    driver = init_edge_driver()\\n    all_new_data = []\\n    \\n    # ç¬¬ä¸€æ­¥ï¼šè®¿é—®ç›®æ ‡é¡µï¼Œçˆ¬å�–ç¬¬1é¡µ\\n    driver.get(TARGET_URL)\\n    print(f\\\"\\\\nğŸš€ å¼€å§‹çˆ¬å�–ç¬¬ 1 é¡µï¼ˆåˆ�å§‹é¡µï¼‰\\\")\\n    page1_data = extract_page_data(driver, 1)\\n    all_new_data.extend(page1_data)\\n    \\n    # è�·å�–æ€»é¡µæ•°\\n    try:\\n        allpage_input = WebDriverWait(driver, 10).until(\\n            EC.presence_of_element_located((By.ID, \\\"allpage\\\"))\\n        )\\n        total_page = int(allpage_input.get_attribute(\\\"value\\\"))\\n        print(f\\\"ğŸ“Š æ€»é¡µæ•°ï¼š{total_page} é¡µ\\\")\\n    except:\\n        total_page = 6  # é»˜è®¤6é¡µ\\n        print(f\\\"âš ï¸� æ— æ³•è�·å�–æ€»é¡µæ•°ï¼Œé»˜è®¤è®¾ç½®ä¸º {total_page} é¡µ\\\")\\n    \\n    # å¾ªç�¯çˆ¬å�–å‰©ä½™é¡µé�¢\\n    for page_num in range(2, total_page + 1):\\n        try:\\n            print(f\\\"\\\\nğŸ“� å‡†å¤‡çˆ¬å�–ç¬¬ {page_num} é¡µ\\\")\\n            \\n            # ç­‰å¾…å¹¶è�·å�–å½“å‰�é¡µç �ï¼Œç¡®è®¤å�¯ä»¥ç¿»é¡µ\\n            time.sleep(2)\\n            \\n            # æ‰§è¡Œç¿»é¡µ\\n            if not click_next_page(driver, page_num - 1):\\n                print(f\\\"â�Œ æ— æ³•ç¿»åˆ°ç¬¬ {page_num} é¡µï¼Œå�œæ­¢çˆ¬å�–\\\")\\n                break\\n            \\n            # ç­‰å¾…é¡µé�¢åŠ è½½å®Œæˆ�ï¼ˆé€šè¿‡URLå�˜åŒ–æˆ–ç‰¹å®šå…ƒç´ ï¼‰\\n            WebDriverWait(driver, 15).until(\\n                EC.url_contains(f\\\"pageNo={page_num}\\\")\\n            )\\n            print(f\\\"âœ… URLå·²æ›´æ–°åˆ°ç¬¬ {page_num} é¡µ\\\")\\n            \\n            # é¢�å¤–ç­‰å¾…é¡µé�¢å†…å®¹åŠ è½½\\n            time.sleep(2)\\n            \\n            # éªŒè¯�å½“å‰�é¡µç �æ˜¯å�¦æ­£ç¡®\\n            try:\\n                now_page, _ = get_page_info(driver)\\n                if now_page != page_num:\\n                    print(f\\\"âš ï¸� é¡µç �ä¸�åŒ¹é…�ï¼šå½“å‰�æ˜¾ç¤ºç¬¬{now_page}é¡µï¼ŒæœŸæœ›ç¬¬{page_num}é¡µ\\\")\\n                    # å°�è¯•ç›´æ�¥é€šè¿‡URLè®¿é—®\\n                    url = f\\\"http://job.mohrss.gov.cn/cjobs/institution/listInstitution?pageNo={page_num}&origin=\\\"\\n                    driver.get(url)\\n                    time.sleep(2)\\n            except:\\n                pass\\n            \\n            # æ��å�–å½“å‰�é¡µæ•°æ�®\\n            page_data = extract_page_data(driver, page_num)\\n            all_new_data.extend(page_data)\\n            \\n            # å¦‚æ�œæ²¡æœ‰æ–°æ•°æ�®ï¼Œå�¯ä»¥ç»§ç»­çˆ¬å�–ï¼ˆå�¯èƒ½éƒ½æ˜¯é‡�å¤�çš„ï¼‰\\n            \\n        except Exception as e:\\n            print(f\\\"â�Œ ç¬¬{page_num}é¡µçˆ¬å�–å¤±è´¥ï¼š{str(e)[:80]}\\\")\\n            # å°�è¯•ç›´æ�¥URLè®¿é—®ä½œä¸ºå¤‡é€‰\\n            try:\\n                url = f\\\"http://job.mohrss.gov.cn/cjobs/institution/listInstitution?pageNo={page_num}&origin=\\\"\\n                driver.get(url)\\n                time.sleep(3)\\n                page_data = extract_page_data(driver, page_num)\\n                all_new_data.extend(page_data)\\n            except:\\n                print(f\\\"â�Œ å¤‡é€‰æ–¹æ¡ˆä¹Ÿå¤±è´¥ï¼Œå�œæ­¢çˆ¬å�–\\\")\\n                break\\n    \\n    # å…³é—­æµ�è§ˆå™¨\\n    driver.quit()\\n    return all_new_data\\n\\ndef save_to_jsonl(new_data):\\n    \\\"\\\"\\\"ä¿�å­˜æ•°æ�®ï¼šå�ˆå¹¶å�†å�²+æ–°å¢�ï¼Œä¿�è¯�IDè¿�ç»­ã€�æ— é‡�å¤�æ ‡é¢˜\\\"\\\"\\\"\\n    # è¯»å�–å�†å�²æ•°æ�®\\n    history_data = []\\n    if os.path.exists(JSONL_FILE):\\n        try:\\n            with open(JSONL_FILE, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n                history_data = [json.loads(line.strip()) for line in f if line.strip()]\\n        except Exception as e:\\n            print(f\\\"âš ï¸� è¯»å�–å�†å�²æ•°æ�®å¤±è´¥ï¼š{e}ï¼Œå°†è¦†ç›–å�Ÿæœ‰æ–‡ä»¶\\\")\\n            history_data = []\\n    \\n    # å�ˆå¹¶æ•°æ�® + å…¨å±€å�»é‡� + æŒ‰IDæ�’åº�\\n    all_data = history_data + new_data\\n    unique_data = []\\n    unique_titles = set()\\n    for