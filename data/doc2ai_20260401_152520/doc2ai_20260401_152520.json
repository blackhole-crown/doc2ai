    \"content\": {\n        \"raw\": \"import requests\\nfrom lxml import etree\\nimport time\\nimport csv\\n\\n# 只能爬取单条\\n\\n# 目标URL\\nurl = \\\"http://job.mohrss.gov.cn/cjobs/institution/listInstitution\\\"\\n\\n# 请求头（模拟浏览器）\\nheaders = {\\n    \\\"User-Agent\\\": \\\"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36\\\",\\n    \\\"Referer\\\": \\\"http://job.mohrss.gov.cn/\\\",\\n    \\\"Accept\\\": \\\"text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8\\\",\\n    \\\"Accept-Language\\\": \\\"zh-CN,zh;q=0.9,en;q=0.8\\\"\\n}\\n\\ntry:\\n    # 发送请求\\n    response = requests.get(url, headers=headers, timeout=10)\\n    response.raise_for_status()\\n    response.encoding = \\\"utf-8\\\"\\n\\n    # 解析HTML\\n    html = etree.HTML(response.text)\\n\\n    # 1. 提取所有标题和链接（使用你提供的XPath）\\n    title_xpath = \\\"/html/body/div[1]/div[3]/div[1]/div[3]/div[1]/div/div/div/table[1]/tbody/tr/td[2]/a\\\"\\n    title_nodes = html.xpath(title_xpath)\\n\\n    # 2. 提取所有发布时间（对应td[3]）\\n    time_xpath = \\\"/html/body/div[1]/div[3]/div[1]/div[3]/div[1]/div/div/div/table[1]/tbody/tr/td[3]\\\"\\n    time_nodes = html.xpath(time_xpath)\\n\\n    # 3. 组装数据\\n    news_list = []\\n    for title_node, time_node in zip(title_nodes, time_nodes):\\n        title = title_node.text.strip()\\n        link = title_node.get(\\\"href\\\")\\n        # 补全链接\\n        if link.startswith(\\\"/\\\"):\\n            link = \\\"http://job.mohrss.gov.cn\\\" + link\\n        publish_time = time_node.text.strip()\\n\\n        news_list.append({\\n            \\\"title\\\": title,\\n            \\\"link\\\": link,\\n            \\\"publish_time\\\": publish_time\\n        })\\n\\n    # 输出结果\\n    if not news_list:\\n        print(\\\"❌ 未提取到数据，请检查XPath或网页结构\\\")\\n    else:\\n        print(f\\\"✅ 成功提取 {len(news_list)} 条数据：\\\")\\n        print(\\\"-\\\" * 80)\\n        for idx, news in enumerate(news_list, 1):\\n            print(f\\\