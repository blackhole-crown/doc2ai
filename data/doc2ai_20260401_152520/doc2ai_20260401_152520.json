t webdriver\\nfrom selenium.webdriver.edge.service import Service\\nfrom selenium.webdriver.edge.options import Options\\nfrom selenium.webdriver.common.by import By\\nfrom selenium.webdriver.support.ui import WebDriverWait\\nfrom selenium.webdriver.support import expected_conditions as EC\\nimport time\\n\\n# ========== ç²¾å‡†é…�ç½®ï¼ˆåŸºäº�ä½ æ��ä¾›çš„ä¿¡æ�¯ï¼‰ ==========\\nEDGE_DRIVER_PATH = r\\\"D:\\\\Mine\\\\Download\\\\edge download\\\\edgedriver_win64\\\\msedgedriver.exe\\\"\\nTARGET_URL = \\\"http://job.mohrss.gov.cn/cjobs/institution/listInstitution\\\"\\nJSONL_FILE = \\\"../data/Recruitment_News.jsonl\\\"\\nLINK_FEATURE = \\\"/SYrlzyhshbzb/fwyd/SYkaoshizhaopin/\\\"  # é“¾æ�¥ç‰¹å¾�\\n# ================================================\\n\\n# å…¨å±€å�˜é‡�ï¼ˆè‡ªå¢�ID+æŸ¥é‡�ï¼‰\\ntitle_duplicate_set = set()\\ncurrent_auto_id = 1\\n\\ndef load_existing_data():\\n    \\\"\\\"\\\"åŠ è½½å�†å�²æ•°æ�®ï¼Œåˆ�å§‹åŒ–è‡ªå¢�IDå’ŒæŸ¥é‡�é›†å�ˆ\\\"\\\"\\\"\\n    global current_auto_id, title_duplicate_set\\n    if os.path.exists(JSONL_FILE):\\n        try:\\n            max_id = 0\\n            with open(JSONL_FILE, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n                for line in f:\\n                    line = line.strip()\\n                    if line:\\n                        data = json.loads(line)\\n                        if \\\"title\\\" in data:\\n                            title_duplicate_set.add(data[\\\"title\\\"])\\n                        if \\\"id\\\" in data and isinstance(data[\\\"id\\\"], int):\\n                            max_id = max(max_id, data[\\\"id\\\"])\\n            current_auto_id = max_id + 1\\n            print(f\\\"âœ… åŠ è½½å�†å�²æ•°æ�®å®Œæˆ�\\\")\\n            print(f\\\"   - å�†å�²ä¸�é‡�å¤�æ ‡é¢˜æ•°ï¼š{len(title_duplicate_set)}\\\")\\n            print(f\\\"   - ä¸‹ä¸€ä¸ªè‡ªå¢�IDï¼š{current_auto_id}\\\")\\n        except Exception as e:\\n            print(f\\\"âš ï¸� åŠ è½½å�†å�²æ•°æ�®å¤±è´¥ï¼š{e}ï¼Œå°†ä»�ID=1é‡�æ–°å¼€å§‹\\\")\\n            current_auto_id = 1\\n            title_duplicate_set = set()\\n    else:\\n        print(f\\\"â„¹ï¸� æ— å�†å�²æ•°æ�®ï¼ŒIDä»�1å¼€å§‹çˆ¬å�–\\\")\\n\\ndef init_edge_driver():\\n    \\\"\\\"\\\"åˆ�å§‹åŒ–Edgeæµ�è§ˆå™¨ï¼ˆæ— å¤´æ¨¡å¼�ï¼Œå®Œå…¨éš�è—�çª—å�£ï¼‰\\\"\\\"\\\"\\n    edge_options = Options()\\n    # ========== æ ¸å¿ƒï¼šå¼€å�¯æ— å¤´æ¨¡å¼�ï¼ˆæ— æµ�è§ˆå™¨çª—å�£ï¼‰ ==========\\n    edge_options.add_argument(\\\"--headless=new\\\")  # æ–°ç‰ˆEdgeæ— å¤´æ¨¡å¼�\\n    edge_options.add_argument(\\\"--disable-blink-features=AutomationControlled\\\")\\n    edge_options.add_experimental_option(\\\"excludeSwitches\\\", [\\\"enable-automation\\\"])\\n    edge_options.add_experimental_option(\\\"useAutomationExtension\\\", False)\\n    edge_options.add_argument(\\\"--start-maximized\\\")  # æœ€å¤§åŒ–æ— å¤´çª—å�£ï¼ˆé�¿å…�å…ƒç´ é�®æŒ¡ï¼‰\\n    edge_options.add_argument(\\\"--window-size=1920,1080\\\")  # è®¾ç½®çª—å�£åˆ†è¾¨ç�‡\\n    edge_options.add_argument(\\\"--disable-gpu\\\")  # ç¦�ç”¨GPUåŠ é€Ÿï¼ˆæ— å¤´æ¨¡å¼�å¿…éœ€ï¼‰\\n    edge_options.add_argument(\\\"--no-sandbox\\\")  # å�–æ¶ˆæ²™ç®±æ¨¡å¼�\\n    edge_options.add_argument(\\\"--log-level=3\\\")  # å…³é—­æ—¥å¿—è¾“å‡ºï¼Œå‡�å°‘å¹²æ‰°\\n    \\n    # åˆ�å§‹åŒ–é©±åŠ¨\\n    service = Service(EDGE_DRIVER_PATH)\\n    driver = webdriver.Edge(service=service, options=edge_options)\\n    # ç§»é™¤webdriveræ ‡è¯†ï¼ˆå…³é”®ï¼šæ¨¡æ‹ŸçœŸäººï¼‰\\n    driver.execute_script(\\\"Object.defineProperty(navigator, 'webdriver', {get: () => undefined})\\\")\\n    driver.implicitly_wait(10)  # å…¨å±€éš�å¼�ç­‰å¾…\\n    return driver\\n\\ndef extract_page_data(driver, page_num):\\n    \\\"\\\"\\\"æ��å�–å½“å‰�é¡µé�¢æ‰€æœ‰æœ‰æ•ˆæ•°æ�®ï¼ˆç²¾å‡†åŒ¹é…�ä½ çš„é¡µé�¢ç»“æ�„ï¼‰\\\"\\\"\\\"\\n    global current_auto_id\\n    page_new_data = []\\n    \\n    # ç­‰å¾…é¡µé�¢æ•°æ�®åŠ è½½å®Œæˆ�\\n    WebDriverWait(driver, 15).until(\\n        EC.presence_of_element_located((By.CLASS_NAME, \\\"zhaopin-title\\\"))\\n    )\\n    time.sleep(1)  # é¢�å¤–ç­‰å¾…1ç§’ï¼Œç¡®ä¿�æ•°æ�®å®Œå…¨æ¸²æŸ“\\n    \\n    # 1. æ��å�–æ‰€æœ‰æ ‡é¢˜åˆ—ï¼ˆzhaopin-titleï¼‰\\n    title_tds = driver.find_elements(By.CLASS_NAME, \\\"zhaopin-title\\\")\\n    # 2. æ��å�–æ‰€æœ‰æ—¶é—´åˆ—ï¼ˆwidth=\\\"240px\\\"ï¼‰\\n    time_tds = driver.find_elements(By.XPATH, \\\"//td[@width='240px']\\\")\\n    \\n    print(f\\\"\\\\nğŸ”� ç¬¬{page_num}é¡µï¼šæ‰¾åˆ° {len(title_tds)} æ�¡æ‹›è�˜ä¿¡æ�¯ï¼Œ{len(time_tds)} ä¸ªå�‘å¸ƒæ—¶é—´\\\")\\n    \\n    # ä¸€ä¸€å¯¹åº”æ��å�–æ•°æ�®\\n    for i in range(min(len(title_tds), len(time_tds))):\\n        try:\\n            # æ��å�–æ ‡é¢˜å’Œé“¾æ�¥\\n            title_td = title_tds[i]\\n            a_tag = title_td.find_element(By.TAG_NAME, \\\"a\\\")\\n            title = a_tag.text.strip()\\n            link = a_tag.get_attribute(\\\"href\\\").strip()\\n            \\n            # æ��å�–å�‘å¸ƒæ—¶é—´ï¼ˆç²¾å‡†åŒ¹é…�width=\\\"240px\\\"çš„tdï¼‰\\n            publish_time = time_tds[i].text.strip()\\n            \\n            # è¿‡æ»¤æ— æ•ˆæ•°æ�®\\n            if not title or not link or len(publish_time) != 10:\\n                continue\\n            \\n            # æ ‡é¢˜æŸ¥é‡�ï¼šè·³è¿‡é‡�å¤�å†…å®¹\\n            if title in title_duplicate_set:\\n                print(f\\\"â�­ï¸� è·³è¿‡é‡�å¤�æ ‡é¢˜ï¼ˆID={current_auto_id}ï¼‰ï¼š{title[:30]}...\\\")\\n                continue\\n            \\n            # ç»„è£…æ•°æ�®ï¼ˆè‡ªå¢�IDï¼‰\\n            news_item = {\\n                \\\"id\\\": current_auto_id,\\n                \\\"page\\\": page_num,  # ä¿�ç•™é¡µç �ä¾¿äº�æº¯æº�ï¼ˆä¸�éœ€è¦�å�¯åˆ é™¤ï¼‰\\n                \\\"title\\\": title,\\n                \\\"link\\\": link,\\n                \\\"publish_time\\\": publish_time\\n            }\\n            page_new_data.append(news_item)\\n            title_duplicate_set.add(title)\\n            current_auto_id += 1  # IDè‡ªå¢�\\n        \\n        except Exception as e:\\n            print(f\\\"âš ï¸� ç¬¬{page_num}é¡µç¬¬{i+1}æ�¡æ•°æ�®æ��å�–å¤±è´¥ï¼š{str(e)[:60]}\\\")\\n            continue\\