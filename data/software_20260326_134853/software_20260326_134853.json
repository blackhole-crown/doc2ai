age = False\n                print(f\"ğŸ“Œ ç¬¬{current_page}é¡µé‡�è¯•å¤±è´¥ï¼Œå�œæ­¢ç¿»é¡µ\")\n    \n    return all_new_data\n\ndef save_to_jsonl(new_data):\n    \"\"\"ä¿�å­˜æ•°æ�®ï¼šå�ˆå¹¶å�†å�²+æ–°å¢�ï¼Œä¿�è¯�IDè¿�ç»­ä¸”ä¸�é‡�å¤�\"\"\"\n    # 1. è¯»å�–å�†å�²æ•°æ�®\n    history_data = []\n    if os.path.exists(JSONL_FILE):\n        try:\n            with open(JSONL_FILE, \"r\", encoding=\"utf-8\") as f:\n                for line in f:\n                    line = line.strip()\n                    if line:\n                        history_data.append(json.loads(line))\n        except Exception as e:\n            print(f\"âš ï¸� è¯»å�–å�†å�²æ•°æ�®å¤±è´¥ï¼š{e}ï¼Œå°†è¦†ç›–å�Ÿæœ‰æ–‡ä»¶\")\n            history_data = []\n    \n    # 2. å�ˆå¹¶æ•°æ�®ï¼ˆå�†å�²+æ–°å¢�ï¼‰\n    all_data = history_data + new_data\n    \n    # 3. æœ€ç»ˆå�»é‡�ï¼ˆæŒ‰æ ‡é¢˜ï¼‰+ æŒ‰IDæ�’åº�\n    unique_data = []\n    unique_titles = set()\n    for item in all_data:\n        if item[\"title\"] not in unique_titles:\n            unique_titles.add(item[\"title\"])\n            unique_data.append(item)\n    # æŒ‰IDå�‡åº�æ�’åˆ—ï¼Œä¿�è¯�é¡ºåº�ä¸€è‡´\n    unique_data.sort(key=lambda x: x[\"id\"])\n    \n    # 4. å†™å…¥æ–‡ä»¶\n    try:\n        with open(JSONL_FILE, \"w\", encoding=\"utf-8\") as f:\n            for item in unique_data:\n                json_line = json.dumps(item, ensure_ascii=False)\n                f.write(json_line + \"\\n\")\n        \n        print(f\"\\nğŸ“„ JSONLæ–‡ä»¶ä¿�å­˜æˆ�åŠŸï¼�\")\n        print(f\"ğŸ“� æ–‡ä»¶è·¯å¾„ï¼š{os.path.abspath(JSONL_FILE)}\")\n        print(f\"ğŸ“ˆ æ€»è®¡æ•°æ�®ï¼š{len(unique_data)} æ�¡ï¼ˆIDèŒƒå›´ï¼š1~{unique_data[-1]['id']}ï¼‰\")\n        print(f\"ğŸ”� æœ¬æ¬¡æ–°å¢�ï¼š{len(new_data)} æ�¡\")\n    except PermissionError:\n        print(f\"\\nâ�Œ æ�ƒé™�ä¸�è¶³ï¼�è¯·å…³é—­æ‰“å¼€çš„ {JSONL_FILE} æ–‡ä»¶å��é‡�è¯•\")\n    except Exception as e:\n        print(f\"\\nâ�Œ ä¿�å­˜å¤±è´¥ï¼š{str(e)}\")\n\nif __name__ == \"__main__\":\n    print(\"ğŸš€ å¼€å§‹çˆ¬å�–äº‹ä¸šå