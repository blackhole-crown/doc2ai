        "raw": "<template>\n  <div class=\"app-container-bg resume-polishing-container\">\n    <div class=\"background-shape-global\"></div>\n    \n    <div class=\"content-wrapper\">\n      <h1>简历润色</h1>\n      \n      <div class=\"action-buttons common-card\">\n        <el-upload\n          class=\"upload-demo\"\n          action=\"#\"\n          :auto-upload=\"false\"\n          :limit=\"1\"\n        >\n          <el-button type=\"primary\" size=\"large\">上传简历 (PDF/Word)</el-button>\n          <template #tip>\n            <div class=\"el-upload__tip\">\n              支持 docx/pdf 文件，不超过 5MB\n            </div>\n          </template>\n        </el-upload>\n        \n        <el-button type=\"success\" size=\"large\" @click=\"polishResume\" class=\"polish-btn\">一键润色</el-button>\n      </div>\n\n      <div class=\"resume-content-area\">\n        <div class=\"original-resume common-card\">\n          <h3>原始简历</h3>\n          <el-input\n            v-model=\"originalContent\"\n            type=\"textarea\"\n            :rows=\"20\"\n            placeholder=\"或者在此粘贴简历内容...\"\n            class=\"resume-textarea\"\n          />\n        </div>\n        \n        <div class=\"polished-resume common-card\">\n          <h3>润色后建议</h3>\n          <el-input\n            v-model=\"polishedContent\"\n            type=\"textarea\"\n            :rows=\"20\"\n            placeholder=\"润色后的内容将显示在这里...\"\n            readonly\n            class=\"resume-textarea\"\n          />\n        </div>\n      </div>\n      \n      <div class=\"templates-section\">\n        <h3>优秀简历模板推荐</h3>\n        <div class=\"template-list\">\n          <div class=\"template-card common-card\" v-for=\"i in 3\" :key=\"i\">\n            <div class=\"template-preview\">模板 {{ i }}</div>\n            <el-button text>使用此模板</el-button>\n          </div>\n        </div>\n      </div>\n\n      <AiChatBox />\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\nimport { ElMessage } from 'element-plus'\nimport AiChatBox from '../components/AiChatBox.vue'\n\nconst originalContent = ref('')\nconst polishedContent = ref('')\n\nconst polishResume = () => {\n  if (!originalContent.value) {\n    ElMessage.warning('请先输入简历内容或上传简历')\n    return\n  }\n  \n  // Mock polishing process\n  ElMessage.success('正在分析简历...')\n  setTimeout(() => {\n    polishedContent.value = `[优化建议]\\n1. 使用更强有力的动词开头，如\"主导\"、\"负责\"、\"优化\"。\\n2. 量化你的成果，例如\"提升了20%的效率\"。\\n\\n[优化后的内容]\\n` + originalContent.value.replace(/参与/g, '主导并负责')\n    ElMessage.success('简历润色完成')\n  }, 1500)\n}\n</script>\n\n<style scoped>\n.resume-polishing-container {\n  padding: 40px 20px;\n}\n\n.content-wrapper {\n  max-width: 1200px;\n  margin: 0 auto;\n  position: relative;\n  z-index: 1;\n  display: flex;\n  flex-direction: column;\n  gap: 30px;\n}\n\n.action-buttons {\n  display: flex;\n  gap: 20px;\n  align-items: center;\n  padding: 30px;\n}\n\n.polish-btn {\n  margin-left: 20px;\n}\n\n.resume-content-area {\n  display: flex;\n  gap: 30px;\n}\n\n.original-resume, .polished-resume {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  gap: 15px;\n  padding: 30px;\n}\n\n.resume-textarea {\n  font-family: inherit;\n}\n\n.templates-section {\n  margin-top: 20px;\n}\n\n.template-list {\n  display: flex;\n  gap: 20px;\n  margin-top: 20px;\n}\n\n.template-card {\n  width: 200px;\n  height: 280px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  gap: 15px;\n  cursor: pointer;\n  padding: 10px;\n}\n\n.template-preview {\n  width: 100%;\n  height: 180px;\n  background-color: #f5f5f5;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: #999;\n  border-radius: 8px;\n}\n</style>",
