        "raw": "<template>\n  <header class=\"app-header\">\n    <div class=\"container\">\n      <div class=\"logo-section\">\n        <div class=\"logo-icon\">ui</div>\n        <span class=\"logo-text\">球球职业规划</span>\n      </div>\n      \n      <nav class=\"nav-links\">\n        <router-link to=\"/\" class=\"nav-item\" active-class=\"active\">首页</router-link>\n        <router-link to=\"/career-planning\" class=\"nav-item\" active-class=\"active\">职业规划</router-link>\n        <router-link to=\"/job-analysis\" class=\"nav-item\" active-class=\"active\">岗位分析</router-link>\n        <router-link to=\"/dashboard\" class=\"nav-item\" active-class=\"active\">个人画像</router-link>\n        <router-link to=\"/resume-polishing\" class=\"nav-item\" active-class=\"active\">简历润色</router-link>\n        <router-link to=\"/career-news\" class=\"nav-item\" active-class=\"active\">职业新闻</router-link>\n      </nav>\n      \n      <div class=\"user-section\">\n        <template v-if=\"isLoggedIn\">\n          <div class=\"user-profile\">\n            <el-avatar :size=\"32\" icon=\"UserFilled\" />\n            <span class=\"username\">周泽辉同学</span>\n          </div>\n        </template>\n        <template v-else>\n          <router-link to=\"/login\">\n            <el-button class=\"login-btn\">登录</el-button>\n          </router-link>\n        </template>\n      </div>\n    </div>\n  </header>\n</template>\n\n<script setup>\nimport { computed } from 'vue'\nimport { useRoute } from 'vue-router'\nimport { UserFilled } from '@element-plus/icons-vue'\n\nconst route = useRoute()\n\n// Simple logic to show logged in state on dashboard\nconst isLoggedIn = computed(() => {\n  return route.path.includes('/dashboard')\n})\n</script>\n\n<style scoped>\n.app-header {\n  height: 60px;\n  background-color: #fff;\n  border-bottom: 1px solid #eaeaea;\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100%;\n  z-index: 1000;\n  display: flex;\n  align-items: center;\n}\n\n.container {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 0 20px;\n  width: 100%;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n}\n\n.logo-section {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n\n.logo-icon {\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  border: 1px solid #ddd;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: #666;\n  font-size: 14px;\n}\n\n.logo-text {\n  font-size: 18px;\n  font-weight: 600;\n  color: #333;\n}\n\n.nav-links {\n  display: flex;\n  gap: 30px;\n}\n\n.nav-item {\n  text-decoration: none;\n  color: #333;\n  font-size: 16px;\n  font-weight: 500;\n  padding: 5px 0;\n}\n\n.nav-item:hover, .nav-item.active {\n  color: #000;\n  font-weight: 600;\n}\n\n.user-section {\n  display: flex;\n  align-items: center;\n}\n\n.login-btn {\n  padding: 8px 20px;\n}\n\n.user-profile {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  cursor: pointer;\n}\n\n.username {\n  font-size: 14px;\n  color: #333;\n  font-weight: 500;\n}\n</style>",
