      "content": {
        "raw": "<template>\n  <div class=\"app-container-bg career-planning-container\">\n    <div class=\"background-shape-global\"></div>\n    \n    <div class=\"content-wrapper\">\n      <h1>职业规划</h1>\n      \n      <el-tabs v-model=\"activeTab\" class=\"planning-tabs\">\n        <el-tab-pane label=\"AI 智能规划\" name=\"ai-planning\">\n          <div class=\"ai-planning-section\">\n            <div class=\"ai-input-card common-card\">\n              <h3>AI 职业路径生成</h3>\n              <p class=\"subtitle\">告诉 AI 你的专业、兴趣和目标，为你定制专属职业路径。</p>\n              <el-input\n                v-model=\"aiInput\"\n                type=\"textarea\"\n                :rows=\"4\"\n                placeholder=\"例如：我是软件工程专业的学生，对数据分析感兴趣，未来想从事人工智能相关工作...\"\n                class=\"ai-textarea\"\n              />\n              <div class=\"ai-actions\">\n                <el-button type=\"primary\" :loading=\"isGenerating\" @click=\"generateAiPath\" size=\"large\">\n                  <el-icon class=\"el-icon--left\"><MagicStick /></el-icon>\n                  生成职业路径\n                </el-button>\n              </div>\n            </div>\n            \n            <div class=\"ai-result-card common-card\" v-if=\"aiPathResult\">\n              <h3>为您推荐的职业路径</h3>\n              <el-timeline>\n                <el-timeline-item\n                  v-for=\"(step, index) in aiPathResult\"\n                  :key=\"index\"\n                  :type=\"step.type\"\n                  :color=\"step.color\"\n                  :size=\"step.size\"\n                  :timestamp=\"step.time\"\n                  placement=\"top\"\n                >\n                  <el-card class=\"timeline-card\">\n                    <h4>{{ step.title }}</h4>\n                    <p>{{ step.description }}</p>\n                    <div class=\"step-tags\" v-if=\"step.tags\">\n                      <el-tag v-for=\"tag in step.tags\" :key=\"tag\" size=\"small\" effect=\"plain\">{{ tag }}</el-tag>\n                    </div>\n                  </el-card>\n                </el-timeline-item>\n              </el-timeline>\n            </div>\n          </div>\n        </el-tab-pane>\n        \n        <el-tab-pane label=\"岗位差距分析\" name=\"gap-analysis\">\n          <div class=\"planning-content\">\n            <div class=\"target-select-section common-card\">\n              <span>选择目标岗位：</span>\n              <el-select v-model=\"selectedTargetJob\" placeholder=\"请选择目标岗位\" size=\"large\" @change=\"handleJobChange\">\n                <el-option label=\"高级前端工程师\" value=\"senior_frontend\" />\n                <el-option label=\"全栈开发工程师\" value=\"fullstack\" />\n                <el-option label=\"技术经理\" value=\"tech_lead\" />\n                <el-option label=\"产品经理\" value=\"product_manager\" />\n              </el-select>\n            </div>\n\n            <div class=\"match-section\">\n              <h2>人岗智能匹配</h2>\n              <div class=\"match-card common-card\">\n                <div class=\"match-score\">\n                  <el-progress type=\"dashboard\" :percentage=\"currentJobData.score\" :color=\"colors\" />\n                  <div class=\"match-label\">匹配度</div>\n                </div>\n                <div class=\"match-details\">\n                  <h3>目标岗位：{{ currentJobData.name }}</h3>\n                  <div class=\"gap-analysis\">\n                    <h4>差距分析</h4>\n                    <div class=\"gap-list\">\n                      <el-tag \n                        v-for=\"gap in currentJobData.gaps\" \n                        :key=\"gap.text\" \n                        :type=\"gap.type\" \n                        class=\"gap-item\"\n                      >\n                        {{ gap.text }}\n                      </el-tag>\n                    </div>\n                  </div>\n                  <div class=\"suggestions\">\n                    <h4>提升建议</h4>\n                    <p>{{ currentJobData.suggestion }}</p>\n                  </div>\n                </div>\n              </div>\n            </div>\n            \n            <div class=\"path-section\">\n              <h2>个性化职业路径</h2>\n              <div class=\"path-card common-card\">\n                <el-steps direction=\"vertical\" :active=\"1\">\n                  <el-step \n                    v-for=\"(step, index) in currentJobData.path\" \n                    :key=\"index\"\n                    :title=\"step.title\" \n                    :description=\"step.description\"\n                  >\n                    <template #icon>\n                      <div :class=\"['step-icon', { active: index <= 1 }]\">{{ index + 1 }}</div>\n                    </template>\n                    <template #description v-if=\"step.tasks\">\n                      <div class=\"step-content\">\n                        <p>{{ step.description }}</p>\n                        <div class=\"step-tasks\">\n                          <h5>阶段任务：</h5>\n                          <ul>\n                            <li v-for=\"(task, tIndex) in step.tasks\" :key=\"tIndex\">\n                              <el-checkbox>{{ task }}</el-checkbox>\n                            </li>\n                          </ul>\n                        </div>\n                      </div>\n                    </template>\n                  </el-step>\n                </el-steps>\n              </div>\n            </div>\n          </div>\n        </el-tab-pane>\n      </el-tabs>\n\n      <AiChatBox />\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, reactive, computed } from 'vue'\nimport { MagicStick } from '@element-plus/icons-vue'\nimport { ElMessage } from 'element-plus'\nimport AiChatBox from '../components/AiChatBox.vue'\n\nconst activeTab = ref('ai-planning')\nconst aiInput = ref('')\nconst isGenerating = ref(false)\nconst aiPathResult = ref(null)\n\nconst selectedTargetJob = ref('senior_frontend')\n\nconst colors = [\n  { color: '#f56c6c', percentage: 20 },\n  { color: '#e6a23c', percentage: 