        "raw": "import os\nimport json\nfrom pathlib import Path\nimport ssl\nfrom urllib.error import HTTPError, URLError\nfrom urllib.parse import quote\n\ntry:\n    import certifi\nexcept Exception:\n    certifi = None\n\ntry:\n    import requests\n    from requests.adapters import HTTPAdapter\n    from requests.exceptions import RequestException, SSLError\nexcept Exception:\n    requests = None\n    HTTPAdapter = None\n    RequestException = Exception\n    SSLError = Exception\n\ntry:\n    from dotenv import load_dotenv\nexcept Exception:\n    load_dotenv = None\n\n\ndef _load_env() -> None:\n    if load_dotenv is None:\n        return\n    project_root = Path(__file__).resolve().parents[2]\n    try:\n        load_dotenv(project_root / \".env\")\n    except Exception:\n        pass\n\n\n_session = None\n\n\ndef _get_session():\n    global _session\n    if _session is not None:\n        return _session\n    global requests, HTTPAdapter\n    if requests is None or HTTPAdapter is None:\n        try:\n            import requests as _requests\n            from requests.adapters import HTTPAdapter as _HTTPAdapter\n            from requests.exceptions import RequestException as _RequestException, SSLError as _SSLError\n        except Exception:\n            raise RuntimeError(\"缺少 requests 依赖\")\n        requests = _requests\n        HTTPAdapter = _HTTPAdapter\n        globals()[\"RequestException\"] = _RequestException\n        globals()[\"SSLError\"] = _SSLError\n    s = requests.Session()\n    s.headers.update({\"Accept\": \"application/json\"})\n    adapter = HTTPAdapter(pool_connections=16, pool_maxsize=16, max_retries=0)\n    s.mount(\"https://\", adapter)\n    s.mount(\"http://\", adapter)\n    _session = s\n    return _session\n\n\ndef _load_knowledge_key() -> str | None:\n    _load_env()\n    project_root = Path(__file__).resolve().parents[2]\n    knowledge_path = project_root / \"knowledge\" / \"tech-stack.md\"\n    if not knowledge_path.exists():\n        return None\n    try:\n        text = knowledge_path.read_text(encoding=\"utf-8\", errors=\"ignore\")\n    except Exception:\n        return None\n    marker = \"sb_publishable_\"\n    idx = text.find(marker)\n    if idx == -1:\n        return None\n    tail = text[idx:].split()[0].strip()\n    return tail or None\n\n\ndef get_supabase_url() -> str | None:\n    _load_env()\n    url = os.getenv(\"SUPABASE_URL\")\n    if url:\n        return url.strip()\n    key = get_supabase_key()\n    if not key:\n        return None\n    parts = key.split(\"_\")\n    if len(parts) >= 3:\n        project_ref = parts[2].strip()\n        if project_ref:\n            return f\"https://{project_ref.lower()}.supabase.co\"\n    return None\n\n\ndef get_supabase_key() -> str | None:\n    _load_env()\n    key = os.getenv(\"SUPABASE_ANON_KEY\") or os.getenv(\"SUPABASE_KEY\")\n    if key:\n        return key.strip()\n    return _load_knowledge_key()\n\n\ndef supabase_request(method: str, endpoint: str, params: dict = None, json_data: dict = None) -> list | dict | None:\n    \"\"\"\n    通用 Supabase REST 请求封装\n    :param method: GET, POST, PATCH, DELETE\n    :param endpoint: 比如 '/rest/v1/sys_profiles'\n    :param params: URL 查询参数字典\n    :param json_data: POST/PATCH 的 body 数据\n    :return: 解析后的 JSON 数据\n    \"\"\"\n    supabase_url = get_supabase_url()\n    supabase_key = get_supabase_key()\n    if not supabase_url or not supabase_key:\n        raise RuntimeError(\"Supabase 配置缺失\")\n\n    url = f\"{supabase_url.rstrip('/')}/{endpoint.lstrip('/')}\"\n    \n    headers = {\n        \"apikey\": supabase_key,\n        \"Authorization\": f\"Bearer {supabase_key}\",\n        \"Accept\": \"application/json\",\n    }\n    \n   \n    if method.upper() in (\"POST\", \"PATCH\", \"DELETE\"):\n        headers[\"Prefer\"] = \"return=representation\"\n\n    try:\n        verify = True\n        if certifi is not None:\n            try:\n                verify = certifi.where()\n            except Exception:\n                verify = True\n                \n        s = _get_session()\n        resp = s.request(\n            method=method.upper(),\n            url=url,\n            headers=headers,\n            params=params,\n            json=json_data,\n            timeout=10,\n            verify=verify,\n        )\n        \n        if resp.status_code >= 400:\n            raise RuntimeError(f\"Supabase 请求失败: HTTP {resp.status_code} - {resp.text}\")\n            \n        raw = resp.text\n    except SSLError as e:\n        raise RuntimeError(f\"Supabase 网络连接失败 (SSL): {str(e)}\") from e\n    except RequestException as e:\n        raise RuntimeError(f\"Supabase 网络连接失败: {str(e)}\") from e\n    except Exception as e:\n        raise RuntimeError(f\"Supabase 请求异常: {str(e)}\") from e\n\n    if not raw:\n        return None\n        \n    try:\n        data = json.loads(raw)\n        return data\n    except Exception as e:\n        raise RuntimeError(\"Supabase 返回数据解析失败\") from e\n\n\ndef get_sys_profile_by_phone(phone: str) -> dict | None:\n    safe_phone = quote(phone, safe=\"\")\n    \n    # 直接使用封装好的 supabase_request\n    data = supabase_request(\n        method=\"GET\",\n        endpoint=\"/rest/v1/sys_profiles\",\n        params={\n            \"select\": \"id,role_code,password,phone,real_name,avatar_url,resume_url\",\n            \"phone\": f\"eq.{safe_phone}\",\n            \"limit\": \"1\"\n        }\n    )\n    \n    if isinstance(data, list) and data:\n        return data[0]\n    return None",
