        "raw": "from flask import Blueprint, request, jsonify\nfrom app.utils.db import get_sys_profile_by_phone\nfrom datetime import datetime\n\n# 创建登录蓝图\nlogin_bp = Blueprint('login', __name__)\n\n@login_bp.route('/login', methods=['POST'])\ndef login():\n    \"\"\"基于 phone 的简单登录接口 (密码不加密，连接 Supabase)\"\"\"\n    try:\n        # 尝试获取 JSON 数据，如果 Content-Type 不是 application/json 也会尝试解析\n        data = request.get_json(silent=True)\n        \n        # 如果不是 JSON 或者没有提供数据，尝试从表单获取\n        if data is None:\n            data = request.form\n            \n        # 如果依然没有数据，返回错误\n        if not data:\n            return jsonify({\n                \"code\": 400,\n                \"message\": \"请提供手机号和密码\"\n            }), 400\n        \n        phone = data.get('phone')\n        password = data.get('password')\n        \n        if not phone or not password:\n            return jsonify({\n                \"code\": 400,\n                \"message\": \"手机号和密码不能为空\"\n            }), 400\n        \n        try:\n            user_info = get_sys_profile_by_phone(phone)\n            if not user_info:\n                return jsonify({\n                    \"code\": 401,\n                    \"message\": \"用户不存在\"\n                }), 401\n            \n            # 验证密码 (明文比对)\n            if user_info.get('password') == password:\n                return jsonify({\n                    \"code\": 200,\n                    \"message\": \"登录成功\",\n                    \"data\": {\n                        \"id\": user_info.get(\"id\"),\n                        \"phone\": user_info.get(\"phone\"),\n                        \"real_name\": user_info.get(\"real_name\"),\n                        \"role_code\": user_info.get(\"role_code\"),\n                        \"avatar_url\": user_info.get(\"avatar_url\"),\n                        \"login_time\": datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n                    }\n                })\n            else:\n                return jsonify({\n                    \"code\": 401,\n                    \"message\": \"密码错误\"\n                }), 401\n                \n        except Exception as db_err:\n            return jsonify({\n                \"code\": 500,\n                \"message\": f\"数据库查询错误: {str(db_err)}\"\n            }), 500\n            \n    except Exception as e:\n        return jsonify({\n            \"code\": 500,\n            \"message\": f\"服务器错误: {str(e)}\"\n        }), 500\n\n@login_bp.route('/health', methods=['GET'])\ndef health():\n    \"\"\"健康检查接口\"\"\"\n    return jsonify({\n        \"code\": 200,\n        \"message\": \"服务正常\",\n        \"data\": {\n            \"status\": \"running\"\n        }\n    })",
