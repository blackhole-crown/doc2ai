      "content": {
        "raw": "<template>\n  <div class=\"input-section\">\n    <div class=\"mascot-float\">\n      <img src=\"https://img.yzcdn.cn/vant/cat.jpeg\" alt=\"Mascot\" class=\"mascot-img-small\" />\n    </div>\n    \n    <div class=\"input-box\" v-if=\"!showChat\">\n      <textarea \n        v-model=\"initialQuery\"\n        class=\"custom-textarea\" \n        placeholder=\"求职路上，随时戳球球助阵！\"\n        rows=\"3\"\n        @keydown.enter.prevent=\"startChat\"\n      ></textarea>\n      <div class=\"send-btn\" @click=\"startChat\">\n        <el-icon><Top /></el-icon>\n      </div>\n      <div class=\"search-icon\">\n        <el-icon><Search /></el-icon> 搜索\n      </div>\n    </div>\n\n    <div class=\"chat-box\" v-else>\n      <div class=\"chat-header\">\n        <span>球球智能助手</span>\n        <el-icon class=\"close-chat\" @click=\"showChat = false\"><Close /></el-icon>\n      </div>\n      <div class=\"chat-messages\" ref=\"messagesRef\">\n        <div v-for=\"(msg, index) in messages\" :key=\"index\" :class=\"['message', msg.role]\">\n          <div class=\"avatar\" v-if=\"msg.role === 'ai'\">\n            <el-icon><Service /></el-icon>\n          </div>\n          <div class=\"content\">{{ msg.content }}</div>\n          <div class=\"avatar\" v-if=\"msg.role === 'user'\">\n            <el-icon><User /></el-icon>\n          </div>\n        </div>\n        <div v-if=\"isTyping\" class=\"message ai typing\">\n            <div class=\"avatar\"><el-icon><Service /></el-icon></div>\n            <div class=\"content\">正在思考...</div>\n        </div>\n      </div>\n      <div class=\"chat-input\">\n        <el-input \n          v-model=\"currentInput\" \n          placeholder=\"请输入您的问题...\" \n          @keydown.enter=\"sendMessage\"\n        >\n          <template #append>\n            <el-button @click=\"sendMessage\">发送</el-button>\n          </template>\n        </el-input>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, nextTick } from 'vue'\nimport { Search, Top, Close, Service, User } from '@element-plus/icons-vue'\n\nconst showChat = ref(false)\nconst initialQuery = ref('')\nconst currentInput = ref('')\nconst messages = ref([])\nconst isTyping = ref(false)\nconst messagesRef = ref(null)\n\nconst startChat = () => {\n  if (!initialQuery.value.trim()) return\n  \n  showChat.value = true\n  messages.value = [\n    { role: 'ai', content: '你好！我是球球智能助手，很高兴为你服务。请问有什么我可以帮你的吗？' },\n    { role: 'user', content: initialQuery.value }\n  ]\n  initialQuery.value = ''\n  simulateResponse()\n}\n\nconst sendMessage = () => {\n  if (!currentInput.value.trim()) return\n  \n  messages.value.push({ role: 'user', content: currentInput.value })\n  currentInput.value = ''\n  scrollToBottom()\n  simulateResponse()\n}\n\nconst simulateResponse = () => {\n  isTyping.value = true\n  scrollToBottom()\n  \n  setTimeout(() => {\n    isTyping.value = false\n    messages.value.push({ \n      role: 'ai', \n      content: '收到！根据您的描述，建议您可以先进行职业兴趣测评，以便我们更精准地为您推荐岗位。' \n    })\n    scrollToBottom()\n  }, 1500)\n}\n\nconst scrollToBottom = () => {\n  nextTick(() => {\n    if (messagesRef.value) {\n      messagesRef.value.scrollTop = messagesRef.value.scrollHeight\n    }\n  })\n}\n</script>\n\n<style scoped>\n.input-section {\n  width: 100%;\n  max-width: 900px;\n  position: relative;\n  margin: 40px auto 0; /* Centered and added top margin */\n}\n\n.mascot-float {\n  position: absolute;\n  top: -40px;\n  left: 20px;\n  z-index: 2;\n}\n\n.mascot-img-small {\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  border: 2px solid #fff;\n  box-shadow: 0 4px 10px rgba(0,0,0,0.1);\n}\n\n.input-box {\n  background: #fff;\n  border-radius: 16px;\n  padding: 20px 20px 50px 20px;\n  position: relative;\n  box-shadow: 0 8px 30px rgba(0,0,0,0.05);\n  border: 1px solid #fff;\n}\n\n.custom-textarea {\n  width: 100%;\n  border: none;\n  resize: none;\n  font-size: 16px;\n  color: #333;\n  outline: none;\n  font-family: inherit;\n  background: transparent;\n}\n\n.custom-textarea::placeholder {\n  color: #ccc;\n}\n\n.send-btn {\n  position: absolute;\n  bottom: 15px;\n  right: 15px;\n  width: 32px;\n  height: 32px;\n  border-radius: 50%;\n  background: #409EFF;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  cursor: pointer;\n  color: #fff;\n  transition: all 0.3s;\n  box-shadow: 0 4px 12px rgba(64, 158, 255, 0.3);\n}\n\n.send-btn:hover {\n  transform: scale(1.05);\n  background: #66b1ff;\n}\n\n.search-icon {\n  position: absolute;\n  bottom: 20px;\n  left: 20px;\n  color: #999;\n  font-size: 14px;\n  display: flex;\n  align-items: center;\n  gap: 5px;\n  background: #f5f7fa;\n  padding: 4px 12px;\n  border-radius: 12px;\n}\n\n/* Chat Box Styles */\n.chat-box {\n  background: #fff;\n  border: 1px solid #e0e0e0;\n  border-radius: 12px;\n  box-shadow: 0 4px 20px rgba(0,0,0,0.1);\n  display: flex;\n  flex-direction: column;\n  height: 500px;\n  overflow: hidden;\n}\n\n.chat-header {\n  padding: 15px 20px;\n  border-bottom: 1px solid #eee;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  background-color: #f9f9f9;\n  font-weight: 600;\n}\n\n.close-chat {\n  cursor: pointer;\n  font-size: 18px;\n  color: #999;\n}\n\n.close-chat:hover {\n  color: #333;\n}\n\n.chat-messages {\n  flex: 1;\n  padding: 20px;\n  overflow-y: auto;\n  display: flex;\n  flex-direction: column;\n  gap: 15px;\n}\n\n.message {\n  display: flex;\n  gap: 10px;\n  max-width: 80%;\n}\n\n.message.ai {\n  align-self: flex-start;\n}\n\n.message.user {\n  align-self: flex-end;\n  flex-direction: row-reverse;\n}\n\n.avatar {\n  width: 36px;\n  height: 36px;\n  border-radius: 50%;\n  background-color: #f0f2f5;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n}\n\n.message.user .avatar {\n  background-color: #409EFF;\n  color: #fff;\n}\n\n.content {\n  background-color: #f0f2f5;\n  padding: 10px 15px;\n  border-radius: 12px;\n  font-size: 14px;\n  line-height: 1.5;\n}\n\n.message.user .content {\n  background-color: #409EFF;\n  color: #fff;\n}\n\n.chat-input {\n  padding: 15px;\n  border-top: 1px solid #eee;\n}\n</style>",
        "preview": "<template>\n  <div class=\"input-section\">\n    <div class=\"mascot-float\">\n      <img src=\"https://img.yzcdn.cn/vant/cat.jpeg\" alt=\"Mascot\" class=\"mascot-img-small\" />\n    </div>\n    \n    <div class=\"input-box\" v-if=\"!showChat\">\n      <textarea \n        v-model=\"initialQuery\"\n        class=\"custom-textarea\" \n        placeholder=\"求职路上，随时戳球球助阵！\"\n        rows=\"3\"\n        @keydown.enter.prevent=\"startChat\"\n      ></textarea>\n      <div class=\"send-btn\" @click=\"startChat\">\n        <el-icon><Top /></el-i...",
