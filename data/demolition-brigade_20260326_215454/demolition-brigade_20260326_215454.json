      "content": {
        "raw": "<template>\n  <div class=\"app-container-bg career-news-container\">\n    <div class=\"background-shape-global\"></div>\n    \n    <div class=\"content-wrapper\">\n      <h1>职业新闻</h1>\n      \n      <div class=\"news-tabs common-card\">\n        <el-tabs v-model=\"activeTab\">\n          <el-tab-pane label=\"政策趋势\" name=\"policy\">\n            <div class=\"news-list\">\n              <div class=\"news-item\" v-for=\"item in policyNews\" :key=\"item.id\">\n                <div class=\"news-title\">{{ item.title }}</div>\n                <div class=\"news-meta\">\n                  <span class=\"source\">{{ item.source }}</span>\n                  <span class=\"date\">{{ item.date }}</span>\n                </div>\n                <div class=\"news-summary\">{{ item.summary }}</div>\n              </div>\n            </div>\n          </el-tab-pane>\n          <el-tab-pane label=\"校招信息\" name=\"campus\">\n            <div class=\"news-list\">\n              <div class=\"news-item\" v-for=\"item in campusNews\" :key=\"item.id\">\n                <div class=\"news-title\">{{ item.title }}</div>\n                <div class=\"news-meta\">\n                  <span class=\"source\">{{ item.company }}</span>\n                  <span class=\"date\">{{ item.date }}</span>\n                </div>\n                <div class=\"news-summary\">{{ item.summary }}</div>\n              </div>\n            </div>\n          </el-tab-pane>\n          <el-tab-pane label=\"行业动态\" name=\"industry\">\n            <el-empty description=\"暂无相关动态\" />\n          </el-tab-pane>\n        </el-tabs>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\n\nconst activeTab = ref('policy')\n\nconst policyNews = ref([\n  {\n    id: 1,\n    title: '关于进一步做好高校毕业生就业工作的通知',\n    source: '教育部',\n    date: '2025-03-15',\n    summary: '教育部发布最新通知，强调加强校企合作，拓宽就业渠道...'\n  },\n  {\n    id: 2,\n    title: '新兴产业人才需求白皮书发布',\n    source: '人社部',\n    date: '2025-03-10',\n    summary: '人工智能、大数据等领域人才缺口持续扩大...'\n  }\n])\n\nconst campusNews = ref([\n  {\n    id: 101,\n    title: '2026届校园招聘启动',\n    company: '某知名互联网大厂',\n    date: '2025-03-12',\n    summary: '面向全球招募研发、产品、运营等岗位优秀毕业生...'\n  },\n  {\n    id: 102,\n    title: '金融科技专场招聘会',\n    company: '某国有银行',\n    date: '2025-03-08',\n    summary: '诚邀计算机、金融复合背景人才加入...'\n  }\n])\n</script>\n\n<style scoped>\n.career-news-container {\n  padding: 40px 20px;\n}\n\n.content-wrapper {\n  max-width: 1200px;\n  margin: 0 auto;\n  position: relative;\n  z-index: 1;\n  display: flex;\n  flex-direction: column;\n  gap: 30px;\n}\n\n.news-tabs {\n  padding: 30px;\n}\n\n.news-list {\n  display: flex;\n  flex-direction: column;\n  gap: 20px;\n  margin-top: 20px;\n}\n\n.news-item {\n  border-bottom: 1px solid #eaeaea;\n  padding-bottom: 20px;\n  cursor: pointer;\n  transition: all 0.2s;\n  padding: 20px;\n  border-radius: 8px;\n}\n\n.news-item:hover {\n  background-color: #f9f9f9;\n  transform: translateX(5px);\n}\n\n.news-title {\n  font-size: 18px;\n  font-weight: 600;\n  color: #333;\n  margin-bottom: 8px;\n}\n\n.news-meta {\n  font-size: 12px;\n  color: #999;\n  margin-bottom: 8px;\n  display: flex;\n  gap: 15px;\n}\n\n.news-summary {\n  font-size: 14px;\n  color: #666;\n  line-height: 1.6;\n}\n</style>",
