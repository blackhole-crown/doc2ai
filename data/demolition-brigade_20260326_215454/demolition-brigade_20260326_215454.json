      "content": {
        "raw": "<template>\n  <div class=\"app-container-bg job-analysis-container\">\n    <div class=\"background-shape-global\"></div>\n    \n    <div class=\"content-wrapper\">\n      <h1>岗位分析</h1>\n      <div class=\"filter-section common-card\">\n        <el-input v-model=\"searchQuery\" placeholder=\"搜索岗位\" class=\"search-input\" clearable>\n          <template #append>\n            <el-button :icon=\"Search\" />\n          </template>\n        </el-input>\n        <el-select v-model=\"selectedIndustry\" placeholder=\"选择行业\" class=\"filter-select\">\n          <el-option label=\"互联网\" value=\"it\" />\n          <el-option label=\"金融\" value=\"finance\" />\n          <el-option label=\"教育\" value=\"education\" />\n        </el-select>\n      </div>\n\n      <el-tabs v-model=\"activeTab\" @tab-change=\"handleTabChange\" class=\"graph-tabs\">\n        <el-tab-pane label=\"纵向晋升图谱\" name=\"promotion\"></el-tab-pane>\n        <el-tab-pane label=\"横向换岗图谱\" name=\"transfer\"></el-tab-pane>\n      </el-tabs>\n      \n      <div class=\"graph-container common-card\" ref=\"graphRef\"></div>\n      \n      <div class=\"job-details common-card\" v-if=\"selectedJob\">\n        <h3>{{ selectedJob.name }}</h3>\n        <p><strong>薪资范围：</strong>{{ selectedJob.salary }}</p>\n        <p><strong>职责描述：</strong>{{ selectedJob.description }}</p>\n        <p><strong>技能标签：</strong></p>\n        <div class=\"tags\">\n          <el-tag v-for=\"tag in selectedJob.tags\" :key=\"tag\" class=\"job-tag\" effect=\"light\">{{ tag }}</el-tag>\n        </div>\n      </div>\n\n      <AiChatBox />\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { ref, onMounted, onUnmounted, watch } from 'vue'\nimport { Search } from '@element-plus/icons-vue'\nimport * as echarts from 'echarts'\nimport AiChatBox from '../components/AiChatBox.vue'\n\nconst searchQuery = ref('')\nconst selectedIndustry = ref('it')\nconst graphRef = ref(null)\nconst selectedJob = ref(null)\nconst activeTab = ref('promotion')\nlet chartInstance = null\n\n// Mock Data\nconst promotionData = {\n  title: '互联网技术岗晋升路径',\n  nodes: [\n    { name: '实习生', value: 1, category: 0, symbolSize: 40 },\n    { name: '初级工程师', value: 2, category: 0, symbolSize: 50 },\n    { name: '中级工程师', value: 3, category: 0, symbolSize: 60 },\n    { name: '高级工程师', value: 4, category: 0, symbolSize: 70 },\n    { name: '技术专家', value: 5, category: 1, symbolSize: 80 },\n    { name: '架构师', value: 5, category: 1, symbolSize: 80 },\n    { name: 'CTO', value: 6, category: 2, symbolSize: 90 }\n  ],\n  links: [\n    { source: '实习生', target: '初级工程师' },\n    { source: '初级工程师', target: '中级工程师' },\n    { source: '中级工程师', target: '高级工程师' },\n    { source: '高级工程师', target: '技术专家' },\n    { source: '高级工程师', target: '架构师' },\n    { source: '技术专家', target: 'CTO' },\n    { source: '架构师', target: 'CTO' }\n  ],\n  categories: [{ name: '基础岗' }, { name: '专家岗' }, { name: '管理岗' }]\n}\n\nconst transferData = {\n  title: '前端开发转岗路径',\n  nodes: [\n    { name: '前端开发', category: 0, symbolSize: 80, itemStyle: { color: '#409EFF' } },\n    { name: '全栈开发', category: 1, symbolSize: 60 },\n    { name: 'Node.js后端', category: 1, symbolSize: 60 },\n    { name: '产品经理', category: 2, symbolSize: 60 },\n    { name: 'UI设计', category: 2, symbolSize: 60 },\n    { name: '测试开发', category: 1, symbolSize: 60 },\n    { name: '项目经理', category: 2, symbolSize: 60 }\n  ],\n  links: [\n    { source: '前端开发', target: '全栈开发' },\n    { source: '前端开发', target: 'Node.js后端' },\n    { source: '前端开发', target: '产品经理' },\n    { source: '前端开发', target: 'UI设计' },\n    { source: '前端开发', target: '测试开发' },\n    { source: '前端开发', target: '项目经理' }\n  ],\n  categories: [{ name: '核心岗' }, { name: '技术方向' }, { name: '非技术方向' }]\n}\n\nconst getOption = (type) => {\n  const data = type === 'promotion' ? promotionData : transferData\n  \n  return {\n    title: {\n      text: data.title,\n      left: 'center',\n      textStyle: { color: '#333', fontSize: 16 }\n    },\n    tooltip: {},\n    legend: [{\n      bottom: 10,\n      data: data.categories.map(function (a) {\n        return a.name;\n      })\n    }],\n    series: [\n      {\n        type: 'graph',\n        layout: 'force',\n        animation: true,\n        label: {\n          show: true,\n          position: 'right',\n          formatter: '{b}',\n          color: '#666'\n        },\n        draggable: true,\n        data: data.nodes.map(node => ({\n          ...node,\n          itemStyle: node.itemStyle || {\n            shadowBlur: 10,\n            shadowColor: 'rgba(0,0,0,0.1)'\n          }\n        })),\n        categories: data.categories,\n        force: {\n          repulsion: 500,\n          edgeLength: type === 'promotion' ? [50, 150] : [100, 200],\n          gravity: 0.1\n        },\n        edges: data.links,\n        edgeSymbol: ['circle', 'arrow'],\n        edgeSymbolSize: [4, 10],\n        lineStyle: {\n          color: 'source',\n          curveness: 0.1,\n          width: 2\n        }\n      }\n    ]\n  }\n}\n\nconst initGraph = () => {\n  if (graphRef.value) {\n    if (chartInstance) {\n      chartInstance.dispose()\n    }\n    chartInstance = echarts.init(graphRef.value)\n    renderGraph()\n    \n    chartInstance.on('click', (params) => {\n      if (params.dataType === 'node') {\n        selectedJob.value = {\n          name: params.name,\n          salary: params.name.includes('高级') || params.name.includes('专家') ? '25k-50k' : '15k-25k',\n          description: `这是关于${params.name}的详细职位描述，包含日常工作内容和核心职责。`,\n          tags: ['Vue', 'React', 'JavaScript', 'HTML/CSS', 'Node.js'].slice(0, Math.floor(Math.random() * 3) + 2)\n        }\n      }\n    })\n  }\n}\n\nconst renderGraph = () => {\n  if (chartInstance) {\n    chartInstance.setOption(getOption(activeTab.value))\n  }\n}\n\nconst handleTabChange = () => {\n  renderGraph()\n  selectedJob.value = null\n}\n\nonMounted(() => {\n  initGraph()\n  window.addEventListener('resize', handleResize)\n})\n\nonUnmounted(() => {\n  window.removeEventListener('resize', handleResize)\n  if (chartInstance) {\n    chartInstance.dispose()\n  }\n})\n\nconst handleResize = () => {\n  if (chartInstance) {\n    chartInstance.resize()\n  }\n}\n</script>\n\n<style scoped>\n.job-analysis-container {\n  padding: 40px 20px;\n}\n\n.content-wrapper {\n  max-width: 1200px;\n  margin: 0 auto;\n  position: relative;\n  z-index: 1;\n  display: flex;\n  flex-direction: column;\n  gap: 30px;\n}\n\n.filter-section {\n  display: flex;\n  gap: 20px;\n  padding: 20px;\n}\n\n.search-input {\n  width: 300px;\n}\n\n.filter-select {\n  width: 200px;\n}\n\n.graph-container {\n  width: 100%;\n  height: 600px;\n  background-color: #fff;\n}\n\n.job-details {\n  padding: 30px;\n  animation: slideIn 0.3s ease-out;\n}\n\n@keyframes slideIn {\n  from { opacity: 0; transform: translateY(20px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n\n.tags {\n  display: flex;\n  gap: 10px;\n  flex-wrap: wrap;\n  margin-top: 10px;\n}\n</style>",
