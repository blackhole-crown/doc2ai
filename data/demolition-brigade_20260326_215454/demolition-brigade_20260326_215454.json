       WebDriverWait(driver, 15).until(\n                EC.url_contains(f\"pageNo={page_num}\")\n            )\n            print(f\"âœ… URLå·²æ›´æ–°åˆ°ç¬¬ {page_num} é¡µ\")\n            \n            # é¢�å¤–ç­‰å¾…é¡µé�¢å†…å®¹åŠ è½½\n            time.sleep(2)\n            \n            # éªŒè¯�å½“å‰�é¡µç �æ˜¯å�¦æ­£ç¡®\n            try:\n                now_page, _ = get_page_info(driver)\n                if now_page != page_num:\n                    print(f\"âš ï¸� é¡µç �ä¸�åŒ¹é…�ï¼šå½“å‰�æ˜¾ç¤ºç¬¬{now_page}é¡µï¼ŒæœŸæœ›ç¬¬{page_num}é¡µ\")\n                    # å°�è¯•ç›´æ�¥é€šè¿‡URLè®¿é—®\n                    url = f\"http://job.mohrss.gov.cn/cjobs/institution/listInstitution?pageNo={page_num}&origin=\"\n                    driver.get(url)\n                    time.sleep(2)\n            except:\n                pass\n            \n            # æ��å�–å½“å‰�é¡µæ•°æ�®\n            page_data = extract_page_data(driver, page_num)\n            all_new_data.extend(page_data)\n            \n            # å¦‚æ�œæ²¡æœ‰æ–°æ•°æ�®ï¼Œå�¯ä»¥ç»§ç»­çˆ¬å�–ï¼ˆå�¯èƒ½éƒ½æ˜¯é‡�å¤�çš„ï¼‰\n            \n        except Exception as e:\n            print(f\"â�Œ ç¬¬{page_num}é¡µçˆ¬å�–å¤±è´¥ï¼š{str(e)[:80]}\")\n            # å°�è¯•ç›´æ�¥URLè®¿é—®ä½œä¸ºå¤‡é€‰\n            try:\n                url = f\"http://job.mohrss.gov.cn/cjobs/institution/listInstitution?pageNo={page_num}&origin=\"\n                driver.get(url)\n                time.sleep(3)\n                page_data = extract_page_data(driver, page_num)\n                all_new_data.extend(page_data)\n            except:\n                print(f\"â�Œ å¤‡é€‰æ–¹æ¡ˆä¹Ÿå¤±è´¥ï¼Œå�œæ­¢çˆ¬å�–\")\n                break\n    \n    # å…³é—­æµ�è§ˆå™¨\n    driver.quit()\n    return all_new_data\n\n# ========== æ–°å¢�çš„æ•°æ�®åº“ä¿�å­˜å‡½æ•° ==========\ndef save_to_database(news_items):\n    \"\"\"ä¿�å­˜æ•°æ�®åˆ°æ•°æ�®åº“ï¼ˆæ–°å¢�åŠŸèƒ½ï¼Œä¸�å½±å“�å�Ÿæœ‰é€»è¾‘ï¼‰\"\"\"\n    if not news_items:\n        return\n    \n    # æ£€æŸ¥æ•°æ�®åº“è¿�æ�¥